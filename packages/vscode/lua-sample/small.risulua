local function elIsLeap(y) return (y%4==0 and y%100~=0) or (y%400==0) end
local function elDIM(y,m)
    local d={31,28,31,30,31,30,31,31,30,31,30,31}
    if m==2 and elIsLeap(y) then return 29 end
    return d[m]
end
local function elDOW(y,m,d)
    if m<3 then m=m+12; y=y-1 end
    return (d+math.floor(13*(m+1)/5)+y+math.floor(y/4)-math.floor(y/100)+math.floor(y/400)+6)%7
end

function elBuildCalendar(triggerId)
    local lang   = tonumber(getChatVar(triggerId,"el_lang") or "1") or 1
    local baseY  = tonumber(getChatVar(triggerId,"el_cur_year") or "2042") or 2042
    local baseM  = tonumber(getChatVar(triggerId,"el_cur_month") or "3") or 3
    local offset = tonumber(getChatVar(triggerId,"el_cal_offset") or "0") or 0

    local totalM = (baseY * 12 + baseM - 1) + offset
    local viewY  = math.floor(totalM / 12)
    local viewM  = (totalM % 12) + 1

    local mN
    if lang==2 then mN={"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"}
    elseif lang==3 then mN={"1月","2月","3月","4月","5月","6月","7月","8月","9月","10月","11月","12月"}
    else mN={"1월","2월","3월","4월","5월","6월","7월","8월","9월","10월","11월","12월"} end

    local dH
    if lang==2 then dH={"S","M","T","W","T","F","S"}
    elseif lang==3 then dH={"日","月","火","水","木","金","土"}
    else dH={"일","월","화","수","목","금","토"} end

    local dim  = elDIM(viewY, viewM)
    local fDow = elDOW(viewY, viewM, 1)
    local evts = (EL_EVENTS[viewY] or {})[viewM] or {}

    local curD = tostring(getChatVar(triggerId,"el_cur_date") or "")
    local tY, tM, tD = curD:match("(%d+)%-(%d+)%-(%d+)")
    tY = tonumber(tY) or 0
    tM = tonumber(tM) or 0
    tD = tonumber(tD) or 0

    local h = '<div class="elp-cal-hd">'
    h = h .. '<button class="elp-cal-arr" risu-trigger="EL_CalPrev">◀</button>'
    h = h .. '<span class="elp-cal-mo">' .. viewY .. ' ' .. mN[viewM] .. '</span>'
    h = h .. '<button class="elp-cal-arr" risu-trigger="EL_CalNext">▶</button>'
    h = h .. '</div><div class="elp-cal-g">'

    for i, dv in ipairs(dH) do
        local c = "elp-cal-dh"
        if i==1 then c=c.." elp-sun" end
        if i==7 then c=c.." elp-sat" end
        h = h .. '<div class="'..c..'">'..dv..'</div>'
    end
    for _=1,fDow do h = h .. '<div class="elp-cal-e"></div>' end
    for d=1,dim do
        local dow = (fDow+d-1)%7
        local c = "elp-cal-d"
        if dow==0 then c=c.." elp-sun" end
        if dow==6 then c=c.." elp-sat" end
        if d==tD and viewM==tM and viewY==tY then c=c.." elp-cal-today" end
        local ev = evts[d]
        local eT = ""
        if ev then
            c=c.." elp-cal-ev"
            if lang==2 then eT=ev.en or "" elseif lang==3 then eT=ev.ja or "" else eT=ev.ko or "" end
        end
        if eT ~= "" then
            h = h .. '<div class="'..c..'" data-tooltip="'..eT..'">'
        else
            h = h .. '<div class="'..c..'">'
        end
        h = h .. '<span class="elp-cal-n">'..d..'</span>'
        h = h .. '</div>'
    end
    h = h .. '</div>'
    return h
end

function elUpdateCalVar(triggerId)
    local html = elBuildCalendar(triggerId)
    setChatVar(triggerId, "el_cal_html", html)
end

