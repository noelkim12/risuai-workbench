-- ============================================
-- Elysion 퍼메 선택기
-- ============================================

function EL_SetLang_1(triggerId)
    setState(triggerId, "el_lang", 1)
    setChatVar(triggerId, "el_lang", "1")
    elUpdateCalVar(triggerId)
end
function EL_SetLang_2(triggerId)
    setState(triggerId, "el_lang", 2)
    setChatVar(triggerId, "el_lang", "2")
    elUpdateCalVar(triggerId)
end
function EL_SetLang_3(triggerId)
    setState(triggerId, "el_lang", 3)
    setChatVar(triggerId, "el_lang", "3")
    elUpdateCalVar(triggerId)
end

local function elUpdateFmInfo(triggerId, y, m, d, mapVal)
    if y and m and d then
        local dateStr = string.format("%04d-%02d-%02d", y, m, d)
        setChatVar(triggerId, "el_cur_date", dateStr)
        setChatVar(triggerId, "el_cur_year", tostring(y))
        setChatVar(triggerId, "el_cur_month", tostring(m))
    end
    if mapVal then
        setChatVar(triggerId, "el_cur_map", mapVal)
    end
    setChatVar(triggerId, "el_cal_offset", "0")
    setState(triggerId, "el_cal_offset", 0)
    elUpdateCalVar(triggerId)
end

function EL_SetFM_1(triggerId) setState(triggerId,"el_fm",1); setChatVar(triggerId,"el_fm","1"); elUpdateFmInfo(triggerId, 2042, 3, 28, "Map School main building") end
function EL_SetFM_2(triggerId) setState(triggerId,"el_fm",2); setChatVar(triggerId,"el_fm","2"); elUpdateFmInfo(triggerId, 2042, 3, 28, "Map Elysion Campus") end
function EL_SetFM_3(triggerId) setState(triggerId,"el_fm",3); setChatVar(triggerId,"el_fm","3"); elUpdateFmInfo(triggerId, 2042, 2, 17, "Map Port") end
function EL_SetFM_4(triggerId) setState(triggerId,"el_fm",4); setChatVar(triggerId,"el_fm","4"); elUpdateFmInfo(triggerId, 2042, 2, 26, "Map School main building") end
function EL_SetFM_5(triggerId) setState(triggerId,"el_fm",5); setChatVar(triggerId,"el_fm","5"); elUpdateFmInfo(triggerId, 2042, 3, 2, "Map Unknown") end
function EL_SetFM_6(triggerId) setState(triggerId,"el_fm",6); setChatVar(triggerId,"el_fm","6"); elUpdateFmInfo(triggerId, 2042, 3, 1, "Map Asia") end
function EL_SetFM_7(triggerId) setState(triggerId,"el_fm",7); setChatVar(triggerId,"el_fm","7"); elUpdateFmInfo(triggerId, 2042, 3, 15, "Map Port") end
function EL_SetFM_8(triggerId) setState(triggerId,"el_fm",8); setChatVar(triggerId,"el_fm","8"); elUpdateFmInfo(triggerId, nil, nil, nil, "Map Unknown") end

-- ============================================
-- Interface 태그 파싱 (onOutput 대신 listenEdit 사용)
-- ============================================
listenEdit('editOutput', function(triggerId, data)
    if not data or data == "" then return data end

    local date     = data:match("|%s*Date:%s*([^|]+)")
    local location = data:match("|%s*Location:%s*([^|]+)")
    local mapVal   = data:match("|%s*Map:%s*([^%]]+)")

    if date then
        date = date:gsub("^%s+",""):gsub("%s+$","")
        setChatVar(triggerId, "el_cur_date", date)
        local y, m = date:match("(%d+)%-(%d+)")
        if y and m then
            setChatVar(triggerId, "el_cur_year", y)
            setChatVar(triggerId, "el_cur_month", m)
        end
    end
    if location then
        location = location:gsub("^%s+",""):gsub("%s+$","")
        setChatVar(triggerId, "el_cur_location", location)
    end
    if mapVal then
        mapVal = mapVal:gsub("^%s+",""):gsub("%s+$","")
        setChatVar(triggerId, "el_cur_map", mapVal)
    end

    return data
end)

-- ============================================
-- 사이드 팝업 버튼 함수
-- ============================================

function EL_PopupClose(triggerId)
    setChatVar(triggerId, "el_popup", "0")
    setState(triggerId, "el_popup", 0)
end

function EL_Popup_1(triggerId)
    local cur = tostring(getChatVar(triggerId, "el_popup") or "0")
    setChatVar(triggerId, "el_popup", cur == "1" and "0" or "1")
    setState(triggerId, "el_popup", cur == "1" and 0 or 1)
end

function EL_Popup_2(triggerId)
    local cur = tostring(getChatVar(triggerId, "el_popup") or "0")
    local next = cur == "2" and "0" or "2"
    setChatVar(triggerId, "el_popup", next)
    setState(triggerId, "el_popup", tonumber(next))
    setChatVar(triggerId, "el_cal_offset", "0")
    setState(triggerId, "el_cal_offset", 0)
    elUpdateCalVar(triggerId)
end

function EL_Popup_3(triggerId)
    local cur = tostring(getChatVar(triggerId, "el_popup") or "0")
    setChatVar(triggerId, "el_popup", cur == "3" and "0" or "3")
    setState(triggerId, "el_popup", cur == "3" and 0 or 3)
end

function EL_Popup_4(triggerId)
    local cur = tostring(getChatVar(triggerId, "el_popup") or "0")
    setChatVar(triggerId, "el_popup", cur == "4" and "0" or "4")
    setState(triggerId, "el_popup", cur == "4" and 0 or 4)
end

function EL_CalPrev(triggerId)
    local o = tonumber(getChatVar(triggerId, "el_cal_offset") or "0") or 0
    setChatVar(triggerId, "el_cal_offset", tostring(o - 1))
    setState(triggerId, "el_cal_offset", o - 1)
    elUpdateCalVar(triggerId)
end

function EL_CalNext(triggerId)
    local o = tonumber(getChatVar(triggerId, "el_cal_offset") or "0") or 0
    setChatVar(triggerId, "el_cal_offset", tostring(o + 1))
    setState(triggerId, "el_cal_offset", o + 1)
    elUpdateCalVar(triggerId)
end

function EL_ToggleRandomEvent(triggerId)
    local cur = tostring(getChatVar(triggerId, "el_random_event") or "1")
    setChatVar(triggerId, "el_random_event", cur == "1" and "0" or "1")
    setState(triggerId, "el_random_event", cur == "1" and 0 or 1)
end

