-- 직업 / 소속
function assignOccupationAndAffiliation(ageType, minTier, maxTier)

    local schoolType = {
        JS = "Elementary School",
        JC = "Middle School",
        JK = "High School"
    }

    if schoolType[ageType] then

        local tiers = {

            [1] = { "Run-Down Public", "Underfunded Public", "Neglected District" },
            [2] = { "Low-Tier Public", "Aging Public", "Unremarkable District" },
            [3] = { "Average Public", "Standard Public", "Typical District" },
            [4] = { "Well-Regarded Public", "Respected Public", "High-Performing Public" },
            [5] = { "Prestigious Private", "Elite Private", "Top-Ranked Private" }

        }

        local tier = math.random(minTier, maxTier)
        local descriptor = tiers[tier][math.random(#tiers[tier])]

        return "Student", descriptor .. " " .. schoolType[ageType]
    -- =================================
    -- 성인 (Adult1 / Adult2)
    -- =================================
    elseif ageType == "Adult1" or ageType == "Adult2" then

        local tier = math.random(minTier, maxTier)

        -- ---------- Adult1 대학 ----------
        if ageType == "Adult1" and tier >= 3 and math.random() < 0.5 then

            local universities = {
                [3] = { "Average University" },
                [4] = { "Prestigious University" },
                [5] = { "Elite University" }
            }

            local uni = universities[tier][1]
            return "Student", uni
        end

        -- ---------- Adult2 주부 ----------
        if ageType == "Adult2" and tier >= 2 and math.random() < 0.15 then

            local households = {
                [2] = { "Troubled Household", "Financially Struggling Household", "Unstable Home" },
                [3] = { "Ordinary Household", "Modest Household", "Working-Class Family" },
                [4] = { "Stable Household", "Comfortable Household", "Well-Off Family" },
                [5] = { "Affluent Household", "Wealthy Family", "High-Society Household" }
            }

            local home = households[tier][math.random(#households[tier])]
            return "Housewife", home
        end

        -- ---------- 공용 직업 ----------
        local jobs = {
            [1] = { "Unemployed" },
            [2] = { "Part-Time Worker", "Service Worker", "Manual Worker", "Low-Skill Job Seeker" },
            [3] = { "Office Worker", "Administrative Staff", "Sales Staff", "Technical Staff", "Graphic Designer", "Public Sector Employee", "Self-Employed" ,"Job Seeker" },
            [4] = { "Office Worker", "Technical Staff", "Graphic Designer", "Educator", "Nurse", "Civil Servant", "Business Owner" },
            [5] = { "Office Worker", "Executive", "Doctor", "High-Ranking Civil Servant", "CEO" }
        }

        local job = jobs[tier][math.random(#jobs[tier])]
        local affiliation = ""

        -- ---------- 소속 생성 ----------
        if tier == 1 then
            affiliation = ""
        elseif tier == 2 then
            affiliation = "Local Business"
        elseif tier == 3 then
            affiliation = "Standard Corporation"
        elseif tier == 4 then
            affiliation = "Major Organization"
        elseif tier == 5 then
            affiliation = "Top-Tier Institution"
        end

        -- 소속 없음 (자영업 / 구직자 등)
        if job == "Unemployed"
        or job == "Self-Employed"
        or job == "Business Owner"
        or job == "Low-Skill Job Seeker"
        or job == "Job Seeker" then
            affiliation = ""

        -- CEO (자기 회사)
        elseif job == "CEO" then
            affiliation = "Own Company"

        -- 공공기관 계열
        elseif job == "Public Sector Employee"
        or job == "Civil Servant"
        or job == "High-Ranking Civil Servant"
        or job == "Educator"
        or job == "Nurse" then
            affiliation = "Public Institution"
        end

        return job, affiliation
    end

    return "", ""
end

function addTraitByName(traitName, traitVar, additionalVar)

    local traitData = loadTraitData()
    local trait = traitData[traitName]

    if trait ~= nil then
        
        local value = traitName .. ": " .. trait.desc
        traitVar = appendPipe(traitVar, value)

        if trait.additional ~= nil then
            additionalVar = appendComma(additionalVar, trait.additional)
        end
    end

    return traitVar, additionalVar
end

