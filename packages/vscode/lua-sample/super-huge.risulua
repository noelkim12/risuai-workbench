function describeArousalLocal(t, v)

    local base

    if v < 15 then
        base = "No arousal whatsoever, with no visible physiological response."
    elseif v < 30 then
        base = "Minimal arousal; barely noticeable physiological response."
    elseif v < 45 then
        base = "Low arousal; very slight internal tension or warmth."
    elseif v < 60 then
        base = "Mild arousal; Subtle physiological response; breathing may shift slightly."
    elseif v < 75 then
        base = "Mild but noticeable physiological arousal."
    elseif v < 90 then
        base = "Clear physiological signs, such as steadier breathing changes."
    elseif v < 105 then
        base = "Sustained physiological arousal; posture visibly affected."
    elseif v < 120 then
        base = "Strong physiological response; movement slightly unsteady."
    elseif v < 135 then
        base = "Very strong physiological arousal; composure may waver."
    else
        base = "Overwhelming physiological arousal; body control noticeably reduced."
    end

    local ct_Target_ResponseArousal = safeGet(t, "ct_Target_ResponseArousal", "")
    local list = splitPipe(ct_Target_ResponseArousal)

    if #list < 10 then
        return base
    end

    local extra

    if v < 15 then
        return base
    elseif v < 30 then
        extra = list[1]
    elseif v < 45 then
        extra = list[2]
    elseif v < 60 then
        extra = list[3]
    elseif v < 75 then
        extra = list[4]
    elseif v < 90 then
        extra = list[5]
    elseif v < 105 then
        extra = list[6]
    elseif v < 120 then
        extra = list[7]
    elseif v < 135 then
        extra = list[8]
    elseif v < 150 then
        extra = list[9]
    else
        extra = list[10]
    end

    local targetName = safeGet(t, "ct_Target_Name", "")
    local targetCode = findCharacterCode(t, targetName)

    local corr = 0
    local corrExtra = ""

    if targetCode then
        local clearFlag = tostring(getChatVar(triggerId, "ct_Target_Clear") or "0")
        corr = tonumber(safeGet(t, targetCode .. "_Corruption", "0")) or 0

        if corr >= 100 then
            if (clearFlag == "1" and v >= 135) or v >= 150 then
                corrExtra = " Completely driven by the overwhelming need for the pleasure " .. getPersonaName(triggerId) .. " gives, relentlessly craving every moment of sex with " .. getPersonaName(triggerId) .. ". The negative feelings once felt—such as hatred or disgust—transform into a twisted mix of love and hate, without any resistance or hesitation towards " .. getPersonaName(triggerId) .. ", fully accepting everything and eagerly seeking pleasure. Having lost her reason to the pleasure, she is fully absorbed in the moment and has no desire to stop, wishing it to continue indefinitely."
