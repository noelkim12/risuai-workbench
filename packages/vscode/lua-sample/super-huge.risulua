end

-- ==========================================
-- 모든 캐릭터 Overview 통합
-- ==========================================
function buildAllCharacterOverview(triggerId)

    local charList = safeGet(triggerId, "ct_CharList", "")
    local targetName = safeGet(triggerId, "ct_Target_Name", "")

    local others = {}     -- 대상 제외 캐릭터
    local targetCode = nil -- 대상 캐릭터 코드

    local objectiveCode = safeGet(triggerId, "ct_Char_Objective", "")

    -- ======================================
    -- 1. 캐릭터 분류
    -- ======================================
    for token in string.gmatch(charList, "([^|]+)") do

        local code, name = token:match("^(C%d+)%=(.+)$")

        if code and name then
            if name == targetName then
                targetCode = code
            else
                table.insert(others, code)
            end
        end
    end

    -- ======================================
    -- 2. 랜덤 섞기 (Fisher-Yates)
    -- ======================================
    for i = #others, 2, -1 do
        local j = math.random(i)
        others[i], others[j] = others[j], others[i]
    end

    -- ======================================
    -- 3. 최대 5명 선택
    -- ======================================
    local selected = {}

    for i = 1, math.min(5, #others) do
        table.insert(selected, others[i])
    end

    -- ======================================
    -- Objective 캐릭터 강제 포함
    -- ======================================
    if objectiveCode ~= "" then

        local found = false

        for _, c in ipairs(selected) do
            if c == objectiveCode then
                found = true
                break
            end
        end

        if not found then
            if #selected >= 5 then
                selected[5] = objectiveCode  -- 마지막 자리 교체
            else
                table.insert(selected, objectiveCode)
            end
        end
    end

    -- ======================================
    -- 4. 부족하면 대상 포함
    -- ======================================
    if #selected < 5 and targetCode then
        table.insert(selected, targetCode)
    end

    -- ======================================
    -- 5. Overview 합치기
    -- ======================================
    local result = ""

    for _, code in ipairs(selected) do

        local overviewKey = code .. "_Overview"
        local overview = safeGet(triggerId, overviewKey, "")

        if overview ~= "" then
            -- 결과 합치기
            if result == "" then
                result = overview
            else
                result = result .. "\n" .. overview
            end
        end
    end

    -- ======================================
    -- 6. 저장 (덮어쓰기)
    -- ======================================
    setChatVar(triggerId, "ct_Char_Overview", result)

end

