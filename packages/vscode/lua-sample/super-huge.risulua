    local function isEmpty(s)
        return (s == nil) or (tostring(s) == "")
    end

    local function addLine(t, label, value)
        if not isEmpty(value) then
            table.insert(t, label .. ": " .. tostring(value))
        end
    end

    local function addRawLine(t, text)
        if not isEmpty(text) then
            table.insert(t, tostring(text))
        end
    end

    local function addSection(out, header, lines)
        if lines and #lines > 0 then
            table.insert(out, "### " .. header)
            for _, ln in ipairs(lines) do
                table.insert(out, ln)
            end
            table.insert(out, "") -- blank line
        end
    end


