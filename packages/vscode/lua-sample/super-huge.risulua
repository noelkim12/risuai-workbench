                    return "[Chikan Message: "
                        .. icon .. " "
                        .. "Lv." .. lvl .. " "
                        .. name
                        .. targetText
                        .. ": "
                        .. "🎲 " .. dice .. " (" .. th .. ")"
                        .. statText
                        .. "]"
                end

                local actMsg1 = buildActionMessage(action1, type1, target1, lvl1, dice1, th1, a1, al1, at1)
                local actMsg2 = buildActionMessage(action2, type2, target2, lvl2, dice2, th2, a2, al2, at2)
                if actMsg1 then table.insert(statLines, actMsg1) end
                if actMsg2 then table.insert(statLines, actMsg2) end

                local function statLine(label, cur, nxt)
                    local diff = nxt - cur

                    local sign = diff > 0 and "+" or ""

                    local maxValue = 100
                    if label == "흥분" then
                        maxValue = 150
                    end

                    return "[Chikan Message: "
                        .. label .. " " .. nxt .. " / " .. maxValue .. " ("
                        .. sign .. diff .. ")]"
                end

                local s1 = statLine("흥분", curArousal, nextArousal)
                local s2 = statLine("경계", curAlert, nextAlert)
                local s3 = statLine("발각", curAttention, nextAttention)

                if s1 then table.insert(statLines, s1) end
                if s2 then table.insert(statLines, s2) end
                if s3 then table.insert(statLines, s3) end

                -- ======================================
                -- Preparation 메시지 추가
                -- ======================================
                if prepExtraMessage ~= "" then
                    table.insert(statLines, "[Chikan Message: " .. prepExtraMessage .. "]")
                end

                if #statLines > 0 then
                    text = text .. "\n" .. table.concat(statLines, "\n")
                end

                if #extraChikanMessages > 0 then
                    for _, msg in ipairs(extraChikanMessages) do
                        text = text .. "\n[Chikan Message: " .. msg .. "]"
                    end
                end

                setChat(t, cl - 1, text)
                handled = true
            end
        end

        if not handled then
            local text = line1 .. "\n" .. line2 .. statusBlock
            addChat(t, "user", text)
        end
    -- =====================================================
    -- 🏁 결과 분기
    -- =====================================================
    elseif actionType == "result" or actionType == "exit" or actionType == "toiletexit" or actionType == "gangbangexit" or actionType == "homeexit" then

        local isExit   = (actionType == "exit")
        local isToiletExit  = (actionType == "toiletexit")
        local isGangbangExit = (actionType == "gangbangexit")
        local isHomeExit = (actionType == "homeexit")

        setChatVar(t, "ct_Mode", "1")

        buildAllCharacterOverview(t)

        local clearFlag = tostring(getChatVar(t, "ct_Target_Clear") or "0")

        local resultText = ""
        local targetName = safeGet(t, "ct_Target_Name", "Target")
        if actionType ~= "exit" then
            resultText = "(Chikan targeting " .. targetName .. " has ended.)"
        else
            resultText = "({{user}} has stopped the Chikan.)"

            local stops  = tonumber(getChatVar(t, "ct_Target_Stops") or "0") or 0
            local remain = tonumber(getChatVar(t, "ct_Target_RemainStops") or "0") or 0

            if stops ~= remain and clearFlag ~= "1" then
                local traitRaw = tostring(getChatVar(t, "ct_Target_Trait") or "")
                if string.find(traitRaw, "Chikan Slayer", 1, true) then
                    resultText = resultText .. "\n" .. "▷ [The heroine immediately takes decisive action, raising her phone while publicly accusing {{user}} of being a molester and calling for intervention—exaggerating what happened and adding accusations of even more blatant acts.]"
                end
            end
        end

        if isToiletExit then
            resultText = resultText .. "\n▷ [{{user}} stops the sexual activity and leaves the heroine behind in the restroom. Describe the process of {{user}} completing what he is currently doing, finishing it fully, before leaving. When {{user}} leaves the area, he is immediately transferred back to the train.]"
        elseif isGangbangExit then
            resultText = resultText .. "\n▷ [The Crowd that was gangbanging the heroine disperses. Describe the process of {{user}} and the crowd completing what they are currently doing, finishing it fully, before dispersing. The heroine leaves the area, whether by her own will or by rescue.]"
        elseif isHomeExit then
            resultText = resultText .. "\n▷ [{{user}} stops the sexual activity and leaves the heroine behind in the house. Describe the process of {{user}} completing what he is currently doing, finishing it fully, before leaving. When {{user}} leaves the area, he is immediately transferred back to the train.]"
        end

        -- 인풋 교체
        local lang = tonumber(safeGet(t, "ct_Language", "1")) or 1
        local outcomeText

        if clearFlag == "1" then
            outcomeText = "This Chikan was a success."
        else
            outcomeText = "This Chikan was a failure."
        end

        local naText

        if lang == 1 then
            naText = "해당 없음"
        elseif lang == 2 then
            naText = "Not Applicable"
        elseif lang == 3 then
            naText = "該当なし"
        end

        local newInput = ""

        -- 🔹 종료 문장
        local commonEndLine =
            "\n▷ [This Chikan that targeted " .. targetName .. " has concluded. " .. outcomeText .. "]"
            .. "\n▷ [Remove the Heroine and Crowd entries from the Status Window, and set the Positioning field to " .. naText .. " in the Chikan entry.]"

        if isExit then
            commonEndLine = commonEndLine
                .. "\n▷ [{{user}} has decided to stop the Chikan. Describe the process of {{user}} stopping the act, disengaging from the current situation, separating from the heroine, and leaving the area.]"
        end

        -- 현재 세션 요약 넣기
        local useMemory = tostring(getChatVar(t, "ct_UseMemory") or "0")
        if useMemory == "1" then
            newInput = newInput .. "[Current Session Summary]\n"
        end

        newInput = newInput
            .. resultText
            .. commonEndLine
            .. "\n▷ [Advance the Daypart by one stage (🌅 → ☀️ → 🌇 → 🌙). If the current Daypart is 🌙, update the Date to the next day and set the Daypart to 🌅.]"
            .. (actionType ~= "result" and ("\n▷ [After separating from " .. targetName .. ", ") or ("\n▷ ["))
            .. "{{user}} must not encounter, approach, or be near any heroines, including " .. targetName .. ". No interaction, implication, foreshadowing, or suggestion of any future meeting is allowed. You must output exactly 5 Choices at the end.]"

        local extraClear = tonumber(getChatVar(t, "ct_Target_Extra") or "0") or 0
        if extraClear > 0 then
            newInput = newInput .. "\n[Chikan Message: 치한을 중단합니다 (x1.5 EXP)]"
        end
            
        local cl = getChatLength(t)

        if cl > 0 then
            local last = getChat(t, cl - 1)

            if last and last.role == "user" then
                setChat(t, cl - 1, newInput)
            else
                addChat(t, "user", newInput)
            end
        else
            addChat(t, "user", newInput)
        end
    end

end)

-- ==========================================
-- 우측 버튼
-- ==========================================
setAutoSuccess = async(function(triggerId)
    local current = safeGet(triggerId, "ct_AutoSuccess", "없음")

    local message =
        "입력한 값 이하의 실패 확률을 가진 액션은 반드시 성공합니다.\n" ..
        "0 ~ 100 사이의 숫자를 입력해주세요.\n\n" ..
        "현재: " .. current

    local input = alertInput(triggerId, message):await()

    -- 입력 취소 시 아무것도 안 함
    if not input or input:match("^%s*$") then
        return
    end

    local num = tonumber(input)

    -- 숫자 검사
    if not num then
        alertError(triggerId, "❌ 숫자만 입력 가능합니다.")
        return
    end

    -- 범위 제한 (원하면 제거 가능)
    if num < 0 or num > 100 then
        alertError(triggerId, "❌ 0 ~ 100 사이의 값만 입력 가능합니다.")
        return
    end

    -- 저장
    setChatVar(triggerId, "ct_AutoSuccess", tostring(num))
end)

function toggleStretchSpeech(triggerId)

    local v = safeGet(triggerId, "ct_NoStretchSpeech", "0")

    if v == "1" then
        setChatVar(triggerId, "ct_NoStretchSpeech", "0")
    else
        setChatVar(triggerId, "ct_NoStretchSpeech", "1")
    end

end

function toggleAutoOffAfterClear(triggerId)

    local v = safeGet(triggerId, "ct_AutoOffAfterClear", "0")

    if v == "1" then
        setChatVar(triggerId, "ct_AutoOffAfterClear", "0")
    else
        setChatVar(triggerId, "ct_AutoOffAfterClear", "1")
    end

end

function toggleOnlyExpansion(triggerId)

    local v = safeGet(triggerId, "ct_OnlyExpansion", "0")

    if v == "1" then
        setChatVar(triggerId, "ct_OnlyExpansion", "0")
    else
        setChatVar(triggerId, "ct_OnlyExpansion", "1")
    end

end

function addExpansionCharacter(triggerId)
    local level = tonumber(safeGet(triggerId, "ct_ChikanLevel", "1")) or 1

    local oldList = safeGet(triggerId, "ct_CharList", "")
    local addedNames = {}

    while true do

        local before = safeGet(triggerId, "ct_CharList", "")

        -- 캐릭터 추가 시도
        createRandomCharacter(triggerId, level, true)

        local after = safeGet(triggerId, "ct_CharList", "")
        if after == before then
            break
        end

        local newPart = after:sub(#before + 2)

        local code, name = newPart:match("^(C%d+)%=(.+)$")
        if name then
            table.insert(addedNames, name)
        end
    end

    if #addedNames > 0 then
        local message = "[추가된 캐릭터]\n\n" .. table.concat(addedNames, "\n")

        alertNormal(triggerId, message)
    else
        alertNormal(triggerId, "⚠️ 추가 가능한 캐릭터가 없습니다.")
    end
end

-- ==========================================
-- 탭 디스플레이
-- ==========================================
--[[
listenEdit("editDisplay", function(triggerId, data)

    local chatHistory = getFullChat(triggerId)
    local count = #chatHistory

    if count > 1 then
        local lastMsg = chatHistory[count].data or ""
        local prevMsg = chatHistory[count-1].data or ""

        -- 마지막 또는 하나 전 메시지가 아니면 skip
        if data ~= lastMsg and data ~= prevMsg then
            return data
        end
    end

    data = data:gsub("♥♣♥", function()
        return safeGet(triggerId, "ct_generatedHTML", "")
    end, 1)

    return data
end)
]]

function generateHTML(triggerId)
    local html = ""

    -- ===== Memory 페이지 계산 =====
    local memoryNum = tonumber(safeGet(triggerId, "ct_MemoryNum", "0")) or 0
    local memoryPages = math.ceil(memoryNum / 10)

    local memRadioHTML = ""
    local memListHTML = ""
    local memDetailHTML = ""

    for i = 1, memoryPages do
        -- radio
        memRadioHTML = memRadioHTML .. [[
            <input type="radio" name="crq-memory" id="mem]] .. i .. [[" class="crq-memory-toggle">
        ]]

        -- list
        memListHTML = memListHTML .. [[
            <label for="mem]] .. i .. [[" class="crq-memory-item">
                Page ]] .. i .. [[
            </label>
        ]]

        -- 메모리 데이터 로드
        local memKey = string.format("ct_Memory_%03d", i)
        local raw = safeGet(triggerId, memKey, "")

        local memoryHTML = ""

        if raw ~= "" then
            local list = splitPipe(raw)

            for idx, entry in ipairs(list) do
                local number = (i - 1) * 10 + idx
                local parts = splitLiteral(entry, " § ")

                local date = parts[1] or ""
                local location = parts[2] or ""
                local name = parts[3] or ""
                local success = parts[4] or "0"
                local important = parts[5] or "0"
                local overview = parts[6] or ""
                local events = parts[7] or ""
                local summary = parts[8] or ""
                local diary = parts[9] or ""
                local dialogue = parts[10] or ""
                local reflection = parts[11] or ""

                local resultText = (success == "1") and "성공" or "실패"

                local lines = {}

                table.insert(lines, "<b>#" .. number .. " " .. date .. " " .. name .. " (" .. resultText .. ")</b>")
                table.insert(lines, "- 노선: " .. location)
                table.insert(lines, "- 개요: " .. overview)
                table.insert(lines, "- 주요 이벤트: " .. events)
                table.insert(lines, "- 요약: " .. summary)
                if reflection ~= "" then
                    table.insert(lines, "- " .. getPersonaName(triggerId) .. "의 소감: " .. reflection)
                end
                table.insert(lines, "- " .. name .. "의 일기: " .. diary)

                if dialogue ~= "" then
                    for quote, line in dialogue:gmatch("([\"'])([^\"']+)%1") do
                        table.insert(lines, quote .. line .. quote)
                    end
                end

                memoryHTML = memoryHTML .. "<div class=\"crq-memory-entry\">"
                memoryHTML = memoryHTML .. table.concat(lines, "<br>")
                memoryHTML = memoryHTML .. "</div><br>"

            end
        else
            memoryHTML = "No Logs"
        end

        memDetailHTML = memDetailHTML .. [[
            <div class="crq-memory-detail" data-mem="]] .. i .. [[">
            <h2>Page ]] .. i .. [[</h2>
            <br>
            ]] .. memoryHTML .. [[
            </div>
        ]]

    end

    -- ===== 캐릭터 목록 =====
    local charList = safeGet(triggerId, "ct_CharList", "")
    local chars = splitPipe(charList)

    table.sort(chars, function(a, b)
        local codeA, nameA = a:match("^(C%d+)%=(.+)$")
        local codeB, nameB = b:match("^(C%d+)%=(.+)$")

        nameA = nameA or ""
        nameB = nameB or ""

        -- Corruption 값 가져오기
        local corrA = tonumber(safeGet(triggerId, codeA .. "_Corruption", "0")) or 0
        local corrB = tonumber(safeGet(triggerId, codeB .. "_Corruption", "0")) or 0

        local unlockedA = (corrA ~= 0)
        local unlockedB = (corrB ~= 0)

        -- 1. 해금 여부 우선
        if unlockedA ~= unlockedB then
            return unlockedA   -- true(해금됨) 이 먼저
        end

        -- 2. 같은 그룹이면 가나다순
        return nameA < nameB
    end)

    local radioHTML = ""
    local listHTML = ""
    local detailHTML = ""

    for i, token in ipairs(chars) do
        local code, name = token:match("^(C%d+)%=(.+)$")
        if code and name then
            -- 숨김 radio
            radioHTML = radioHTML .. [[
                <input type="radio" name="crq-char" id="char]] .. i .. [[" class="crq-char-toggle">
            ]]

            -- Corruption 값 가져오기
            local corr = tonumber(safeGet(triggerId, code .. "_Corruption", "0")) or 0

            -- =========================
            -- 표시용 단계 (0~5)
            -- =========================
            local stage = 0

            if corr == 0 then
                stage = 0
            elseif corr < 25 then
                stage = 1
            elseif corr < 50 then
                stage = 2
            elseif corr < 75 then
                stage = 3
            elseif corr < 100 then
                stage = 4
            else
                stage = 5
            end


            -- =========================
            -- 기존 로직 호환용 (3조건)
            -- =========================
            local clearFlag = -1

            if corr == 0 then
                local startExpert = tonumber(getChatVar(triggerId, "ct_StartExpert") or "0")
                if startExpert == 1 then
                    clearFlag = 0
                else
                    clearFlag = -1      -- 미해금
                end
            elseif corr < 5 then
                clearFlag = 0       -- 해금됨
            else
                clearFlag = 1       -- 고단계
            end

            -- 상태 아이콘 결정
            local icon = "❔"

            if stage == 0 then
                icon = "❔"
            elseif stage == 1 then
                icon = "🤍"
            elseif stage == 2 then
                icon = "💛"
            elseif stage == 3 then
                icon = "💚"
            elseif stage == 4 then
                icon = "❤️"
            else
                icon = "💖"
            end

            -- Objective 상태 확인
            local objective = safeGet(triggerId, "ct_Char_Objective", "")
            local isChecked = (objective == code)

            -- 버튼 클래스 결정
            local btnClass = "crq-char-btn"
            if isChecked then
                btnClass = btnClass .. " crq-char-btn-active"
            end

            -- 목록 출력
            listHTML = listHTML .. [[
                <label for="char]] .. i .. [[" class="crq-char-item">
                    ]] .. icon .. " " .. name .. [[

                    <button class="]] .. btnClass .. [["
                            risu-btn="choice_objective_]] .. code .. [["
                            onclick="event.stopPropagation();">
                    </button>

                </label>
            ]]

            -- =========================
            -- 프로필
            -- =========================
            local profileKey = code .. "_Profile"
            local profile = safeGet(triggerId, profileKey, "프로필 없음")

            -- Clear -1 → 프로필 필터링
            if clearFlag == -1 then
                local lines = splitLiteral(profile, "\n")
                local newLines = {}

                local allowedFull = {
                    ["### Basic"] = true,
                    ["### Appearance"] = true
                }

                local maskedHeaders = {
                    ["### Personality"] = true,
                    ["### Interpersonal"] = true,
                    ["### Personal History"] = true,
                    ["### Sexual Profile"] = true,
                    ["### Background"] = true,
                    ["### Virginity"] = true,
                    ["### Reproductive Cycle"] = true
                }

                local currentHeader = nil

                for _, line in ipairs(lines) do
                    if string.match(line, "^### ") then
                        currentHeader = trim(line)

                        table.insert(newLines, line)

                        if maskedHeaders[currentHeader] then
                            table.insert(newLines, "???")
                            table.insert(newLines, "")  -- ← 빈 줄 추가 (핵심)
                        end

                    else
                        if allowedFull[currentHeader] then
                            table.insert(newLines, line)
                        end
                    end
                end

                profile = table.concat(newLines, "\n")
            end

            profile = profile:gsub("\n", "<br>")

            -- =========================
            -- Corruption (게이지)
            -- =========================
            local corruptionHTML = ""

            if clearFlag ~= -1 then
                local corr = tonumber(safeGet(triggerId, code .. "_Corruption", "0")) or 0
                if corr < 0 then corr = 0 end
                if corr > 100 then corr = 100 end

                local percent = corr  -- 0~100 그대로 사용

                corruptionHTML = corruptionHTML .. [[
                <div class="crq-gauge crq-corruption">
                    <div class="crq-gauge-label">Corruption</div>
                    <div class="crq-gauge-bar">
                        <div class="crq-gauge-fill" style="width:]] .. percent .. [[%;"></div>
                    </div>
                </div>
                ]]
            end

            -- =========================
            -- Bodypart (게이지)
            -- =========================
            local gaugeHTML = ""

            if clearFlag ~= -1 then
                local bodyKey = code .. "_Bodypart"
                local bodyStr = safeGet(triggerId, bodyKey, "")
                local bodyVals = splitPipe(bodyStr)

                local labels = {
                    "Breast", "Oral", "Clitoris", "Vaginal", "Anal"
                }

                for j = 1, 5 do
                    local v = tonumber(bodyVals[j]) or 0
                    if v < 0 then v = 0 end
                    if v > 200 then v = 200 end

                    local percent = (v / 200) * 100

                    gaugeHTML = gaugeHTML .. [[
                    <div class="crq-gauge">
                        <div class="crq-gauge-label">]] .. labels[j] .. [[</div>
                        <div class="crq-gauge-bar">
                            <div class="crq-gauge-fill" style="width:]] .. percent .. [[%;"></div>
                        </div>
                    </div>
                    ]]
                end
            end

            -- =========================
            -- Virginity / Reproductive / History
            -- =========================
            local vText = ""

            if clearFlag ~= -1 then
                local vLines = {}
                buildVirginityReproductiveHistory(triggerId, code, vLines, true)

                vText = table.concat(vLines, "\n")
                vText = vText:gsub("\n", "<br>")
            end


            -- =========================
            -- Trait
            -- =========================
            local tText = ""

            if clearFlag == 1 then
                local tLines = {}
                buildTraitSection(triggerId, code, tLines)

                tText = table.concat(tLines, "\n")
                tText = tText:gsub("\n", "<br>")

            elseif clearFlag == 0 then
                local tLines = {
                    "\n### Trait",
                    "???"
                }

                tText = table.concat(tLines, "\n")
                tText = tText:gsub("\n", "<br>")
            end


            -- =========================
            -- Count
            -- =========================
            local cText = ""

            if clearFlag ~= -1 then
                local countKey = code .. "_Count"
                local countStr = safeGet(triggerId, countKey, "")
                local countVals = splitPipe(countStr)

                local countLabels = {
                    "Climax",
                    "External Ejaculation",
                    "Oral Ejaculation",
                    "Vaginal Ejaculation",
                    "Anal Ejaculation"
                }

                local cLines = {}
                table.insert(cLines, "\n### Cumulative Count")

                for j = 1, 5 do
                    local v = tonumber(countVals[j]) or 0
                    if v < 0 then v = 0 end
                    table.insert(cLines, "- " .. countLabels[j] .. ": " .. v)
                end

                cText = table.concat(cLines, "\n")
                cText = cText:gsub("\n", "<br>")
            end

            -- =========================
            -- Type 표시 (프로필 내부용)
            -- =========================
            local typeStr = safeGet(triggerId, code .. "_Type", "")
            local typeVals = splitPipe(typeStr)

            local typeName  = typeVals[1] or ""
            local typeDifficulty = tonumber(typeVals[2]) or 0
            local typeHTML = ""

            -- 타입 정보가 존재할 때만 표시
            if typeName ~= "" then
                if clearFlag == -1 then
                    -- 미해금 → ??? (대시 없음)
                    typeHTML =
                        "### Type<br>" ..
                        "???<br><br>"
                else
                    -- 해금됨 → 실제 타입 + ⭐레벨
                    typeHTML =
                        "### Type<br>" ..
                        "- " .. typeName .. " ⭐" .. typeDifficulty .. "<br><br>"
                end
            end

            -- =========================
            -- 프로필 + 상태 + Count + Trait 합치기
            -- =========================
            local combinedText = profile

            -- Type 추가 (프로필 위쪽에)
            combinedText = typeHTML .. combinedText

            if clearFlag ~= -1 then
                combinedText =
                    combinedText ..
                    "<br><br>" ..
                    vText ..
                    "<br>" ..
                    cText ..
                    "<br>" ..
                    tText
            end

            local imgPath = "images/" .. name .. ".png"

            detailHTML = detailHTML .. [[
            <div class="crq-char-detail" data-char="]] .. i .. [[">
                <h2>]] .. name .. [[</h2>

                {{settempvar::asset_find::]] .. name .. [[.png}}
                {{settempvar::found_status::0}}

                {{#each {{module_assetlist::Chikan}} asset_name}}
                    {{#if {{equal::{{slot::asset_name}}::{{gettempvar::asset_find}}}}}}
                        {{settempvar::found_status::1}}
                    {{/if}}
                {{/each}}

                {{#if {{equal::{{gettempvar::found_status}}::1}}}}
                <div class="image-container"
                     style="background-image: url('{{raw::]] .. name .. [[.png}}');"
                     tabindex="0">
                </div>
                {{/if}}

                <div class="crq-gauge-box">
                    ]] .. corruptionHTML .. [[
                    ]] .. gaugeHTML .. [[
                </div>

                <div class="crq-profile">
                    ]] .. combinedText .. [[
                </div>

            </div>
            ]]

        end
    end

    local html = [[
<style>

.image-container {
  width: 21em;
  height: 13em;
  margin: auto;
  background-size: cover;
  background-position: center 10%;
  border-radius: 20px;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.image-container:hover {
  height: 30em;
  background-position: center 5%;
  outline: none;
}

.crq-wrap, .crq-wrap *{
    color:#111 !important;
    font-family:'Malgun Gothic','맑은 고딕',sans-serif;
}
#crq-toggle{display:none;}
#crq-settings-toggle{ display:none; }
#crq-memory-toggle{display:none;}
#crq-guide-toggle{display:none;}

/* ===== 버튼 ===== */
.crq-btn-box,
.crq-btn-box-auto,
.crq-btn-box2,
.crq-btn-box3,
.crq-btn-box-memory,
.crq-btn-box-guide {
    position:fixed;
    right:0;          /* 화면에 딱 붙임 */
    z-index:21000;
}

/* 각 버튼 위치만 다름 */
.crq-btn-box{ top:60px; }
.crq-btn-box-auto{ top:150px; }
.crq-btn-box-guide { top: 240px; }
.crq-btn-box3{ top:330px; }
.crq-btn-box2{
{{#if {{equal::{{getvar::ct_UseMemory}}::0}} || {{getvar::ct_UseMemory}} == null }}
top:420px;
{{/if}}
{{#if {{equal::{{getvar::ct_UseMemory}}::1}}}}
top:510px;
{{/if}}
}
.crq-btn-box-memory{ top:420px; }


.crq-open-btn,
.crq-open-btn-auto,
.crq-open-btn2,
.crq-open-btn3,
.crq-open-btn-memory,
.crq-open-btn-guide {
    width:32px;
    height:70px;

    display:flex;
    align-items:center;
    justify-content:center;

    border-radius:12px 0 0 12px;   /* 왼쪽만 둥글게 */
    border-right:none;             /* 벽에 붙은 느낌 */

    background:#fff;
    cursor:pointer;

    box-shadow:-3px 0 10px rgba(0,0,0,0.15);
}

.crq-open-btn{
    border:3px solid #ffc0d9;
}


.crq-open-btn-auto{
    border:3px solid #7edc9a;
}


.crq-open-btn2{
    border:3px solid #b6e0ff;
}

.crq-open-btn3{
    border:3px solid #ffe08a;
}

.crq-open-btn-memory{
    border:3px solid #bfa6ff;
}

.crq-open-btn-guide {
    border: 3px solid #7EC8E3;
}


/* 패널 열리면 버튼 숨김 */
#crq-toggle:checked ~ .crq-btn-box{ display:none; }
#crq-toggle:checked ~ .crq-btn-box-auto{ display:none; }
#crq-toggle:checked ~ .crq-btn-box2{ display:none; }
#crq-toggle:checked ~ .crq-btn-box3{ display:none; }
#crq-toggle:checked ~ .crq-btn-box-memory{ display:none; }
#crq-toggle:checked ~ .crq-btn-box-guide { display: none; }

/* ===== 패널 ===== */
.crq-panel{
    position:fixed; top:0; right:-32%;
    width:32%; height:100vh;
    background:#fff;
    border-left:3px solid #ffc0d9;
    padding:20px;
    overflow:hidden;
    z-index:20000;
    transition:right 0.3s ease;
}
#crq-toggle:checked ~ .crq-panel{ right:0; }

/* ===== 플레이 가이드 패널 ===== */
.crq-guide-panel {
    position: fixed;
    top: 0;
    right: -32%;
    width: 32%;
    height: 100vh;
    background: #fff;
    border-left: 3px solid #add8e6;
    padding: 10px;
    overflow: hidden;
    z-index: 20000;
    transition: right 0.3s ease;
}

.crq-guide-container {
    display: flex;
    flex-direction: column;
    height: calc(100% - 50px);
}

.crq-guide-content {
    flex: 1;
    overflow-y: auto;
    margin-top: 10px;
    padding: 10px;
    border: 2px solid #add8e6;
    border-radius: 10px;
    background: #F5FFFF;
}

/* 게임 가이드 텍스트 스타일 */
.crq-guide-content p {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
}

#crq-guide-toggle:checked ~ .crq-guide-panel{
    right:0;
}

/* ===== 헤더 ===== */
.crq-header{ position:relative; text-align:center; margin-bottom:15px; }
.crq-title{ font-size:24px; font-weight:bold; color:#ff1493 !important; }
.crq-close{ position:absolute; right:0; top:0; font-size:22px; cursor:pointer; }

.crq-guide-panel .crq-title {
    color: #4682B4 !important; /* 진한 파란색 */
}

.crq-settings-panel .crq-title {
    color: #FFA500 !important; /* 연한 파란색 */
}

.crq-memory-panel .crq-title {
    color: #9B59B6 !important; /* 중간 파란색 */
}

/* ===== 레이아웃 ===== */
.crq-char-container{
    display:flex;
    flex-direction:column;
    height:calc(100% - 50px);
}
.crq-char-toggle{ display:none; }
.crq-memory-toggle{ display:none; }

/* ===== 목록 ===== */
.crq-char-list{
    flex:0 0 20%;
    overflow-y:auto;
    border:2px solid #ffc0d9;
    border-radius:10px;
    padding:8px;
    background:#fff5fa;
}

.crq-char-item{
    display:block;
    padding:8px;
    margin-bottom:6px;
    border-radius:6px;
    cursor:pointer;
    font-weight:600;
    background:#ffd6ea;
    transition:all 0.15s;
}

.crq-char-item:hover{
    background:#ffc1de;
}

/* ===== 상세 ===== */
.crq-char-view{
    flex:1;
    overflow-y:auto;
    margin-top:10px;
    padding:10px;
    border:2px solid #ffc0d9;
    border-radius:10px;
    background:#fff0f5;
}

.crq-char-detail h2{
    font-size:1.7em;
    font-weight:800;
    color:#ff1493 !important;
    margin:0 0 10px 0;
}

.crq-gauge-box{ margin:10px 0 15px 0; }
.crq-gauge{ margin-bottom:8px; }

.crq-gauge-label{
    font-size:13px;
    font-weight:700;
}

.crq-corruption .crq-gauge-fill{
    background:#bb66ff;
}

.crq-gauge-bar{
    width:100%;
    height:10px;
    background:#ffd6ea;
    border-radius:5px;
    overflow:hidden;
}

.crq-gauge-fill{
    height:100%;
    background:#ff5ca8;
}

.crq-profile{
    font-size:18px;
    font-weight:600;
}

/* ===== 설정 패널 ===== */
.crq-settings-panel{
    position:fixed;
    top:0;
    right:-32%;
    width:32%;
    height:100vh;

    background:#fff;
    border-left:3px solid #ffe08a;

    padding:10px;
    overflow:hidden;
    z-index:20000;

    transition:right 0.3s ease;
}

/* 열림 */
#crq-settings-toggle:checked ~ .crq-settings-panel{
    right:0;
}

/* 설정 패널 열리면 모든 버튼 숨김 */
#crq-settings-toggle:checked ~ .crq-btn-box,
#crq-settings-toggle:checked ~ .crq-btn-box-auto,
#crq-settings-toggle:checked ~ .crq-btn-box2,
#crq-settings-toggle:checked ~ .crq-btn-box3,
#crq-settings-toggle:checked ~ .crq-btn-box-memory,
#crq-settings-toggle:checked ~ .crq-btn-box-guide{
    display:none;
}

#crq-memory-toggle:checked ~ .crq-btn-box,
#crq-memory-toggle:checked ~ .crq-btn-box-auto,
#crq-memory-toggle:checked ~ .crq-btn-box2,
#crq-memory-toggle:checked ~ .crq-btn-box3,
#crq-memory-toggle:checked ~ .crq-btn-box-memory,
#crq-memory-toggle:checked ~ .crq-btn-box-guide{
    display:none;
}

#crq-guide-toggle:checked ~ .crq-btn-box,
#crq-guide-toggle:checked ~ .crq-btn-box-auto,
#crq-guide-toggle:checked ~ .crq-btn-box2,
#crq-guide-toggle:checked ~ .crq-btn-box3,
#crq-guide-toggle:checked ~ .crq-btn-box-memory,
#crq-guide-toggle:checked ~ .crq-btn-box-guide {
    display: none;
}

/* ===== 캐릭터 버튼 추가 (레이아웃 안전) ===== */

/* label 기준점 */
.crq-char-item{
    position:relative;
    padding-right:36px; /* 버튼 공간만 확보 */
}

/* 오른쪽 내부 버튼 */
.crq-char-btn{
    position:absolute;
    right:6px;
    top:50%;
    transform:translateY(-50%);

    width:20px;
    height:20px;

    border-radius:4px;
    border:2px solid #ff8acb;
    background:#fff;

    cursor:pointer;
    z-index:5;
}

/* hover 효과 */
.crq-char-btn:hover{
    background:#ffe4f2;
}

.crq-char-btn-active{
    background:#ff8acb;
    border-color:#ff1493;
}

/* ===== 설정 옵션 버튼 ===== */

.crq-setting-item{
    margin:6px 0;
}

.crq-setting-btn{
    width:100%;
    height:36px;
    padding:0 10px;

    border-radius:8px;
    border:2px solid #d8d8d8;

    background:#f5f5f5;
    color:#333;

    font-size:16px;
    font-weight:700;

    cursor:pointer;
    text-align:center;
}

.crq-setting-btn span{
    display:block;
    line-height:30px;
}

/* ===== 옵션 버튼 ACTIVE (연두색) ===== */
.crq-setting-active{
    border-color:#6fd66f !important;
    background:#ddffdd !important;
    color:#166b16 !important;
    font-weight:800;
}

/* ===== 확장 캐릭터 추가 버튼 ACTIVE (핑크 고정) ===== */
.crq-setting-active-fixed{
    border-color:#ff8acb !important;
    background:#ffe4f3 !important;
    color:#c40074 !important;
    font-weight:800;
}

.crq-memory-panel{
    position:fixed;
    top:0;
    right:-50%;
    width:50%;
    height:100vh;

    background:#fff;
    border-left:3px solid #bfa6ff;

    padding:10px;
    overflow:hidden;
    z-index:20000;

    transition:right 0.3s ease;
}

#crq-memory-toggle:checked ~ .crq-memory-panel{
    right:0;
}

.crq-memory-container{
    display:flex;
    flex-direction:column;
    height:calc(100% - 50px);
}

.crq-memory-list{
    flex:0 0 15%;
    overflow-y:auto;
    border:2px solid #bfa6ff;
    border-radius:10px;
    padding:8px;
    background:#f5f0ff;
}

.crq-memory-item{
    display:block;
    padding:8px;
    margin-bottom:6px;
    border-radius:6px;
    cursor:pointer;
    font-weight:600;
    background:#e9e2ff;
    transition:all 0.15s;
}

.crq-memory-item:hover{
    background:#dcd0ff;
}

.crq-memory-detail h2{
    font-size:1.7em;
    font-weight:800;
    color:#5a3cff !important;
    margin:0 0 10px 0;
}

.crq-memory-view{
    flex:1;
    overflow-y:auto;
    margin-top:10px;
    padding:10px;
    border:2px solid #bfa6ff;
    border-radius:10px;
    background:#f5f0ff;
}

@media (max-width: 768px){

  .crq-panel,
  .crq-guide-panel,
  .crq-settings-panel,
  .crq-memory-panel {
      width: 92%;
      right: -92%;
  }

}

.crq-char-detail{ display:none; }
.crq-memory-detail{ display:none; }

]] .. (function()

    local css = ""

    -- 캐릭터 CSS
    for i,_ in ipairs(chars) do
        css = css .. ".crq-char-toggle#char"..i..":checked ~ .crq-char-container .crq-char-view .crq-char-detail[data-char=\""..i.."\"]{display:block;}\n"
    end

    -- Memory CSS
    for i=1, memoryPages do
        css = css .. ".crq-memory-toggle#mem"..i..":checked ~ .crq-memory-container .crq-memory-view .crq-memory-detail[data-mem=\""..i.."\"]{display:block;}\n"
    end

    return css

end)() .. [[
</style>

<div class="crq-wrap">
<input type="checkbox" id="crq-toggle">
<input type="checkbox" id="crq-settings-toggle">
<input type="checkbox" id="crq-memory-toggle">
<input type="checkbox" id="crq-guide-toggle">

<div class="crq-btn-box">
    <label for="crq-toggle" class="crq-open-btn crq-side-tab">💕</label>
</div>

<div class="crq-btn-box-auto">
    <button class="crq-open-btn-auto crq-side-tab" risu-trigger="setAutoSuccess">🎲</button>
</div>

<div class="crq-btn-box-guide">
    <label for="crq-guide-toggle" class="crq-open-btn-guide crq-side-tab">🎮</label>
</div>

<div class="crq-btn-box3">
    <label for="crq-settings-toggle" class="crq-open-btn3 crq-side-tab">🛠️</label>
</div>

<div class="crq-btn-box2">
    <button class="crq-open-btn2 crq-side-tab" risu-trigger="loadData">📥</button>
</div>


{{#if {{equal::{{getvar::ct_UseMemory}}::1}}}}<div class="crq-btn-box-memory">
    <label for="crq-memory-toggle" class="crq-open-btn-memory crq-side-tab">🏷️</label>
</div>{{/if}}

<div class="crq-panel">

    <div class="crq-header">
        <div class="crq-title">캐릭터 목록</div>
        <label for="crq-toggle" class="crq-close">✖</label>
    </div>

]] .. radioHTML .. [[

    <div class="crq-char-container">

        <div class="crq-char-list">
]] .. listHTML .. [[
        </div>

        <div class="crq-char-view">
]] .. detailHTML .. [[
        </div>

    </div>

</div>
    <div class="crq-guide-panel">
        <div class="crq-header">
            <div class="crq-title">플레이 가이드</div>
            <label for="crq-guide-toggle" class="crq-close">✖</label>
        </div>

        <div class="crq-guide-container">
            <div class="crq-guide-content">
                <p># 액션</p>
                <p>- 매 턴 시작 시 5개의 액션을 획득하며 두 개의 액션을 사용해야 합니다.</p>
                <p>- 🖐️ 성추행 액션: 상대를 직접적으로 성추행하는 액션<br>
                - 🕸️ 준비 액션: 성추행을 유리하게 만들기 위한 준비 행동<br>
                - 👥 완화 액션: 다른 액션과 함께 사용하여 🚨와 👁️을 낮추는 액션</p>
                <p><br></p>
                <p># 덱 레벨: 상대의 현재 💗에 따라 획득할 수 있는 최대 액션의 레벨이 결정됩니다.</p>
                <p>Lv.1: 우연처럼 보이는 비의도적 접촉 (💗 0 이상)<br>
                Lv.2: 의도는 있으나 아직까지는 부인 가능한 접촉 (💗 15 이상)<br>
                Lv.3: 명확한 의도가 담긴 접촉 (💗 45 이상)<br>
                Lv.4: 강도가 높은 노골적인 자극 (💗 75 이상)<br>
                Lv.5: 명백한 성행위 (💗 105 이상)</p>
                <p><br></p>
                <p># 액션의 수치 변화</p>
                <p>- 특정 부위를 목표로 하는 액션의 💗 증감량은 상대 캐릭터의 민감도에 영향을 받아 난이도에 큰 영향을 미칩니다. 민감도가 설정되지 않는 부위를 목표로 하는 경우, 다섯 부위의 민감도의 평균치로 계산됩니다.</p>
                <p>- 상대 캐릭터가 가진 특성들은 획득하는 액션의 🎲 / 💗 / 🚨 / 👁️ 에 영향을 줄 수 있습니다. 난이도를 높이는 특성은 캐릭터 타입의 ⭐을 증가시키며, 반대로 난이도를 낮추는 특성은 캐릭터 타입의 ⭐를 감소시킵니다.</p>
                <p>- 치한 레벨 5 이상부터 추가되는 캐릭터들은 기본 ⭐이 증가합니다. (기본 ⭐은 치한 레벨 30까지 증가, 30레벨부터 추가되는 캐릭터는 기본 ⭐7)</p>
                <p>- 상대 캐릭터가 상당히 흥분한 상태 (💗 105 이상)일 때 획득하는 액션은 🚨 증가량이 절반이 됩니다.</p>
                <p>- 상대 캐릭터가 완전히 쾌락에 빠진 상태  (💗 150)일 때 획득하는 액션은 👁️ 증가량이 25% 증가하는 대신, 🚨 증가량이 크게 감소되며 때때로 마이너스가 될 수도 있습니다.</p>
                <p><br></p>
                <p># 🕸️ 액션</p>
                <p>- 🕸️ 액션을 성공시키면 해당 액션이 목표로 하는 부위들을 공유하는 다른 모든 액션들의 🎲를 감소시킵니다. (🕸️ 액션의 레벨 ×7 / 대성공 ×10)</p>
                <p>- 부위는 다음 그룹으로 이루어져 있으며 포함되는 모든 부위의 액션들의 🎲를 감소시킵니다.</p>
                <p>가슴: Breast / Nipple / Chest<br>
                머리: Neck / Head / Ear / Hair / Face / Lips / Tongue / Oral / Throat / Mouth / Cheek / Breath<br>
                클리토리스: Vulva / Crotch / Clitoris<br>
                음부: Vulva / Vaginal / Cervix / Crotch / Uterus / Womb<br>
                엉덩이: Buttock / Anal / Pelvis / Hip<br>
                팔: Arm / Shoulder / Wrist / Hand / Armpit / Elbow / Finger / Palm / Collarbone<br>
                다리: Leg / Thigh / Knee / Calf / Foot / Ankle / Toe<br>
                허리: Waist / Back / Belly / Rib / Stomach / Belly</p>
                <p>- 대성공: 💗 증가량 ×1.5, 감소량 ÷1.5 / 🚨·👁️ 증가량 ÷1.5, 감소량 ×1.5<br>
                - 주사위가 95 이상이면 대성공, 🎲가 90 이상인 경우엔 대성공 최소값이 더 높습니다.</p>
                <p>- 대실패: 💗 증가량 ÷1.5, 감소량 ×1.5 / 🚨·👁️ 증가량 ×1.5, 감소량 ÷1.5<br>
                - 주사위가 5 이하이면 대실패, 🎲가 10 이하인 경우엔 대실패 최대값이 더 낮습니다.</p>
                <p>- 🎲이 0인 액션은 반드시 대성공합니다.</p>
                <p><br></p>
                <p># 치한의 성공과 실패</p>
                <p>- 성공: 🚨 또는 👁️이 100에 도달하지 않은 상태에서 💗이 150에 도달. 기본 턴 포함 최대 20턴동안 치한을 계속할 수 있습니다. 💗이 135 미만으로 떨어지거나 🚨 또는 👁️이 100에 도달하면 치한은 중단됩니다.<br>
                - 상대의 💗이 150이상인 경우 두 개의 액션의 💗 합산이 높을 수록 상대를 절정시킬 확률이 증가합니다.</p>
                <p>- 실패: 🚨 또는 👁️이 100에 도달 / 💗을 150에 도달시키지 못한 채 열차가 목적지에 도착</p>
                <p>- 치한 종료 시 최종 💗이 높을 수록 더 많은 경험치를, 🚨와 👁️이 높을 수록 더 적은 경험치를 획득합니다 (<br>
                - 그 외에도 경과 턴 수, 절정, 사정, 성감대 개발, 첫 경험 등에 따라 추가 경험치를 획득합니다.<br>
                - 치한 성공 시 경과 턴 수에 따라 더 많은 경험치를 획득할 수 있습니다.</p>
                <p>- 치한 종료 시 행했던 치한 행동들에 의해 상대 캐릭터의 성감대 개발도가 상승할 수 있습니다.</p>
                <p>- 획득한 경험치에 비례해 상대 캐릭터의 함락도가 증가합니다. 캐릭터의 함락도가 높을 수록 함락도 증가량과 해당 캐릭터로부터 얻을 수 있는 경험치도 감소합니다.</p>
                <p>- 치한 레벨이 오를 때마다 새로운 캐릭터가 추가됩니다 (기본 최대 41명 / 확장 캐릭터 사용 시 최대 50명)</p>
                <p><br></p>
                <p># 함락도</p>
                <p>❔ 아직 만나지 않은 캐릭터<br>
                🤍 1% 이상<br>
                💛 25% 이상<br>
                💚 50% 이상<br>
                ❤️ 75% 이상<br>
                💖 100%</p>
                <p>- 함락도가 50%미만일 때는 난이도를 증가시키지만 그 이상부터는 오히려 난이도를 감소시킵니다.</p>
            </div>
        </div>
    </div>

    <div class="crq-settings-panel">

        <div class="crq-header">
            <div class="crq-title">추가 설정</div>

            <label for="crq-settings-toggle"
                class="crq-close">✖</label>
        </div>

        <div class="crq-setting-item">

            <div class="crq-setting-btn {{#if {{equal::{{getvar::ct_NoStretchSpeech}}::1}}}}crq-setting-active{{/if}}" risu-trigger="toggleStretchSpeech">
                <span>늘임 말투 가리기 (~요오 ~잖아아) {{#if {{equal::{{getvar::ct_NoStretchSpeech}}::1}}}}ON{{/if}}{{#if {{notequal::{{getvar::ct_NoStretchSpeech}}::1}}}}OFF{{/if}}</span>
            </div>

        </div>
        <div class="crq-setting-item">
            <div class="crq-setting-btn {{#if {{equal::{{getvar::ct_AutoOffAfterClear}}::1}}}}crq-setting-active{{/if}}" risu-trigger="toggleAutoOffAfterClear">
                <span>치한성공 후 액션성공보정 끄기 {{#if {{equal::{{getvar::ct_AutoOffAfterClear}}::1}}}}ON{{/if}}{{#if {{notequal::{{getvar::ct_AutoOffAfterClear}}::1}}}}OFF{{/if}}</span>
            </div>
        </div>

        <div class="crq-setting-item">
            <div class="crq-setting-btn {{#if {{equal::{{getvar::ct_OnlyExpansion}}::1}}}}crq-setting-active{{/if}}" risu-trigger="toggleOnlyExpansion">
                <span>확장 캐릭터만 사용 {{#if {{equal::{{getvar::ct_OnlyExpansion}}::1}}}}ON{{/if}}{{#if {{notequal::{{getvar::ct_OnlyExpansion}}::1}}}}OFF{{/if}}</span>
            </div>
        </div>

        <div class="crq-setting-item">
            <div class="crq-setting-btn crq-setting-active-fixed" risu-trigger="addExpansionCharacter">
                <span>확장 캐릭터 즉시 추가</span>
            </div>
        </div>
    </div>

    {{#if {{equal::{{getvar::ct_UseMemory}}::1}}}}
    <div class="crq-memory-panel">

        <div class="crq-header">
            <div class="crq-title">치한 로그</div>
            <label for="crq-memory-toggle" class="crq-close">✖</label>
        </div>

        ]] .. memRadioHTML .. [[

        <div class="crq-memory-container">

            <div class="crq-memory-list">
        ]] .. memListHTML .. [[
            </div>

            <div class="crq-memory-view">
        ]] .. memDetailHTML .. [[
            </div>

        </div>

    </div>{{/if}}
</div>
]]

    html = "{{#if {{? ({{lastmessageid}}-{{chat_index}})<2}}}}" .. html .. "{{/if}}"

    setChatVar(triggerId, "ct_generatedHTML", html)
end

