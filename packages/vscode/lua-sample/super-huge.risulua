                corrExtra = " The body unconsciously exhibits responses, including physiological reactions, suggestive movements, subtle gestures, in anticipation and craving for sex."
            else
                corrExtra = " An anticipation of the sexual pleasure to come is present."
            end
        end
    end

    if extra == nil or extra == "" then
        return base .. corrExtra
    end

    return base .. " " .. extra .. corrExtra
end

