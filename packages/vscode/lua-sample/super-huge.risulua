    local v_SocialStyle = "Trusting and easily deceived due to a lack of suspicion."
    
    -- SpeechStyle
    local v_SpeechStyle = "Formal Speech, Honorific Language, Calm Tone, Soft Voice"

    -- 평판: 주위에서 그녀를 어떻게 보고 있는지
    local v_Reputation = "Generally viewed favorably by people around her."

    -- 친구: 친구가 얼마나 많은지, 사회적으로 고립되어 있는지
    local v_Friend = "Maintains a few deep and meaningful friendships."

    -- 컴플렉스: 가지고 있는 컴플렉스
    local v_Complex = "Insecure about her small breasts."

    -- 트라우마: 과거에 겪은 트라우마
