        end

        -- =========================
        -- 랜덤 선택 + 제거 함수
        -- =========================
        local function pickTraits(pool, count)

            -- 원본 보호용 복사
            local workingPool = {}
            for _, v in ipairs(pool) do
                table.insert(workingPool, v)
            end

            local result = {}

            for i = 1, count do

                if #workingPool == 0 then break end

                -- 랜덤 선택
                local idx = math.random(#workingPool)
                local name = workingPool[idx]
                local data = traitData[name]

                table.insert(result, name)

                -- =========================
                -- Sensitivity 값 조정
                -- =========================
                if data and data.type == "sensitivity" then
                    local value = math.random(71, 99)

                    if name == "Breast Sensitivity" or name == "Nipple Sensitivity" then
                        v_Sensitivity_Breast = math.max(v_Sensitivity_Breast, value)

                    elseif name == "Oral Sensitivity" then
                        v_Sensitivity_Oral = math.max(v_Sensitivity_Oral, value)

                    elseif name == "Clitoral Sensitivity" then
                        v_Sensitivity_Clitoris = math.max(v_Sensitivity_Clitoris, value)

                    elseif name == "Vaginal Sensitivity" or name == "Uterine Sensitivity" then
                        v_Sensitivity_Vaginal = math.max(v_Sensitivity_Vaginal, value)

                    elseif name == "Anal Sensitivity" then
                        v_Sensitivity_Anal = math.max(v_Sensitivity_Anal, value)
                    end
                end

                -- 선택된 항목 제거
                table.remove(workingPool, idx)

                -- =========================
                -- 같은 type 제거
                -- =========================
                if data and data.type then
                    for j = #workingPool, 1, -1 do
                        local otherName = workingPool[j]
                        local otherData = traitData[otherName]

                        if otherData and otherData.type == data.type then
                            table.remove(workingPool, j)
                        end
                    end
                end

                -- =========================
                -- exclude 제거
                -- =========================
                if data and data.exclude then
                    for ex in string.gmatch(data.exclude, "[^|]+") do
                        for j = #workingPool, 1, -1 do
                            if workingPool[j] == ex then
                                table.remove(workingPool, j)
                            end
                        end
                    end
                end

            end

            return result
        end


