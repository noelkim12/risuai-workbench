    elseif v < 70 then
        return "Within a normal sensitivity range"
    elseif v < 85 then
        return "Slightly above average; touch is clearly felt"
    elseif v < 100 then
        return "Sensitive; reactions are quick and noticeable"
    elseif v < 120 then
        return "Very sensitive; even mild stimulation has a strong effect"
    elseif v < 150 then
        return "Extremely sensitive; intense reactions occur with little effort"
    elseif v < 200 then
        return "Hyper-sensitive; minimal contact triggers overwhelming response"
    else
        return "Transcendent sensitivity; constant heightened arousal, even without direct stimulation"
    end
end

