    -- Vaginal
    if fv == "0" then
        table.insert(lines, "- Vaginal Virginity: Virgin")
    else
        table.insert(lines, "- Vaginal Virginity: Non-Virgin / " .. fv)
    end

    -- Anal
    if fa == "0" then
        table.insert(lines, "- Anal Virginity: Virgin")
    else
        table.insert(lines, "- Anal Virginity: Non-Virgin / " .. fa)
    end


    -- =====================================================
    -- Reproductive Cycle
    -- =====================================================

    table.insert(lines, "\n### Reproductive Cycle")

    local lastPeriodRaw = safeGet(triggerId, targetCode .. "_LastPeriod", "")
    local currentDate   = safeGet(triggerId, "ct_NextDate", "")
    local pregRaw       = safeGet(triggerId, targetCode .. "_Pregnancy", "")
    local skipCycle = false

    -- 임신 미확정인 경우
    if charProfile then
        local pregChance   = tonumber(pregRaw)

        -- 1. pregRaw 존재 + 숫자 (판정 대기 상태)
        if pregChance and pregChance > 0 then

            local targetName   = safeGet(triggerId, "ct_Target_Name", "")
            local currentTargetCode = findCharacterCode(triggerId, targetName)

            if currentTargetCode ~= targetCode then

                -- 3. 임신 체크 기준일 계산 (LastPeriod + 15일)
                local y, m, d = lastPeriodRaw:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")
                local y2, m2, d2 = currentDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

                if y and m and d and y2 and m2 and d2 then

                    local baseTime = os.time({
                        year  = tonumber(y),
                        month = tonumber(m),
                        day   = tonumber(d),
                        hour  = 12
                    })

                    local currentTime = os.time({
                        year  = tonumber(y2),
                        month = tonumber(m2),
                        day   = tonumber(d2),
                        hour  = 12
                    })

                    local pregCheckTime = baseTime + (14 * 86400) -- 배란일+1일

                    -- 4. 현재 날짜가 체크일 이후
                    if currentTime > pregCheckTime then
                        table.insert(lines, "- Last Period: " .. lastPeriodRaw)
                        table.insert(lines, "- Reproductive Status: Possible pregnancy")
                        table.insert(lines, "- Pregnancy Chance: " .. pregChance .. "%")
                        skipCycle = true

                    end
                end
            end
        end
    end

    if not skipCycle then
        -- 임신 상태
        if lastPeriodRaw == "X" and pregRaw ~= "" then

            local y, m, d   = pregRaw:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")
            local y2, m2, d2 = currentDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

            if y and m and d and y2 and m2 and d2 then

                local conceptionTime = os.time({
                    year  = tonumber(y),
                    month = tonumber(m),
                    day   = tonumber(d),
                    hour  = 12
                })

                local currentTime = os.time({
                    year  = tonumber(y2),
                    month = tonumber(m2),
                    day   = tonumber(d2),
                    hour  = 12
                })

                local daysPassed = math.floor((currentTime - conceptionTime) / 86400)
                if daysPassed < 0 then daysPassed = 0 end

                local weeks = math.floor(daysPassed / 7)

                table.insert(lines, "- Pregnancy Status: Pregnant")
                table.insert(lines, "- Conception Date: " .. pregRaw)

                local weekWord = (weeks == 1) and "week" or "weeks"

                table.insert(lines,
                    "- Gestational Age: " .. weeks .. " " .. weekWord)

                if weeks >= 4 and weeks <= 11 then
                    table.insert(lines, "- Physical Changes: Early pregnancy symptoms may be present, but there is no visible abdominal change.")

                elseif weeks >= 12 and weeks <= 23 then
                    table.insert(lines, "- Physical Changes: The abdomen shows gentle rounding consistent with early pregnancy.")

                elseif weeks >= 24 and weeks <= 31 then
                    table.insert(lines, "- Physical Changes: The abdomen is noticeably enlarged, clearly indicating pregnancy.")

                elseif weeks >= 32 and weeks <= 36 then
                    table.insert(lines, "- Physical Changes: The abdomen is prominently enlarged, reflecting late-stage pregnancy.")

                elseif weeks >= 37 then
                    table.insert(lines, "- Physical Changes: The abdomen is fully distended, indicating a full-term pregnancy.")
                end

                if weeks <= 3 then
                    table.insert(lines, "- Pregnancy Awareness: She is very unlikely to realize she is pregnant.")
                elseif weeks <= 4 then
                    table.insert(lines, "- Pregnancy Awareness: With basic reproductive knowledge, she may suspect pregnancy due to a missed period.")
                elseif weeks <= 6 then
                    table.insert(lines, "- Pregnancy Awareness: She may begin to suspect pregnancy, though she might not fully understand the cause without adequate knowledge.")
                elseif weeks <= 11 then
                    table.insert(lines, "- Pregnancy Awareness: With adequate reproductive knowledge, she would almost certainly recognize that she is pregnant.")
                else
                    table.insert(lines, "- Pregnancy Awareness: Regardless of her reproductive knowledge, her pregnancy is unmistakably known, whether by her own realization or by others informing her.")
                end
            end

        elseif lastPeriodRaw ~= "" and currentDate ~= "" then

            local y, m, d   = lastPeriodRaw:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")
            local y2, m2, d2 = currentDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

            if y and m and d and y2 and m2 and d2 then

                local lastTime = os.time({
                    year  = tonumber(y),
                    month = tonumber(m),
                    day   = tonumber(d),
                    hour  = 12
                })

                local currentTime = os.time({
                    year  = tonumber(y2),
                    month = tonumber(m2),
                    day   = tonumber(d2),
                    hour  = 12
                })

                local cycleDay = math.floor((currentTime - lastTime) / 86400) + 1
                if cycleDay < 1 then cycleDay = 1 end
                cycleDay = ((cycleDay - 1) % 28) + 1

                local phase = ""
                local statusLine = ""
                local fertileState = 0

                if cycleDay >= 1 and cycleDay <= 2 then
                    phase = "Menstruation"
                    statusLine = "She is currently menstruating and may experience mild cramps, fatigue, or lower abdominal discomfort. Pregnancy risk is nonexistent."

                elseif cycleDay >= 9 and cycleDay <= 15 then

                    local diff = 14 - cycleDay
                    fertileState = 1

                    if diff == 0 then
                        fertileState = 2
                        phase = "Fertile Window (Ovulation Day)"
                        statusLine = "Today is the ovulation day. The probability of pregnancy is at its highest."

                    elseif diff > 0 then
                        local dayWord = (diff == 1) and "day" or "days"
                        phase = "Fertile Window (" .. diff .. " " .. dayWord .. " before ovulation)"

                        if diff == 1 then
                            statusLine = "Ovulation is imminent. The probability of pregnancy is very high."
                        elseif diff == 2 then
                            statusLine = "Ovulation is approaching. The probability of pregnancy is moderately high."
                        else
                            statusLine = "Ovulation is expected in " .. diff .. " days. There is an increasing probability of pregnancy."
                        end
                    else
                        local after = math.abs(diff)
                        local dayWord = (after == 1) and "day" or "days"
                        phase = "Fertile Window (" .. after .. " " .. dayWord .. " after ovulation)"
                        statusLine = "Ovulation has recently occurred. The probability of pregnancy remains elevated."
                    end

                else
                    phase = "Infertile Phase"
                    statusLine = "This is a safe period. There is no risk of pregnancy."
                end

                table.insert(lines, "- Last Period: " .. lastPeriodRaw)
                table.insert(lines, "- Current Phase: " .. phase)
                table.insert(lines, "- Reproductive Status: " .. statusLine)

                local corrKey = targetCode .. "_Corruption"
                local corrRaw = safeGet(triggerId, corrKey, "0")
                local corruption = tonumber(corrRaw) or 0

                if not charProfile and fertileState ~= 0 and corruption < 100 then
                    local typeRaw = safeGet(triggerId, targetCode .. "_Type", "")
                    local typeFirst = splitPipe(typeRaw)[1] or ""

                    if typeFirst ~= "Yandere" then

                        if fertileState == 2 then
                            table.insert(lines,
                                "- High Pregnancy Risk Response: As it is ovulation day, if a situation arises where intravaginal ejaculation is likely, she will display even stronger refusal and active resistance due to the extremely high risk of pregnancy, consciously or instinctively.")

                        else
                            table.insert(lines,
                                "- Pregnancy Risk Response: As she is currently in the fertile window, if a situation arises where intravaginal ejaculation is likely, she will display intense refusal and active resistance due to the risk of pregnancy, consciously or instinctively.")
                        end

                    end
                end

                local pregChance = tonumber(pregRaw)
                if pregChance then
                    table.insert(lines, "- Pregnancy Chance: " .. pregChance .. "%")
                end

                local targetName   = safeGet(triggerId, "ct_Target_Name", "")
                local currentTargetCode = findCharacterCode(triggerId, targetName)

                if currentTargetCode == targetCode and not charProfile then
                    print(phase)
                end
            end
        end
    end

    -- =====================================================
    -- History
    -- =====================================================

    table.insert(lines, "\n### History of Being Molested by " .. getPersonaName(triggerId))

    local rawHistory = safeGet(triggerId, targetCode .. "_History", "")

    if rawHistory == "" then
        table.insert(lines, "- None")
    else

        local historyList = splitPipe(rawHistory)

        for _, entry in ipairs(historyList) do

            local parts = splitLiteral(entry, " § ")

            local datePart = parts[1] or ""
            local acts     = parts[2] or ""
            local comment  = parts[3] or ""

            local formatted = datePart .. ":"

            if acts ~= "" then
                formatted = formatted .. " " .. acts
            else
                formatted = formatted .. " 별다른 접촉 없었음"
            end

            if charProfile and comment ~= "" then
                formatted = formatted .. " (" .. comment .. ")"
            end

            table.insert(lines, "- " .. formatted)
        end
    end

end

function buildCurrentMemory(triggerId)

    local TARGET_FULL_LIMIT = 5
    local TARGET_EVENT_LIMIT = 10
    local OTHER_OVERVIEW_LIMIT = 10

    local memNum = tonumber(getChatVar(triggerId, "ct_MemoryNum") or "0") or 0
    local currentTarget = tostring(getChatVar(triggerId, "ct_Target_Name") or "")

    if memNum <= 0 then
        setChatVar(triggerId, "ct_MemoryCurrent", "")
        return
    end

    local pages = math.ceil(memNum / 10)
    local lines = {}

    table.insert(lines, "## Chikan Log")

    local entries = {}

    -- 모든 메모리 로드
    for p = 1, pages do
        local key = string.format("ct_Memory_%03d", p)
        local raw = safeGet(triggerId, key, "")

        if raw ~= "" then
            local list = splitPipe(raw)
            for _, entry in ipairs(list) do
                if #entries >= memNum then
                    break
                end
                table.insert(entries, entry)
            end
        end
    end

    local total = #entries

    for i, entry in ipairs(entries) do

        local parts = splitLiteral(entry, " § ")

        local date      = parts[1] or ""
        local location  = parts[2] or ""
        local name      = parts[3] or ""
        local successFlag = parts[4] or ""
        local importantFlag = parts[5] or ""
        local overview  = parts[6] or ""
        local events    = parts[7] or ""
        local summary   = parts[8] or ""
        local diary     = parts[9] or ""
        local dialogue  = parts[10] or ""
        local reflection  = parts[11] or ""

        local resultText = (successFlag == "1") and "Success" or "Failure"

        local isTarget = (name == currentTarget)
        local isImportant = (importantFlag == "1")

        local recentIndex = total - i + 1

        table.insert(lines, "")
        table.insert(lines, "### " .. date .. " " .. name .. " (" .. resultText .. ")")
        table.insert(lines, "- Line: " .. location)

        if isTarget then

            table.insert(lines, "- Context Overview: " .. overview)

            if isImportant or recentIndex <= TARGET_FULL_LIMIT then

                table.insert(lines, "- Core Events: " .. events)
                table.insert(lines, "- Summary: " .. summary)

                if reflection ~= "" then
                    table.insert(lines, "- " .. getPersonaName(triggerId) .. "'s Reflection: " .. reflection)
                end

                table.insert(lines, "- Heroine's Diary: " .. diary)
                table.insert(lines, "- Heroine's Key Lines:")

                if dialogue ~= "" then
                    for line in dialogue:gmatch("\"([^\"]+)\"") do
                        table.insert(lines, "\"" .. line .. "\"")
                    end
                end

            elseif recentIndex <= TARGET_EVENT_LIMIT then

                table.insert(lines, "- Core Events: " .. events)
                if reflection ~= "" then
                    table.insert(lines, "- " .. getPersonaName(triggerId) .. "'s Reflection: " .. reflection)
                end
            end

        else

            if recentIndex == 1 then

                table.insert(lines, "- Context Overview: " .. overview)
                table.insert(lines, "- Core Events: " .. events)
                table.insert(lines, "- Summary: " .. summary)
                if reflection ~= "" then
                    table.insert(lines, "- " .. getPersonaName(triggerId) .. "'s Reflection: " .. reflection)
                end

            elseif recentIndex <= OTHER_OVERVIEW_LIMIT then

                table.insert(lines, "- Context Overview: " .. overview)

            end

        end

    end

    setChatVar(triggerId, "ct_MemoryCurrent", table.concat(lines, "\n"))

end

function buildSessionMemory(triggerId)

    local useMemory = tostring(getChatVar(triggerId, "ct_UseMemory") or "0")
    if useMemory ~= "1" then
        return
    end

    local history = getFullChat(triggerId)
    if not history or #history == 0 then
        setChatVar(triggerId, "ct_MemoryTemp", "")
        return
    end

    local fullIndex = nil

    -- 최신 SaveChikanFullData 찾기
    for i = #history, 1, -1 do
        if history[i].role == "char" then
            local text = history[i].data or ""
            if text:find("<SaveChikanFullData>", 1, true) then
                fullIndex = i
                break
            end
        end
    end

    if not fullIndex then
        setChatVar(triggerId, "ct_MemoryTemp", "")
        return
    end

    local memoryText = "## Current Session Summary\n\n"

    -- FullSave 이후 Response Summary 수집
    for i = fullIndex + 1, #history do

        if history[i].role == "char" then

            local text = history[i].data or ""

            for block in text:gmatch("<Response Summary>([%s%S]-)</Response Summary>") do

                local normalized = block
                normalized = normalized:gsub("[\r\n]+", " ")
                normalized = normalized:gsub("Summary:%s*(.-)%s*Heroine's Key Lines:", "Summary: %1 | Heroine's Key Lines:")
                normalized = normalized:gsub("%s+", " ")

                local memSummary  = trim(normalized:match("Summary:%s*([^|]+)") or "")
                local memDialogue = trim(normalized:match("Heroine's Key Lines:%s*(.+)") or "")

                if memSummary ~= "" or memDialogue ~= "" then
                    memoryText = memoryText ..
                        "- " .. memSummary .. "\n" ..
                        memDialogue .. "\n\n"
                end

            end

        end

    end

    setChatVar(triggerId, "ct_MemoryTemp", memoryText)

end

-- ==========================================
-- 카드 타입 → 아이콘 반환
-- ==========================================
function getDeckIcon(cardType)

    if cardType == "Molestation" then
        return "🖐️"
    elseif cardType == "Preparation" then
        return "🕸️"
    elseif cardType == "Deception" then
        return "🎭"
    elseif cardType == "Mitigation" then
        return "👥"
    elseif cardType == "Toilet" then
        return "🚽"
    elseif cardType == "Gangbang" then
        return "💔"
    elseif cardType == "Home" then
        return "🏠"
    else
        return "❓"
    end

end

-- ==========================================
-- 덱 불러오기
-- ==========================================
function restoreChikanDeck(triggerId)

    local history = getFullChat(triggerId)
    if not history or #history == 0 then
        return false
    end

    -- 1️⃣ 초기화
    setChatVar(triggerId, "ct_Deck_Num", "0")
    setChatVar(triggerId, "ct_Deck_List", "")

    -- 2️⃣ 최신 FullSave 위치 찾기
    local fullIndex = nil

    for i = #history, 1, -1 do
        if history[i].role == "char" then
            local text = history[i].data or ""
            if text:find("<SaveChikanFullData>", 1, true) then
                fullIndex = i
                break
            end
        end
    end

    if not fullIndex then
        fullIndex = 0
    end

    -- Deck 상태 저장용
    local deckMap = {}   -- code → "[Deck: ...]"
    local maxCode = 0

    -- 3️⃣ FullSave 이후 채팅 순차 처리
    for i = fullIndex + 1, #history do

        local msg = history[i]

        if msg.role == "char" then
            local text = msg.data or ""

            -- <Chikan Deck> 블록 찾기
            for block in text:gmatch(
                "<Chikan Deck>([%s%S]-)</Chikan Deck>"
            ) do

                -- 각 라인 처리 ([ ... ])
                for line in block:gmatch("%b[]") do

                    -- ==================================
                    -- ADD
                    -- [Add: 16 | ...]
                    -- ==================================
                    if line:find("[Add:", 1, true) then

                        local content = line:match("^%[(.*)%]$")
                        if content then

                            local parts = splitLiteral(content, "|")
                            local head  = trim(parts[1] or "")

                            local code =
                                trim(head:match("Add:%s*(%d+)") or "")

                            if code ~= "" then

                                local rest = {}

                                for k = 2, #parts do
                                    rest[#rest + 1] =
                                        trim(parts[k] or "")
                                end

                                deckMap[code] =
                                    "[Deck: " .. code .. " | "
                                    .. table.concat(rest, " | ")
                                    .. "]"

                                local num = tonumber(code) or 0
                                if num > maxCode then
                                    maxCode = num
                                end
                            end
                        end

                    -- ==================================
                    -- REMOVE
                    -- [Remove: 12 | ...]
                    -- ==================================
                    elseif line:find("[Remove:", 1, true) then

                        local content = line:match("^%[(.*)%]$")
                        if content then

                            local parts = splitLiteral(content, "|")
                            local head  = trim(parts[1] or "")

                            local code =
                                trim(head:match("Remove:%s*(%d+)") or "")

                            if code ~= "" then
                                deckMap[code] = nil
                            end
                        end

                    -- ==================================
                    -- MODIFY
                    -- [Modify: 6 | ...]
                    -- ==================================
                    elseif line:find("[Modify:", 1, true) then

                        local content = line:match("^%[(.*)%]$")
                        if content then

                            local parts = splitLiteral(content, "|")
                            local head  = trim(parts[1] or "")

                            local code =
                                trim(head:match("Modify:%s*(%d+)") or "")

                            if code ~= "" then

                                local rest = {}

                                for k = 2, #parts do
                                    rest[#rest + 1] =
                                        trim(parts[k] or "")
                                end

                                deckMap[code] =
                                    "[Deck: " .. code .. " | "
                                    .. table.concat(rest, " | ")
                                    .. "]"
                            end
                        end
                    end
                end
            end
        end
    end

    -- 4️⃣ Deck_List 생성 (코드 순 정렬)
    local codes = {}

    for code in pairs(deckMap) do
        table.insert(codes, tonumber(code))
    end

    table.sort(codes)

    local lines = {}

    for _, num in ipairs(codes) do
        local code = tostring(num)
        table.insert(lines, deckMap[code])
    end

    local finalList = table.concat(lines, "\n")

    -- 5️⃣ 변수 저장
    setChatVar(triggerId, "ct_Deck_List", finalList)
    setChatVar(triggerId, "ct_Deck_Num", tostring(maxCode))

    print(">>> Deck Restore Complete")

    return true
end

-- ==========================================
-- 세이브
-- ==========================================
-- 모든 관련 변수 저장
local function buildChikanFullSave(triggerId)

    local FS = "\x1F" -- field separator
    local RS = "\x1E" -- record separator
    local GS = "\x1D" -- section separator
    local TS = "\x1C" -- tag separator

    local SAVE_FULL_TAG = "SaveChikanFullData"

    local sections = {}

    -- ==========================================
    -- 1. Global 변수 저장
    -- ==========================================
    local globalKeys = {
        "ct_Mode",
        "ct_NextDate",
        "ct_ChikanLevel",
        "ct_ChikanExp",
        "ct_ChikanPoint",
        "ct_Skill_1",
        "ct_Skill_2",
        "ct_Skill_3",
        "ct_Skill_4",
        "ct_Skill_5",
        "ct_Skill_6",
        "ct_Skill_7",
        "ct_Skill_8",
        "ct_Skill_9",
        "ct_Skill_10",
        "ct_Skill_11",
        "ct_Skill_12",
        "ct_Skill_13",
        "ct_Skill_14",
        "ct_Skill_15",
        "ct_Skill_16",
        "ct_Skill_17",
        "ct_Skill_18"
    }

    local useMemory = tostring(getChatVar(triggerId, "ct_UseMemory") or "0")
    if useMemory == "1" then
        table.insert(globalKeys, "ct_MemoryNum")
    end

    local globalFields = {}

    for _, key in ipairs(globalKeys) do
        local val = tostring(getChatVar(triggerId, key) or "")
        table.insert(globalFields, key .. "=" .. val)
    end

    table.insert(sections,
        "G" .. TS .. table.concat(globalFields, FS))

    -- ==========================================
    -- 2. Character 변수 저장
    -- ct_CharList 기준으로 실제 존재 캐릭터만 저장
    -- ==========================================
    local charListRaw = tostring(getChatVar(triggerId, "ct_CharList") or "")
    local charRecords = {}

    for entry in string.gmatch(charListRaw, "([^|]+)") do

        local code = entry:match("^(C%d%d%d)=")

        if code then

            local fields = {}

            local suffixes = {
                "_Corruption",
                "_First",
                "_Count",
                "_Bodypart",
                "_HistoryNum",
                "_LastPeriod",
                "_Pregnancy"
            }

            for _, suffix in ipairs(suffixes) do
                local fullKey = code .. suffix
                local val = tostring(getChatVar(triggerId, fullKey) or "")
                table.insert(fields, fullKey .. "=" .. val)
            end

            table.insert(charRecords,
                table.concat(fields, FS))
        end
    end

    if #charRecords > 0 then
        table.insert(sections,
            "C" .. TS .. table.concat(charRecords, RS))
    end


    -- ==========================================
    -- 3. 최종 블록 생성
    -- ==========================================
    local saveBlock =
        "<" .. SAVE_FULL_TAG .. ">"
        .. table.concat(sections, GS)
        .. "</" .. SAVE_FULL_TAG .. ">"

    return saveBlock
end

local function buildChikanTargetSave(triggerId, extraChanged)

    local FS = "\x1F"

    local parts = {}

    local stops = tonumber(getChatVar(triggerId, "ct_Target_Stops") or "0") or 0
    local remain = tonumber(getChatVar(triggerId, "ct_Target_RemainStops") or "0") or 0

    local isStartPhase = (stops == remain)

    local alwaysKeys = {
        "ct_Mode",
        "ct_Target_Arousal",
        "ct_Target_Alert",
        "ct_Target_Attention",
        "ct_Target_NextArousal",
        "ct_Target_NextAlert",
        "ct_Target_NextAttention",
        "ct_Deck_Level",
        "ct_Target_RemainStops",
        "ct_Target_ExTurn",
        "ct_Target_Extra"
    }

    for _, key in ipairs(alwaysKeys) do
        local val = tostring(getChatVar(triggerId, key) or "")
        table.insert(parts, key .. "=" .. val)
    end

    if isStartPhase then
        local startKeys = {
            "ct_Target_Name",
            "ct_Target_Stops",
            "ct_Target_Line",
            "ct_Target_Station",
            "ct_Target_Crowd",
            "ct_Target_Purpose",
            "ct_NextDate",
            "ct_NextDaypart",
            "ct_Target_Clear",

            "ct_ChikanPoint",
            "ct_Skill_1",
            "ct_Skill_2",
            "ct_Skill_3",
            "ct_Skill_4",
            "ct_Skill_5",
            "ct_Skill_6",
            "ct_Skill_7",
            "ct_Skill_8",
            "ct_Skill_9",
            "ct_Skill_10",
            "ct_Skill_11",
            "ct_Skill_12",
            "ct_Skill_13",
            "ct_Skill_14",
            "ct_Skill_15",
            "ct_Skill_16",
            "ct_Skill_17",
            "ct_Skill_18"
        }

        for _, key in ipairs(startKeys) do
            local val = tostring(getChatVar(triggerId, key) or "")
            table.insert(parts, key .. "=" .. val)
        end

        -- Target Character LastPeriod / Pregnancy 저장
        local targetName = tostring(getChatVar(triggerId, "ct_Target_Name") or "")
        local targetCode = findCharacterCode(triggerId, targetName)

        if targetCode then
            local lastPeriodKey = targetCode .. "_LastPeriod"
            local pregnancyKey  = targetCode .. "_Pregnancy"

            local lastPeriodVal = tostring(getChatVar(triggerId, lastPeriodKey) or "")
            local pregnancyVal  = tostring(getChatVar(triggerId, pregnancyKey) or "")

            table.insert(parts, lastPeriodKey .. "=" .. lastPeriodVal)
            table.insert(parts, pregnancyKey .. "=" .. pregnancyVal)

            local historyNumKey = targetCode .. "_HistoryNum"
            local historyNumVal = tostring(getChatVar(triggerId, historyNumKey) or "")

            table.insert(parts, historyNumKey .. "=" .. historyNumVal)

        end

    end

    if extraChanged then
        for key, value in pairs(extraChanged) do
            table.insert(parts, key .. "=" .. tostring(value))
        end
    end

    if #parts == 0 then
        return ""
    end

    return "<SaveChikanTargetData>"
        .. table.concat(parts, FS)
        .. "</SaveChikanTargetData>"
end

local function applyChikanFullSave(triggerId, block)

    local FS = "\x1F"
    local RS = "\x1E"
    local GS = "\x1D"
    local TS = "\x1C"

    if not block or block == "" then return end

    -- GS 단위 분리 (G / C 섹션)
    for section in block:gmatch("[^" .. GS .. "]+") do

        local tag, body = section:match("^(.-)" .. TS .. "(.*)$")

        if tag == "G" and body then
            -- Global
            for pair in body:gmatch("[^" .. FS .. "]+") do
                local key, value = pair:match("^(.-)=(.*)$")
                if key then
                    setChatVar(triggerId, key, value or "")
                end
            end

        elseif tag == "C" and body then
            -- Character
            for record in body:gmatch("[^" .. RS .. "]+") do
                for pair in record:gmatch("[^" .. FS .. "]+") do
                    local key, value = pair:match("^(.-)=(.*)$")
                    if key then
                        setChatVar(triggerId, key, value or "")
                    end
                end
            end
        end
    end
end

local function restoreChikanTargetSave(triggerId, block)

    local FS = "\x1F"

    if not block or block == "" then return end

    for pair in block:gmatch("[^" .. FS .. "]+") do
        local key, value = pair:match("^(.-)=(.*)$")
        if key then
            setChatVar(triggerId, key, value or "")
        end
    end
end

-- ==========================================
-- Restore Chikan Save From History
-- FullSave 기준 → 이후 TargetData 순차 적용
-- ==========================================
local function restoreChikanFullSave(triggerId)

    local FS = "\x1F"
    local RS = "\x1E"
    local GS = "\x1D"
    local TS = "\x1C"

    local history = getFullChat(triggerId)
    if not history or #history == 0 then
        return false
    end

    -- 초기화
    resetTargetState(triggerId)

    local fullIndex = nil
    
    local oldMemoryNum = tonumber(getChatVar(triggerId, "ct_MemoryNum") or "0") or 0

    -- ======================================
    -- 1) 최신 FullSave 찾기 (아래 → 위)
    -- ======================================
    for i = #history, 1, -1 do
        if history[i].role == "char" then
            local text = history[i].data or ""
            if text:find("<SaveChikanFullData>", 1, true) then
                fullIndex = i
                break
            end
        end
    end

    if not fullIndex then
        return false
    end

    -- ======================================
    -- 2) FullSave 블록 추출
    -- ======================================
    local fullBlock =
        history[fullIndex].data:match(
            "<SaveChikanFullData>([%s%S]-)</SaveChikanFullData>"
        )

    if not fullBlock then
        return false
    end

    -- ======================================
    -- 2.5) FullSave 블록 기준 최대 캐릭 코드 찾기
    -- ======================================
    local maxSavedCharNum = 0

    do
        -- fullBlock 전체에서 "C###_" 패턴을 스캔
        for numStr in fullBlock:gmatch("C(%d%d%d)_") do
            local n = tonumber(numStr) or 0
            if n > maxSavedCharNum then
                maxSavedCharNum = n
            end
        end
    end

    -- ======================================
    -- 3) FullSave 적용
    -- ======================================
    for section in fullBlock:gmatch("[^" .. GS .. "]+") do

        local tag, body = section:match("^(.-)" .. TS .. "(.*)$")

        if tag == "G" and body then

            -- Global
            for pair in body:gmatch("[^" .. FS .. "]+") do
                local key, value = pair:match("^(.-)=(.*)$")
                if key then
                    setChatVar(triggerId, key, value or "")
                end
            end

        elseif tag == "C" and body then

            -- Character
            for record in body:gmatch("[^" .. RS .. "]+") do
                for pair in record:gmatch("[^" .. FS .. "]+") do
                    local key, value = pair:match("^(.-)=(.*)$")
                    if key then
                        setChatVar(triggerId, key, value or "")
                    end
                end
            end
        end
    end

    -- ======================================
    -- 4) Full 이후 TargetData 순차 적용
    -- ======================================
    for i = fullIndex + 1, #history do

        if history[i].role == "char" then

            local text = history[i].data or ""

            for block in text:gmatch(
                "<SaveChikanTargetData>([%s%S]-)</SaveChikanTargetData>"
            ) do

                for pair in block:gmatch("[^" .. FS .. "]+") do
                    local key, value = pair:match("^(.-)=(.*)$")
                    if key then
                        setChatVar(triggerId, key, value or "")
                    end
                end

            end
        end
    end

    print(">>> Chikan Restore Complete (Full + Target)")

    -- ======================================
    -- FullSave 기준 초과 캐릭 정리 (CharList 기반)
    -- ======================================
    do
        local raw = safeGet(triggerId, "ct_CharList", "")
        local newEntries = {}
        local removedCodes = {}

        for token in raw:gmatch("([^|]+)") do
            local code, name = token:match("^(C%d%d%d)%=(.+)$")
            if code and name then
                local n = tonumber(code:match("%d+")) or 0
                if n <= maxSavedCharNum then
                    newEntries[#newEntries + 1] = code .. "=" .. name
                else
                    removedCodes[#removedCodes + 1] = code
                end
            end
        end

        -- ct_CharList 재작성
        setChatVar(triggerId, "ct_CharList", table.concat(newEntries, "|"))

        -- 초과 코드들에 대해서만 변수 정리
        local suffixes = {
            "_First",
            "_Count",
            "_Bodypart",
            "_HistoryNum",
            "_History",
            "_Trait",
            "_LastPeriod",
            "_Pregnancy",
            "_Profile",
            "_Type",
            "_Overview",
            "_Corruption",
            "_Nai",
            "_Response",
            "_ResponseArousal"
        }

        for _, code in ipairs(removedCodes) do
            for _, suf in ipairs(suffixes) do
                setChatVar(triggerId, code .. suf, "")
            end
        end
    end

    -- ======================================
    -- History 정합성 보정 (_HistoryNum 기준)
    -- ======================================
    do
        local raw = safeGet(triggerId, "ct_CharList", "")

        for token in raw:gmatch("([^|]+)") do

            local code = token:match("^(C%d%d%d)=")

            if code then

                local historyKey = code .. "_History"
                local numKey     = code .. "_HistoryNum"

                local historyStr = safeGet(triggerId, historyKey, "")
                local numStr     = safeGet(triggerId, numKey, "")

                local maxCount = tonumber(numStr)

                -- HistoryNum 없거나 0 이하 → 전부 삭제
                if not maxCount or maxCount <= 0 then

                    setChatVar(triggerId, historyKey, "")

                else

                    local list = splitPipe(historyStr)

                    if #list > maxCount then

                        -- 처음 maxCount개만 유지 (앞에서 유지)
                        local newList = {}

                        for i = 1, maxCount do
                            newList[#newList + 1] = list[i]
                        end

                        setChatVar(triggerId, historyKey, joinPipe(newList))
                    end
                end
            end
        end
    end

    -- ======================================
    -- Memory 정합성 보정 (ct_MemoryNum 기준)
    -- ======================================
    do
        local memNum = tonumber(getChatVar(triggerId, "ct_MemoryNum") or "0") or 0

        -- 새로 로드된 Memory 기준 페이지 계산
        local newPage = 0
        if memNum > 0 then
            newPage = math.ceil(memNum / 10)
        end

        -- 이전 Memory 기준 페이지
        local oldPage = 0
        if oldMemoryNum > 0 then
            oldPage = math.ceil(oldMemoryNum / 10)
        end

        -- ======================================
        -- 1) 마지막 페이지 내부 개수 정리
        -- ======================================
        if memNum > 0 then

            local remain = memNum % 10
            if remain == 0 then
                remain = 10
            end

            local key = string.format("ct_Memory_%03d", newPage)
            local raw = safeGet(triggerId, key, "")

            if raw ~= "" then

                local list = splitPipe(raw)

                if #list > remain then

                    local newList = {}

                    for i = 1, remain do
                        newList[#newList + 1] = list[i]
                    end

                    setChatVar(triggerId, key, joinPipe(newList))
                end
            end
        end

        -- ======================================
        -- 2) 초과 페이지 삭제
        -- ======================================
        if oldPage > newPage then

            for i = newPage + 1, oldPage do

                local key = string.format("ct_Memory_%03d", i)
                setChatVar(triggerId, key, "")

            end
        end
    end

    return true
end

-- ==========================================
-- 출력
-- ==========================================
onOutput = async(function(triggerId)

    local mode = tostring(getChatVar(triggerId, "ct_Mode") or "")

    local changedVars = {}
    local function setTrackedChatVar(triggerId, key, value)
        local prev = safeGet(triggerId, key, "")
        if tostring(prev) ~= tostring(value) then
            changedVars[key] = value
        end
        setChatVar(triggerId, key, value)
    end

    -- ==========================================
    -- Date 블록 후처리
    -- ==========================================
    local chatHistory = getFullChat(triggerId)
    if #chatHistory > 0 then
        local lastIndex = #chatHistory
        local lastMsg = chatHistory[lastIndex].data or ""
        local cleanMsg = lastMsg

        -- Date 블록 Daypart / Crowding / Appears 괄호 제거 (형식 유지)
        cleanMsg = string.gsub(cleanMsg, "(%[Date:%s*[^%]]+%])", function(block)
            block = string.gsub(block, "(Daypart:%s*[^|%]]-)%s*%b()%s*(%|)", "%1 %2")
            block = string.gsub(block, "(Crowding:%s*[^|%]]-)%s*%b()%s*(%|)", "%1 %2")
            block = string.gsub(block, "(Appears:%s*[^|%]]-)%s*%b()%s*(%|)", "%1 %2")
            block = string.gsub(block, "(Daypart:%s*[^|%]]-)%s*%b()%s*(%])", "%1 %2")
            block = string.gsub(block, "(Crowding:%s*[^|%]]-)%s*%b()%s*(%])", "%1 %2")
            block = string.gsub(block, "(Appears:%s*[^|%]]-)%s*%b()%s*(%])", "%1 %2")
            return block
        end)

        local targetName = safeGet(triggerId, "ct_Target_Name", "")
        if mode == "1" and targetName ~= "" then

            local function isValidDate(str)
                if not str then return false end
                str = trim(str)
                return str:match("^%d%d%d%d%-%d%d%-%d%d$") ~= nil
            end
            -- ==========================================
            -- 1. 원본 <Result ...> 상태에서 먼저 파싱
            -- ==========================================
            local countContent   = cleanMsg:match("<Result Count>%s*(.-)%s*</Result Count>")
            local bodyContent    = cleanMsg:match("<Result Body Part>%s*(.-)%s*</Result Body Part>")
            local actContent     = cleanMsg:match("<Result Sexual Act>%s*(.-)%s*</Result Sexual Act>")

            local firstKiss      = cleanMsg:match("<Result First Kiss>%s*(.-)%s*</Result First Kiss>")
            local firstFellatio  = cleanMsg:match("<Result First Fellatio>%s*(.-)%s*</Result First Fellatio>")
            local firstVaginal   = cleanMsg:match("<Result First Vaginal Penetration>%s*(.-)%s*</Result First Vaginal Penetration>")
            local firstAnal      = cleanMsg:match("<Result First Anal Penetration>%s*(.-)%s*</Result First Anal Penetration>")

            local fkDate, fkSource = cleanMsg:match("<Result First Kiss>%s*Date:%s*(.-)%s*|%s*Source:%s*(.-)%s*</Result First Kiss>")
            local ffDate, ffSource = cleanMsg:match("<Result First Fellatio>%s*Date:%s*(.-)%s*|%s*Source:%s*(.-)%s*</Result First Fellatio>")
            local fvDate, fvSource = cleanMsg:match("<Result First Vaginal Penetration>%s*Date:%s*(.-)%s*|%s*Source:%s*(.-)%s*</Result First Vaginal Penetration>")
            local faDate, faSource = cleanMsg:match("<Result First Anal Penetration>%s*Date:%s*(.-)%s*|%s*Source:%s*(.-)%s*</Result First Anal Penetration>")

            local isImportantMemory = false

            -- Session
            local targetCode = findCharacterCode(triggerId, targetName)
            local timeSpan = ""
            local location = ""

            local nextDate = tostring(getChatVar(t, "ct_NextDate") or "")
            local nextDaypart = tostring(getChatVar(t, "ct_NextDaypart") or "")
            local targetLine = tostring(getChatVar(t, "ct_Target_Line") or "")

            if nextDate ~= "" then
                timeSpan = nextDate .. " " .. nextDaypart
            end

            location = trim(targetLine)

            -- Stat 계산
            local totalStops = tonumber(getChatVar(triggerId, "ct_Target_Stops") or "0") or 0
            local remainStops = tonumber(getChatVar(triggerId, "ct_Target_RemainStops") or "0") or 0
            local exTurn     = tonumber(getChatVar(triggerId, "ct_Target_ExTurn") or "-1") or -1
            local finalArousal        = tonumber(getChatVar(triggerId, "ct_Target_NextArousal") or "0") or 0
            local finalAlert      = tonumber(getChatVar(triggerId, "ct_Target_NextAlert") or "0") or 0
            local finalAttention  = tonumber(getChatVar(triggerId, "ct_Target_NextAttention") or "0") or 0

            local elapsed = totalStops - remainStops + exTurn + 1
            if elapsed < 0 then elapsed = 0 end

            -- Sexual Acts
            local act1, act2, act3 = nil, nil, nil
            if actContent then
                act1 = trim(actContent:match("Act1:%s*([^|]+)") or "")
                act2 = trim(actContent:match("Act2:%s*([^|]+)") or "")
                act3 = trim(actContent:match("Act3:%s*([^\n]+)") or "")

                -- Act1/2/3 형식이 없으면 | 분리 방식 사용
                if act1 == "" and act2 == "" and act3 == "" then
                    local parts = {}

                    for part in string.gmatch(actContent, "([^|]+)") do
                        table.insert(parts, trim(part))
                    end

                    act1 = parts[1] or ""
                    act2 = parts[2] or ""
                    act3 = parts[3] or ""
                end
            end

            local acts = {}
            local function validAct(a)
                return a and a ~= "" and a ~= "None" and a ~= "없음" and a ~= "なし"
            end
            if validAct(act1) then table.insert(acts, act1) end
            if validAct(act2) then table.insert(acts, act2) end
            if validAct(act3) then table.insert(acts, act3) end

            local climax, ext, oral, vaginal, anal = 0,0,0,0,0
            if countContent then
                climax  = tonumber(countContent:match("Climax:%s*(%d+)") or "0")
                ext     = tonumber(countContent:match("External Ejaculation:%s*(%d+)") or "0")
                oral    = tonumber(countContent:match("Oral Ejaculation:%s*(%d+)") or "0")
                vaginal = tonumber(countContent:match("Vaginal Ejaculation:%s*(%d+)") or "0")
                anal    = tonumber(countContent:match("Anal Ejaculation:%s*(%d+)") or "0")
            end

            -- Count
            local currentBodyRaw = ""
            local currentBody = {}
            local bodyParts = {}
            local bodyExpGain = 0

            local bodyIndexMap = {
                ["Breast"]    = 1,
                ["Oral"]     = 2,
                ["Clitoris"] = 3,
                ["Vaginal"]  = 4,
                ["Anal"]     = 5
            }

            -- Body Part
            local levelMap = {
                ["None"] = 0,
                ["Trace"] = 1,
                ["Subtle"] = 2,
                ["Very Light"] = 3,
                ["Light"] = 4,
                ["Slight"] = 5,
                ["Mild"] = 6,
                ["Moderate"] = 7,
                ["Noticeable"] = 8,
                ["Pronounced"] = 9,
                ["Heavy"] = 10,
                ["Strong"] = 11,
                ["Intense"] = 12,
                ["Overwhelming"] = 13,
                ["Saturated"] = 14
            }

            local function bodypartSkillAdd(prev, num)
                local skillRaw = tostring(getChatVar(triggerId, "ct_Skill_18") or "0")
                local s18 = tonumber(extractInt(skillRaw) or 0) or 0

                if s18 > 0 then
                    local scale = 1

                    if prev <= 55 then
                        scale = 6 - (prev / 55) * 4
                    elseif prev <= 100 then
                        scale = 2 - (prev - 55) / 45
                    end

                    return math.floor(num * scale)
                end

                return num
            end

            if targetCode then
                currentBodyRaw = safeGet(triggerId, targetCode .. "_Bodypart", "0|0|0|0|0")
                currentBody = splitPipe(currentBodyRaw)

                if bodyContent then

                    local labelMap = {
                        ["Breast"]    = "가슴",
                        ["Oral"]     = "구강",
                        ["Clitoris"] = "클리토리스",
                        ["Vaginal"]  = "질",
                        ["Anal"]     = "항문"
                    }

                    for label, value in string.gmatch(bodyContent, "([^:|]+):%s*([^|]+)") do
                        label = trim(label)
                        value = trim(value)

                        local num = levelMap[value] or 0
                        if num > 0 then
                            local koreanLabel = labelMap[label] or label

                            local idx = bodyIndexMap[label]
                            local prev = tonumber(currentBody[idx]) or 0

                            if prev >= 200 then
                                table.insert(bodyParts, koreanLabel .. ": 이미 최대치 입니다 (200 / 200)")
                            else       
                                bodyExpGain = bodyExpGain + clamp(prev + num, 0, 200) - prev

                                num = bodypartSkillAdd(prev, num)

                                local after = clamp(prev + num, 0, 200)
                                local gained = after - prev

                                table.insert(bodyParts, koreanLabel .. ": +" .. gained .. " (" .. after .. " / 200)")
                            end
                        end
                    end


                end
            end

            local commentLine = ""
            local lineMatch = cleanMsg:match("<Result Comment>%s*Line:%s*\"(.-)\"%s*</Result Comment>")

            if lineMatch and trim(lineMatch) ~= "" then
                commentLine = trim(lineMatch)
            else
                local rawComment = cleanMsg:match("<Result Comment>%s*(.-)%s*</Result Comment>")

                if rawComment and trim(rawComment) ~= "" then
                    rawComment = trim(rawComment)

                    -- 2-1) 콜론 오른쪽 시도
                    local right = rawComment:match(":%s*(.*)")

                    if right then
                        right = trim(right)

                        -- 콜론은 있는데 오른쪽이 비었으면 전체 사용
                        if right ~= "" then
                            commentLine = right
                        else
                            commentLine = rawComment
                        end
                    else
                        commentLine = rawComment
                    end

                    commentLine = commentLine:gsub('[\"\']', '')
                    commentLine = trim(commentLine)
                end
            end

            if not commentLine then
                commentLine = ""
            end

            -- ==========================================
            -- 2. 최종 Result Message 구성
            -- ==========================================

            local resultLines = {}
            local targetDisplayName = safeGet(triggerId, "ct_Target_Name", "")

            if targetDisplayName ~= "" then
                table.insert(resultLines,
                    "이름: " .. targetDisplayName)
            end

            if timeSpan ~= "" then
                table.insert(resultLines, "날짜: " .. timeSpan)
            end

            if location ~= "" then
                table.insert(resultLines, "장소: " .. location)
            end

            table.insert(resultLines, "경과 턴: " .. elapsed)

            local clearFlag = tostring(getChatVar(triggerId, "ct_Target_Clear") or "0")

            -- 결과 표시
            do
                local resultText

                if clearFlag == "1" then
                    resultText = "결과: 성공"
                else
                    resultText = "결과: 실패"
                end

                table.insert(resultLines, resultText)
            end

            if commentLine ~= "" and targetDisplayName ~= "" then
                table.insert(resultLines, targetDisplayName .. "의 한마디: " .. commentLine)
            end

            if #acts > 0 then
                table.insert(resultLines, "주요 성행위: " .. table.concat(acts, ", "))
            end

            if climax > 0 then table.insert(resultLines, "절정: " .. climax .. "회") end
            if ext > 0 then table.insert(resultLines, "부카케: " .. ext .. "회") end
            if vaginal > 0 then table.insert(resultLines, "질내사정: " .. vaginal .. "회") end
            if oral > 0 then table.insert(resultLines, "구강사정: " .. oral .. "회") end
            if anal > 0 then table.insert(resultLines, "항문사정: " .. anal .. "회") end

            for _, b in ipairs(bodyParts) do
                table.insert(resultLines, b)
            end

            if firstKiss and trim(firstKiss) ~= "" then
                local date   = firstKiss:match("Date:%s*([^|]+)")
                local source = firstKiss:match("Source:%s*(.+)")
                if isValidDate(date) and source then
                    table.insert(resultLines,
                        "첫 키스: " .. trim(date) .. " (" .. trim(source) .. ")")
                end
            end

            if firstFellatio and trim(firstFellatio) ~= "" then
                local date   = firstFellatio:match("Date:%s*([^|]+)")
                local source = firstFellatio:match("Source:%s*(.+)")
                if isValidDate(date) and source then
                    table.insert(resultLines,
                        "첫 펠라치오: " .. trim(date) .. " (" .. trim(source) .. ")")
                end
            end

            if firstVaginal and trim(firstVaginal) ~= "" then
                local date   = firstVaginal:match("Date:%s*([^|]+)")
                local source = firstVaginal:match("Source:%s*(.+)")
                if isValidDate(date) and source then
                    table.insert(resultLines,
                        "처녀막 상실: " .. trim(date) .. " (" .. trim(source) .. ")")
                end
            end

            if firstAnal and trim(firstAnal) ~= "" then
                local date   = firstAnal:match("Date:%s*([^|]+)")
                local source = firstAnal:match("Source:%s*(.+)")
                if isValidDate(date) and source then
                    table.insert(resultLines,
                        "첫 항문 삽입: " .. trim(date) .. " (" .. trim(source) .. ")")
                end
            end

            -- --------------------------------------
            -- Pregnancy Score 계산
            -- --------------------------------------
            if targetCode and vaginal > 0 then

                local lastPeriodRaw = safeGet(triggerId, targetCode .. "_LastPeriod", "")
                local currentDate = safeGet(triggerId, "ct_NextDate", "")
                local pregKey = targetCode .. "_Pregnancy"
                local pregRaw = safeGet(triggerId, pregKey, "")

                -- 날짜 형식인지 체크 (임신 확정 상태인지 판별)
                local isDate = pregRaw:match("^%d%d%d%d%-%d%d%-%d%d$")

                -- ==========================================
                -- 실행 조건:
                -- 1) LastPeriod가 "X"가 아닐 것 (이미 임신 상태 아님)
                -- 2) Pregnancy가 날짜가 아닐 것 (이미 임신 확정 아님)
                -- ==========================================
                if lastPeriodRaw ~= "X" and not isDate then

                    local y, m, d = lastPeriodRaw:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")
                    local y2, m2, d2 = currentDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

                    if y and m and d and y2 and m2 and d2 then

                        local lastTime = os.time({
                            year  = tonumber(y),
                            month = tonumber(m),
                            day   = tonumber(d),
                            hour  = 12
                        })

                        local currentTime = os.time({
                            year  = tonumber(y2),
                            month = tonumber(m2),
                            day   = tonumber(d2),
                            hour  = 12
                        })

                        local cycleDay = math.floor((currentTime - lastTime) / 86400) + 1
                        cycleDay = ((cycleDay - 1) % 28) + 1

                        local multiplier = 0

                        if cycleDay == 14 then
                            multiplier = 25
                        elseif cycleDay == 13 then
                            multiplier = 20
                        elseif cycleDay == 15 then
                            multiplier = 17
                        elseif cycleDay == 12 then
                            multiplier = 15
                        elseif cycleDay == 11 then
                            multiplier = 12
                        elseif cycleDay == 9 or cycleDay == 10 then
                            multiplier = 9
                        else
                            multiplier = 0
                        end

                        if multiplier > 0 then

                            -- ""이면 0부터 시작
                            local prevPreg = tonumber(pregRaw) or 0
                            local newPreg  = prevPreg + (vaginal * multiplier)

                            newPreg = math.min(newPreg, 100)

                            setTrackedChatVar(triggerId, pregKey, tostring(newPreg))
                            table.insert(resultLines, "임신 확률: " .. prevPreg .. "％ → " .. newPreg .. "％")
                        end
                    end
                end
            end

            -- ==========================================
            -- Chikan Experience 계산
            -- ==========================================
            local expGain = 0

            -- 1) 경과 턴 기반 EXP
            if totalStops ~= remainStops then
                if clearFlag == "1" then
                    expGain = expGain + (math.min(elapsed, 10)* 10)

                    if elapsed > 10 then
                        local extra = elapsed - 10
                        expGain = expGain + (extra * 5)

                        if elapsed >= 20 and finalAlert < 100 and finalAttention < 100 and finalArousal >= 135 then
                            expGain = expGain + 100
                        end
                    end
                else
                    expGain = expGain + (elapsed * 2)
                end
            end

            -- 2) Stat 기반
            local statPart = math.max(0, math.floor(finalArousal - ((finalAlert + finalAttention) / 2)))

            expGain = expGain + statPart

            local arousalBonus = math.floor(finalArousal / 10)
            expGain = expGain + arousalBonus

            -- 3) Body Part 합산
            expGain = expGain + bodyExpGain

            -- 4) First 경험 보너스 (Date + Source 형식일 때만 +10)
            local firstBonus = 0

            if isValidDate(fkDate) and fkSource then
                firstBonus = firstBonus + 25
            end

            if isValidDate(ffDate) and ffSource then
                firstBonus = firstBonus + 25
            end

            if isValidDate(fvDate) and fvSource then
                firstBonus = firstBonus + 25
            end

            if isValidDate(faDate) and faSource then
                firstBonus = firstBonus + 25
            end

            expGain = expGain + firstBonus

            -- 4-1) Count 총합 보너스
            local totalCount = climax + ext + oral + vaginal + anal
            local countExp = math.min(totalCount * 5, 50)
            expGain = expGain + countExp

            -- 특수 x1.5
            local extraClear = tonumber(getChatVar(triggerId, "ct_Target_Extra") or "0") or 0
            if extraClear > 0 then
                expGain = math.floor(expGain * 1.5)
            end

            if targetCode then
                local corrKey = targetCode .. "_Corruption"

                local curCorr = tonumber(getChatVar(triggerId, corrKey) or "0") or 0
                
                -- Corruption 증가
                local gain = 0

                if totalStops == remainStops then
                    gain = 0
                else
                    local baseDiv

                    if clearFlag ~= "1" then
                        baseDiv = 30
                    else
                        baseDiv = 10 + math.floor(curCorr / 15)
                    end

                    local corrScale = 1 + math.sqrt(curCorr) / 30
                    local expScale  = 1 + math.log(expGain + 1) * 0.05

                    gain = math.ceil(expGain / (baseDiv * corrScale * expScale))
                end

                if gain > 0 then
                    local newCorr = clamp(curCorr + gain, 0, 100)
                    setTrackedChatVar(triggerId, corrKey, tostring(newCorr))

                    if newCorr ~= curCorr then
                        table.insert(resultLines, "함락: +" .. (newCorr - curCorr) .. " (" .. newCorr .. " / 100)")
                    end
                end

                local reduction = 0

                if curCorr < 50 then
                    reduction = 0
                else
                    reduction = (curCorr - 50) / 50 * 0.5
                    if reduction > 0.5 then reduction = 0.5 end
                end

                expGain = math.floor(expGain * (1 - reduction))
            end

            -- 5) ct_ChikanExp 누적
            local currentExp = tonumber(getChatVar(triggerId, "ct_ChikanExp") or "0") or 0
            local currentLevel = tonumber(getChatVar(triggerId, "ct_ChikanLevel") or "1") or 1

            local originalLevel = currentLevel

            local function getRequiredExp(level)
                local cap = 200
                if level >= 40 then
                    cap = 300
                elseif level >= 30 then
                    cap = 250
                end

                return math.min(cap, level * 10)
            end

            local requiredBefore = getRequiredExp(originalLevel)

            local newExpTotal = currentExp + expGain
            local newExp = newExpTotal
            local levelUp = false

            -- 레벨업 처리
            while newExp >= getRequiredExp(currentLevel) do
                newExp = newExp - getRequiredExp(currentLevel)
                currentLevel = currentLevel + 1
                levelUp = true

                createRandomCharacter(triggerId, currentLevel, false)
            end

            setTrackedChatVar(triggerId, "ct_ChikanExp", tostring(newExp))
            setTrackedChatVar(triggerId, "ct_ChikanLevel", tostring(currentLevel))

            -- 6) Result Message 표시

            table.insert(resultLines, "치한 경험치: +" .. expGain .. " EXP (" .. newExpTotal .. " / " .. requiredBefore .. ")")

            if levelUp then
                local requiredAfter = getRequiredExp(currentLevel)
                table.insert(resultLines, "치한 레벨 상승! Lv." .. currentLevel .. " (" .. newExp .. " / " .. requiredAfter .. ")")
            end

            -- ==========================================
            -- 3. Character Variable Update (파싱 후 값 저장)
            -- ==========================================
            if targetCode then

                -- --------------------------------------
                -- 3-1. History 저장
                -- --------------------------------------
                if timeSpan ~= "" and totalStops ~= remainStops then
                    local historyEntry = timeSpan

                    local actsText = ""
                    if #acts > 0 then
                        actsText = table.concat(acts, ", ")
                    end
                    historyEntry = historyEntry .. " § " .. actsText .. " § " .. commentLine

                    local oldHistory = safeGet(triggerId, targetCode .. "_History", "")

                    if oldHistory == "" then
                        isImportantMemory = true
                        setChatVar(triggerId, targetCode .. "_History", historyEntry)
                    else
                        setChatVar(triggerId, targetCode .. "_History", oldHistory .. " | " .. historyEntry)
                    end

                    -- History 개수 계산 → _HistoryNum 저장
                    updateHistoryCount(triggerId, targetCode)

                end

                -- --------------------------------------
                -- 3-2. Count 누적 저장
                -- --------------------------------------
                local currentCountRaw = safeGet(triggerId, targetCode .. "_Count", "0|0|0|0|0")
                local currentCount = splitPipe(currentCountRaw)

                local prevClimax  = tonumber(currentCount[1]) or 0
                local prevOral    = tonumber(currentCount[3]) or 0
                local prevVaginal = tonumber(currentCount[4]) or 0
                local prevAnal    = tonumber(currentCount[5]) or 0

                if (prevClimax == 0 and climax > 0) or (prevOral == 0 and oral > 0) or (prevVaginal == 0 and vaginal > 0) or (prevAnal == 0 and anal > 0) then
                    isImportantMemory = true
                end

                currentCount[1] = tostring((tonumber(currentCount[1]) or 0) + climax)
                currentCount[2] = tostring((tonumber(currentCount[2]) or 0) + ext)
                currentCount[3] = tostring((tonumber(currentCount[3]) or 0) + oral)
                currentCount[4] = tostring((tonumber(currentCount[4]) or 0) + vaginal)
                currentCount[5] = tostring((tonumber(currentCount[5]) or 0) + anal)

                setTrackedChatVar(triggerId, targetCode .. "_Count", table.concat(currentCount, "|"))

                -- --------------------------------------
                -- 3-3. Bodypart 저장 (누적 +)
                -- --------------------------------------
                if bodyContent then
                    for label, value in string.gmatch(bodyContent, "([^:|]+):%s*([^|]+)") do
                        label = trim(label)
                        value = trim(value)

                        local idx = bodyIndexMap[label]
                        local num = levelMap[value] or 0

                        if idx then
                            local prev = tonumber(currentBody[idx]) or 0
                            num = bodypartSkillAdd(prev, num)

                            currentBody[idx] = tostring(clamp(prev + num, 0, 200))
                        end
                    end
                end

                setTrackedChatVar(triggerId, targetCode .. "_Bodypart",
                    table.concat(currentBody, "|"))

                -- --------------------------------------
                -- 3-4. First 저장 (Date (Source))
                -- --------------------------------------
                local rawFirst = safeGet(triggerId, targetCode .. "_First", "0|0|0|0")
                local firstStatus = splitPipe(rawFirst)

                if isValidDate(fkDate) and fkSource and firstStatus[1] == "0" then
                    firstStatus[1] = trim(fkDate) .. " (" .. trim(fkSource) .. ")"
                    isImportantMemory = true
                end

                if isValidDate(ffDate) and ffSource and firstStatus[2] == "0" then
                    firstStatus[2] = trim(ffDate) .. " (" .. trim(ffSource) .. ")"
                    isImportantMemory = true
                end

                if isValidDate(fvDate) and fvSource and firstStatus[3] == "0" then
                    firstStatus[3] = trim(fvDate) .. " (" .. trim(fvSource) .. ")"
                    isImportantMemory = true
                end

                if isValidDate(faDate) and faSource and firstStatus[4] == "0" then
                    firstStatus[4] = trim(faDate) .. " (" .. trim(faSource) .. ")"
                    isImportantMemory = true
                end

                setTrackedChatVar(triggerId, targetCode .. "_First", table.concat(firstStatus, "|"))

                -- --------------------------------------
                -- Memory 저장
                -- --------------------------------------
                local useMemory = tostring(getChatVar(triggerId, "ct_UseMemory") or "0")
                if useMemory == "1" then

                    local summaryContent = cleanMsg:match("<Result Summary>%s*(.-)%s*</Result Summary>")

                    if summaryContent then

                        local normalized = summaryContent

                        -- 줄바꿈 제거
                        normalized = normalized:gsub("[\r\n]+", " ")

                        -- 필드 사이 | 강제 삽입
                        normalized = normalized:gsub("Context Overview:%s*(.-)%s*Core Events:", "Context Overview: %1 | Core Events:")
                        normalized = normalized:gsub("Core Events:%s*(.-)%s*Summary:", "Core Events: %1 | Summary:")
                        normalized = normalized:gsub("Summary:%s*(.-)%s*Heroine's Diary:", "Summary: %1 | Heroine's Diary:")
                        normalized = normalized:gsub("Heroine's Diary:%s*(.-)%s*Heroine's Key Lines:", "Heroine's Diary: %1 | Heroine's Key Lines:")
                        normalized = normalized:gsub("Heroine's Key Lines:%s*(.-)%s*Personal Reflection:", "Heroine's Key Lines: %1 | Personal Reflection:")
                        normalized = normalized:gsub("%s+", " ")

                        local memOverview = trim(normalized:match("Context Overview:%s*([^|]+)") or "")
                        local memEvents   = trim(normalized:match("Core Events:%s*([^|]+)") or "")
                        local memSummary  = trim(normalized:match("Summary:%s*([^|]+)") or "")
                        local memDiary    = trim(normalized:match("Heroine's Diary:%s*([^|]+)") or "")
                        local memDialogue = trim(normalized:match("Heroine's Key Lines:%s*([^|]+)") or "")
                        local memReflection = trim(normalized:match("Personal Reflection:%s*(.+)") or "")

                        if memOverview ~= "" or memEvents ~= "" or memSummary ~= "" or memDialogue ~= "" or memDiary ~= "" or memReflection ~= "" then

                            local dateStr = timeSpan or ""
                            local locStr = location or ""
                            local nameStr = targetDisplayName or ""
                            local successFlag = (clearFlag == "1") and "1" or "0"
                            local importantFlag = isImportantMemory and "1" or "0"

                            local entry =
                                dateStr .. " § " ..
                                locStr .. " § " ..
                                nameStr .. " § " ..
                                successFlag .. " § " ..
                                importantFlag .. " § " ..
                                memOverview .. " § " ..
                                memEvents .. " § " ..
                                memSummary .. " § " ..
                                memDiary .. " § " ..
                                memDialogue .. " § " ..
                                memReflection

                            local memNum = tonumber(getChatVar(triggerId, "ct_MemoryNum") or "0") or 0

                            local page = math.floor(memNum / 10) + 1
                            local memKey = string.format("ct_Memory_%03d", page)

                            local oldMemory = safeGet(triggerId, memKey, "")

                            if oldMemory == "" then
                                setChatVar(triggerId, memKey, entry)
                            else
                                setChatVar(triggerId, memKey, oldMemory .. " | " .. entry)
                            end

                            setChatVar(triggerId, "ct_MemoryNum", tostring(memNum + 1))
                        end
                    end
                end
            end

            -- 기존 특정 <Result ...> 태그만 제거
            cleanMsg = cleanMsg:gsub("<Result Count>%s*.-%s*</Result Count>", "")
            cleanMsg = cleanMsg:gsub("<Result Body Part>%s*.-%s*</Result Body Part>", "")
            cleanMsg = cleanMsg:gsub("<Result Sexual Act>%s*.-%s*</Result Sexual Act>", "")
            cleanMsg = cleanMsg:gsub("<Result First Kiss>%s*.-%s*</Result First Kiss>", "")
            cleanMsg = cleanMsg:gsub("<Result First Fellatio>%s*.-%s*</Result First Fellatio>", "")
            cleanMsg = cleanMsg:gsub("<Result First Vaginal Penetration>%s*.-%s*</Result First Vaginal Penetration>", "")
            cleanMsg = cleanMsg:gsub("<Result First Anal Penetration>%s*.-%s*</Result First Anal Penetration>", "")
            cleanMsg = cleanMsg:gsub("<Result Comment>%s*.-%s*</Result Comment>", "")
            cleanMsg = cleanMsg:gsub("<Result Summary>%s*.-%s*</Result Summary>", "")

            -- 최종 메시지 추가
            local finalBlocks = {}

            for _, line in ipairs(resultLines) do
                table.insert(finalBlocks,
                    "[Result Message: " .. line .. "]")
            end

            local resultTextBlock = table.concat(finalBlocks, "\n")

            if cleanMsg:find("<Choice>") then
                cleanMsg = cleanMsg:gsub("(<Choice>)", "\n\n" .. resultTextBlock .. "\n\n%1", 1)
            else
                cleanMsg = cleanMsg .. "\n\n" .. resultTextBlock
            end

            -- 변수 초기화
            --resetTargetState(triggerId)

        elseif mode == "2" then
            local chikanMessages = {}
            -- ==========================================
            -- Deck 처리 (Action Order 기반)
            -- ==========================================
            print("치한 Deck Update")
            do
                local chatHistory = getFullChat(triggerId)

                if chatHistory and #chatHistory >= 2 then
                    local prevMsg = chatHistory[#chatHistory - 1].data or ""

                    local deckRaw = safeGet(triggerId, "ct_Deck_List", "")
                    if deckRaw ~= "" then

                        local deckLines = splitLiteral(deckRaw, "\n")

                        local removeOutputs = {}
                        local removedInfo = {}
                        local modifyOutputs = {}
                        local removedCodes = {}
                        local modifyMap = {}

                        local usedCodes = {}

                        for code in prevMsg:gmatch(
                            "%[Action Order:%s*%d+%s*|%s*Code:%s*(%d+)"
                        ) do
                            usedCodes[trim(code)] = true
                        end

                        -- ==================================
                        -- 수동 제거(ct_Deck_Remove) 먼저 처리
                        -- ==================================
                        do
                            local removeRaw = tostring(getChatVar(triggerId, "ct_Deck_Remove") or "")
                            if removeRaw ~= "" then

                                -- 제거 대상 이름 목록
                                local removeNameMap = {}
                                for name in string.gmatch(removeRaw, "[^,]+") do
                                    local n = trim(name)
                                    if n ~= "" then
                                        removeNameMap[n] = true
                                    end
                                end

                                if next(removeNameMap) then
                                    local i = 1
                                    while i <= #deckLines do
                                        local line = deckLines[i]
                                        local content = line:match("^%[(.*)%]$")

                                        if content then
                                            local parts = splitLiteral(content, "|")

                                            local rawCode = trim(parts[1] or "")
                                            local dCode   = trim(rawCode:match("(%d+)$") or rawCode)
                                            local name    = trim(parts[2] or "")
                                            local level   = tonumber(trim(parts[3] or "")) or 1
                                            local cType   = trim(parts[4] or "")

                                            -- 이름 일치 + 이번 턴 사용 액션이 아니면 제거
                                            if removeNameMap[name] and not removedCodes[dCode] and not usedCodes[dCode] then

                                                table.insert(removeOutputs, "[Remove: " .. dCode .. " | " .. name .. "]")

                                                removedCodes[dCode] = true

                                                removedInfo[dCode] = {
                                                    name  = name,
                                                    level = level,
                                                    type  = cType
                                                }

                                                table.remove(deckLines, i)
                                            else
                                                i = i + 1
                                            end
                                        else
                                            i = i + 1
                                        end
                                    end
                                end

                                setChatVar(triggerId, "ct_Deck_Remove", "")
                            end
                        end

                        -- ==================================
                        -- Action Order 블록 순회
                        -- ==================================
                        for code, result in prevMsg:gmatch(
                            "%[Action Order:%s*%d+%s*|%s*Code:%s*(%d+).-Result:%s*([^|%]]+)"
                        ) do

                            code   = trim(code or "")
                            result = trim(result or "")

                            local removeIndex = nil
                            local removedParts = nil
                            local removedLevel = 0

                            -- ==================================
                            -- 1️⃣ 제거 대상 찾기
                            -- ==================================
                            for i, line in ipairs(deckLines) do

                                local content = line:match("^%[(.*)%]$")
                                if content then
                                    local parts = splitLiteral(content, "|")

                                    local rawCode = trim(parts[1] or "")
                                    local dCode   = trim(rawCode:match("(%d+)$") or rawCode)
                                    local name    = trim(parts[2] or "")
                                    local level   = tonumber(trim(parts[3] or "")) or 1

                                    if dCode == code then
                                        removeIndex = i
                                        removedParts = parts
                                        removedLevel = level

                                        table.insert(removeOutputs,
                                            "[Remove: " .. dCode .. " | " .. name .. "]")

                                        removedCodes[dCode] = true

                                        removedInfo[dCode] = {
                                            name  = name,
                                            level = level,
                                            type  = trim(removedParts[4] or "")
                                        }

                                        break
                                    end
                                end
                            end

                            if removeIndex then

                                local rType   = trim(removedParts[4] or "")
                                local rTarget = trim(removedParts[5] or "")

                                -- 실제 제거
                                table.remove(deckLines, removeIndex)

                                -- ==================================
                                -- 저레벨 자동 제거 (타입별 기준)
                                -- Molestation: 2레벨 차이
                                -- Preparation: 3레벨 차이
                                -- ==================================
                                do
                                    local deckLevel =
                                        tonumber(getChatVar(triggerId, "ct_Deck_Level") or "0") or 0

                                    local autoRemoveMaxLevel_MD = deckLevel - 2   -- Molestation
                                    local autoRemoveMaxLevel_P  = deckLevel - 3   -- Preparation

                                    if autoRemoveMaxLevel_MD >= 1 or autoRemoveMaxLevel_P >= 1 then

                                        local i = 1
                                        while i <= #deckLines do
                                            local line = deckLines[i]
                                            local content = line:match("^%[(.*)%]$")

                                            if content then
                                                local parts = splitLiteral(content, "|")

                                                local rawCode = trim(parts[1] or "")
                                                local dCode   = trim(rawCode:match("(%d+)$") or rawCode)
                                                local name    = trim(parts[2] or "")
                                                local level   = tonumber(trim(parts[3] or "")) or 1
                                                local cType   = trim(parts[4] or "")

                                                local shouldRemove = false

                                                -- Molestation : 2레벨 차이
                                                if cType == "Molestation" and autoRemoveMaxLevel_MD >= 1 and level <= autoRemoveMaxLevel_MD then
                                                    shouldRemove = true
                                                end

                                                -- Preparation : 3레벨 차이
                                                if cType == "Preparation" and autoRemoveMaxLevel_P >= 1 and level <= autoRemoveMaxLevel_P then
                                                    shouldRemove = true
                                                end

                                                if shouldRemove and not removedCodes[dCode] and not usedCodes[dCode] then

                                                    table.insert(removeOutputs,
                                                        "[Remove: " .. dCode .. " | " .. name .. "]")

                                                    removedCodes[dCode] = true

                                                    removedInfo[dCode] = {
                                                        name  = name,
                                                        level = level,
                                                        type  = cType
                                                    }

                                                    table.remove(deckLines, i)

                                                else
                                                    i = i + 1
                                                end

                                            else
                                                i = i + 1
                                            end
                                        end
                                    end
                                end

                                -- ==================================
                                -- 덱 최대 20장 제한 (저레벨 + 오래된 카드부터 제거)
                                -- ==================================
                                do
                                    local MAX_DECK = 20

                                    while #deckLines > MAX_DECK do

                                        -- 1️⃣ 현재 덱에서 가장 낮은 레벨 찾기
                                        local minLevel = math.huge

                                        for _, line in ipairs(deckLines) do
                                            local content = line:match("^%[(.*)%]$")
                                            if content then
                                                local parts = splitLiteral(content, "|")
                                                local rawCode = trim(parts[1] or "")
                                                local dCode   = trim(rawCode:match("(%d+)$") or rawCode)
                                                local level   = tonumber(trim(parts[3] or "")) or 1

                                                if not usedCodes[dCode] and level < minLevel then
                                                    minLevel = level
                                                end
                                            end
                                        end

                                        -- 2️⃣ 앞에서부터 가장 낮은 레벨 카드 찾기
                                        local removeIndex = nil

                                        for i, line in ipairs(deckLines) do
                                            local content = line:match("^%[(.*)%]$")
                                            if content then
                                                local parts = splitLiteral(content, "|")
                                                local rawCode = trim(parts[1] or "")
                                                local dCode   = trim(rawCode:match("(%d+)$") or rawCode)
                                                local level   = tonumber(trim(parts[3] or "")) or 1

                                                if not usedCodes[dCode] and level == minLevel then
                                                    removeIndex = i
                                                    break
                                                end
                                            end
                                        end

                                        -- 3️⃣ 제거 실행
                                        if removeIndex then
                                            local line = deckLines[removeIndex]

                                            local content = line:match("^%[(.*)%]$")
                                            if content then
                                                local parts = splitLiteral(content, "|")

                                                local rawCode = trim(parts[1] or "")
                                                local dCode   = trim(rawCode:match("(%d+)$") or rawCode)
                                                local name    = trim(parts[2] or "")
                                                local level   = tonumber(trim(parts[3] or "")) or 1
                                                local cType   = trim(parts[4] or "")

                                                table.insert(removeOutputs,
                                                    "[Remove: " .. dCode .. " | " .. name .. "]")

                                                removedCodes[dCode] = true

                                                removedInfo[dCode] = {
                                                    name  = name,
                                                    level = level,
                                                    type  = cType
                                                }
                                            end

                                            table.remove(deckLines, removeIndex)
                                        else
                                            break
                                        end
                                    end
                                end

                                -- ==================================
                                -- 2️⃣ Preparation + Target 적용
                                -- ==================================
                                if rType == "Preparation"
                                and rTarget ~= ""
                                and rTarget ~= "None"
                                and (result == "Success" or result == "Critical Success") then

                                    -- Target 파트 분리 + 그룹 확장 함수
                                    local function splitTarget(str)
                                        local t = {}

                                        -- 그룹 정의
                                        local groups = getTargetTable()
                                        local seen = {}

                                        for part in string.gmatch(str, "[^/]+") do
                                            local p = trim(part)
                                            local g = groups[p]

                                            if g then
                                                for _, v in ipairs(g) do
                                                    if not seen[v] then
                                                        table.insert(t, v)
                                                        seen[v] = true
                                                    end
                                                end
                                            else
                                                if p ~= "" and not seen[p] then
                                                    table.insert(t, p)
                                                    seen[p] = true
                                                end
                                            end
                                        end

                                        return t
                                    end

                                    local rParts = splitTarget(rTarget)

                                    -- 스킬 5: 추가 감소
                                    local rawSkill5 = tostring(getChatVar(triggerId, "ct_Skill_5") or "0")
                                    local s5 = tonumber(extractInt(rawSkill5) or 0) or 0

                                    -- ==================================
                                    -- 모든 카드 검사
                                    -- ==================================
                                    for i, line in ipairs(deckLines) do

                                        local content = line:match("^%[(.*)%]$")
                                        if content then
                                            local parts = splitLiteral(content, "|")

                                            local rawCode = trim(parts[1] or "")
                                            local dCode   = trim(rawCode:match("(%d+)$") or rawCode)
                                            local name    = trim(parts[2] or "")
                                            local dTarget = trim(parts[5] or "")

                                            if dTarget ~= ""
                                            and dTarget ~= "None" then

                                                local dParts = splitTarget(dTarget)

                                                -- 파트 겹침 검사
                                                local overlap = false

                                                for _, a in ipairs(rParts) do
                                                    for _, b in ipairs(dParts) do
                                                        if a == b then
                                                            overlap = true
                                                            break
                                                        end
                                                    end
                                                    if overlap then break end
                                                end

                                                if overlap and not removedCodes[dCode] then

                                                    local threshold =
                                                        tonumber(trim(parts[6] or "")) or 0

                                                    local reduce = (removedLevel * 7) + s5
                                                    if result == "Critical Success" then
                                                        reduce = reduce + (removedLevel * 3) + s5
                                                    end

                                                    threshold =
                                                        math.max(0,
                                                            threshold - reduce)


                                                    parts[6] = tostring(threshold)

                                                    deckLines[i] =
                                                        "[" .. table.concat(parts, " | ") .. "]"

                                                    local codeOnly = dCode
                                                    local rest = {}

                                                    for idx = 2, #parts do
                                                        rest[#rest + 1] = trim(parts[idx] or "")
                                                    end

                                                    modifyMap[dCode] = {
                                                        text = "[Modify: " .. codeOnly .. " | "
                                                            .. table.concat(rest, " | ") .. "]",
                                                        delta = reduce
                                                    }

                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end

                        -- ==================================
                        -- 결과 저장
                        -- ==================================
                        local newDeck = table.concat(deckLines, "\n")

                        setChatVar(triggerId, "ct_Deck_List", newDeck)

                        -- ===============================
                        -- Remove 로그 생성 (타입 아이콘)
                        -- ===============================
                        if #removeOutputs > 0 then

                            local items = {}

                            for _, v in ipairs(removeOutputs) do

                                local content = v:match("^%[(.*)%]$")
                                if content then
                                    local parts = splitLiteral(content, "|")

                                    local code = trim(parts[1]:match("Remove:%s*(%d+)") or "")

                                    local info = removedInfo[code]

                                    if info then
                                        local icon = getDeckIcon(info.type)

                                        table.insert(items,
                                            icon .. " " .. info.name
                                            .. " (Lv." .. info.level .. ")")
                                    end
                                end
                            end

                            table.insert(chikanMessages, "제거: " .. table.concat(items, ", "))
                        end

                        -- ===============================
                        -- Modify 로그 생성 (감소 카드 전체 묶음)
                        -- ===============================
                        do
                            local items = {}

                            for code, data in pairs(modifyMap) do
                                if not removedCodes[code] then

                                    local v = data.text
                                    local content = v:match("^%[(.*)%]$")

                                    if content then
                                        local parts = splitLiteral(content, "|")

                                        local name     = trim(parts[2] or "")
                                        local level    = trim(parts[3] or "1")
                                        local cardType = trim(parts[4] or "")

                                        local icon = getDeckIcon(cardType)

                                        table.insert(items,
                                            icon .. " " .. name .. " (Lv." .. level .. ")")
                                    end
                                end
                            end

                            if #items > 0 then
                                table.insert(chikanMessages,
                                    "🎲🔻: " .. table.concat(items, ", "))
                            end
                        end
                        -- ==================================
                        -- <Chikan Deck> 출력 생성
                        -- ==================================
                        local output = {}

                        for _, v in ipairs(removeOutputs) do
                            table.insert(output, v)
                        end

                        for code, data in pairs(modifyMap) do
                            if not removedCodes[code] then
                                table.insert(output, data.text)
                            end
                        end

                        if #output > 0 then
                            cleanMsg = cleanMsg .. "\n\n<Chikan Deck>\n"
                                .. table.concat(output, "\n")
                                .. "\n</Chikan Deck>"
                        end
                    end
                end
            end

            -- ==========================================
            -- <New Chikan Actions> → <Chikan Deck> 변환 (Add)
            -- ==========================================
            print("치한 Deck Add")
            do
                local deckLines = {}
                local addItems = {}

                -- Deck 코드 관리 변수
                local deckNum = tonumber(getChatVar(triggerId, "ct_Deck_Num") or "0") or 0

                local deckList = safeGet(triggerId, "ct_Deck_List", "")

                -- 숫자 pair 정제 함수 (로컬)
                local function cleanPair(pair, level)

                    local a, b = tostring(pair or "0:0"):match("^(.-):(.-)$")

                    local function fix(n)
                        n = tonumber(extractInt(n)) or 0

                        -- 범위 계산 (레벨 × 6)
                        local range = level * 6
                        n = clamp(n, -range, range)

                        if n == 0 then
                            return "0"
                        elseif n > 0 then
                            return "+" .. n
                        else
                            return tostring(n)
                        end
                    end

                    return fix(a) .. ":" .. fix(b)
                end

                -- ==========================================
                -- 스킬 보정 (획득 시 수치 적용)
                -- ==========================================
                function applyDeckSkillPair(triggerId, pair, level, type, statKey, target)

                    local s1 = tonumber(getChatVar(triggerId, "ct_Skill_1")) or 0
                    local s2 = tonumber(getChatVar(triggerId, "ct_Skill_2")) or 0
                    local s3 = tonumber(getChatVar(triggerId, "ct_Skill_3")) or 0
                    local s5 = tonumber(getChatVar(triggerId, "ct_Skill_5")) or 0
                    local s7 = tonumber(getChatVar(triggerId, "ct_Skill_7")) or 0
                    local s9 = tonumber(getChatVar(triggerId, "ct_Skill_9")) or 0
                    local s16 = tonumber(getChatVar(triggerId, "ct_Skill_16")) or 0

                    local nextArousal = tonumber(getChatVar(triggerId, "ct_Target_NextArousal") or "0") or 0
                    local nextAlert = tonumber(getChatVar(triggerId, "ct_Target_NextAlert") or "0") or 0
                    local nextAttention = tonumber(getChatVar(triggerId, "ct_Target_NextAttention") or "0") or 0

                    local traitRaw = tostring(getChatVar(triggerId, "ct_Target_Trait") or "")

                    -- ===============================
                    -- 타겟 캐릭터 정보 캐싱
                    -- ===============================
                    local targetName    = safeGet(triggerId, "ct_Target_Name", "")
                    local targetCode    = ""
                    local targetBodyRaw = ""
                    local targetParts   = {}
                    local typeLevel     = 0
                    local typeCorruption = 0

                    if targetName ~= "" then
                        targetCode = findCharacterCode(triggerId, targetName)

                        if targetCode then

                            -- ===============================
                            -- Body Part 캐싱
                            -- ===============================
                            targetBodyRaw = safeGet(triggerId, targetCode .. "_Bodypart", "")

                            if targetBodyRaw ~= "" then
                                targetParts = splitPipe(targetBodyRaw)
                            end

                            -- ===============================
                            -- Type Level 캐싱
                            -- ===============================
                            local typeRaw = safeGet(triggerId, targetCode .. "_Type", "")

                            if typeRaw ~= "" then
                                local t1, t2, t3 = typeRaw:match("^(.-)|(.-)|(.-)$")
                                typeLevel = tonumber(t3) or 0
                            end

                            -- ===============================
                            -- Type Corruption 캐싱
                            -- ===============================
                            local corruptionRaw = safeGet(triggerId, targetCode .. "_Corruption", "")

                            if corruptionRaw ~= "" then
                                typeCorruption = tonumber(corruptionRaw) or 0
                            end

                        end
                    end

                    -- Threshold는 단일 값이므로 pair 처리 전에 별도 처리
                    if statKey == "threshold" then
                        local val = tonumber(pair) or 0
                        local thresholdMul = 1.0

                        -- 타입 레벨 기반 Threshold 보너스 (최대 +6)
                        val = val + math.min(6, math.floor(typeLevel / 5))

                        if s5 >= 1 then
                            if type == "Preparation" then
                                val = val - (s5 * 4)
                            else
                                val = val - (s5 * 2)
                            end
                        end

                        if string.find(traitRaw, "Counter-Chikan", 1, true) then
                            local inc = 5 + (level * 2)
                            val = val + inc
                        end

                        if string.find(traitRaw, "Distorted Succubus Belief", 1, true) then
                            local inc = (6 - level) * 2
                            val = val + inc
                        end

                        if string.find(traitRaw, "Chikan Slayer", 1, true) then
                            local inc = 18 - (level * 2)
                            val = val + inc
                        end

                        if (string.find(traitRaw, "Phone Addiction", 1, true)
                        or string.find(traitRaw, "Social Media Addiction", 1, true)) then

                            local dec = math.max(2, 12 - level * 2)

                            val = val - dec

                        end

                        if (string.find(traitRaw, "Chronic Fatigue", 1, true)
                        or string.find(traitRaw, "Excessive Sleepiness", 1, true)
                        or string.find(traitRaw, "Frequent Headaches", 1, true)
                        or string.find(traitRaw, "Burned Out", 1, true)) then

                            val = val - 6

                        end

                        if (string.find(traitRaw, "Poor Situational Awareness", 1, true)
                            or string.find(traitRaw, "Easily Distracted", 1, true)
                            or string.find(traitRaw, "Daydreamer", 1, true)) then

                            val = val - 4

                        end

                        if type == "Molestation" then

                            if string.find(traitRaw, "High Pain Tolerance", 1, true) then
                                if nextAlert > 50 then
                                    val = val + 5
                                end
                            end

                            if string.find(traitRaw, "Good Balance", 1, true) then
                                val = val + 8
                            end

                            if string.find(traitRaw, "Exceptional Stamina", 1, true) then
                                if nextArousal >= 75 then
                                    val = val + 5
                                end
                            end

                            if (string.find(traitRaw, "Rigid Body", 1, true) or string.find(traitRaw, "Clumsy Body", 1, true)) then
                                val = val - 5
                            end

                            if (string.find(traitRaw, "Agile Body", 1, true) or string.find(traitRaw, "Flexible Body", 1, true)) then
                                val = val + 5
                            end

                            if string.find(traitRaw, "Sexual Offender Hunter", 1, true) then
                                local inc = (nextAlert / 100) * 0.3
                                thresholdMul = thresholdMul + inc
                            end

                            if string.find(traitRaw, "Bodyguard Protection", 1, true) or string.find(traitRaw, "Always Prepared", 1, true) then
                                thresholdMul = thresholdMul + 0.2
                            elseif string.find(traitRaw, "Personal Safety Buzzer", 1, true)
                                or string.find(traitRaw, "Self-Defense Tools", 1, true) then

                                thresholdMul = thresholdMul + 0.1
                            end

                            if string.find(traitRaw, "Martial Arts Training", 1, true) then

                                thresholdMul = thresholdMul + 0.1
                            end

                            if string.find(traitRaw, "Superhuman Strength", 1, true) or string.find(traitRaw, "Escape Artist", 1, true) then
                                thresholdMul = thresholdMul + 0.2
                            end

                            if string.find(traitRaw, "Always Accompanied", 1, true) then
                                thresholdMul = thresholdMul + 0.2
                            end

                        end

                        if string.find(traitRaw, "Weapon", 1, true) then
                            val = val + 5
                            if type == "Molestation" then
                                thresholdMul = thresholdMul + 0.2
                            end
                        end

                        if string.find(traitRaw, "Menhera", 1, true) then
                            thresholdMul = thresholdMul - 0.2
                        end

                        if (string.find(traitRaw, "Inferiority Complex", 1, true) or string.find(traitRaw, "Body Insecurity", 1, true)) then
                            thresholdMul = thresholdMul - 0.1
                        end

                        -- ===============================
                        -- Corruption 기반 Threshold 보정
                        -- ===============================
                        if typeCorruption >= 5 then

                            local rate = 0

                            if typeCorruption < 25 then
                                rate = 0.05
                            elseif typeCorruption < 50 then
                                rate = 0.1
                            elseif typeCorruption < 75 then
                                rate = 0
                            elseif typeCorruption < 100 then
                                rate = -0.1
                            else
                                rate = -0.2
                            end

                            thresholdMul = thresholdMul + rate
                        end
                        
                        thresholdMul = clamp(thresholdMul, 0.5, 1.5)
                        val = math.floor(val * thresholdMul)
                        return tostring(clamp(val, 0, 100))
                    end

                    local leftStr, rightStr = tostring(pair or "0:0"):match("^(.-):(.-)$")

                    local function toNum(x)
                        return tonumber(x) or 0
                    end

                    -- +인 값에만 더하기 / -인 값에만 더하기(추후 확장용)
                    local function plusPos(n, inc)
                        if n > 0 then
                            return n + inc
                        end
                        return n
                    end

                    local function plusNeg(n, inc)
                        if n < 0 then
                            return math.min(n + inc, -1)
                        end
                        return n
                    end

                    local function minusPos(n, dec)
                        if n > 0 then
                            return math.max(n - dec, 1)
                        end
                        return n
                    end

                    local function minusNeg(n, dec)
                        if n < 0 then
                            return n - dec
                        end
                        return n
                    end

                    local function fmt(n)
                        n = clamp(n, -100, 100)

                        if n == 0 then
                            return "0"
                        elseif n > 0 then
                            return "+" .. n
                        else
                            return tostring(n)
                        end
                    end

                    local leftVal  = toNum(leftStr)
                    local rightVal = toNum(rightStr)
                    
                    -- =====================================
                    -- 흥분 보정
                    -- =====================================
                    if statKey == "alert" then
                        if nextArousal >= 150 then

                            if leftVal > 0 then
                                local step = math.ceil(leftVal / 2)
                                leftVal = step - 4
                            end

                            if rightVal > 0 then
                                rightVal = math.max(1, math.floor(rightVal * 0.5))
                            end

                        elseif nextArousal >= 105 then

                            local function reducePos50(n)
                                if n > 0 then
                                    local v = math.floor(n * 0.5)
                                    return math.max(v, 1)
                                end
                                return n
                            end

                            leftVal  = reducePos50(leftVal)
                            rightVal = reducePos50(rightVal)

                        end
                    elseif statKey == "attention" then
                        if nextArousal >= 150 then
                            if leftVal > 0 then
                                leftVal = math.floor(leftVal * 1.25)
                            end

                            if rightVal > 0 then
                                rightVal = math.floor(rightVal * 1.25)
                            end
                        end
                    end

                    -- ---------------------------
                    -- 민감도 기반 배율
                    -- ---------------------------
                    if statKey == "arousal" and target and target ~= "" then

                        if targetCode and targetParts then

                            local parts = targetParts

                            -- ===============================
                            -- 타겟 문자열 → 부위 인덱스 찾기
                            -- ===============================
                            local function getIndexFromTarget(t)

                                local map = {

                                    Breast   = {"Breast", "Nipple", "Chest"},
                                    Oral     = {"Lips", "Tongue", "Oral", "Throat", "Mouth"},
                                    Clitoris = {"Clitoris"},
                                    Vaginal  = {"Vulva", "Vaginal", "Cervix", "Crotch", "Uterus", "Womb"},
                                    Anal     = {"Buttock", "Anal"}
                                }

                                for idx, key in ipairs({"Breast","Oral","Clitoris","Vaginal","Anal"}) do
                                    local group = map[key]
                                    for _, word in ipairs(group) do
                                        if string.find(t, word, 1, true) then
                                            return idx
                                        end
                                    end
                                end

                                return nil
                            end

                            local idx = getIndexFromTarget(target)

                            local base = 0

                            -- ===============================
                            -- 특정 부위 존재
                            -- ===============================
                            if idx and parts[idx] then
                                base = tonumber(parts[idx]) or 0

                            -- ===============================
                            -- 매칭 실패 → 5개 평균
                            -- ===============================
                            else
                                local sum = 0
                                local cnt = 0

                                for i = 1, 5 do
                                    local v = tonumber(parts[i]) or 0
                                    sum = sum + v
                                    cnt = cnt + 1
                                end

                                if cnt > 0 then
                                    base = sum / cnt
                                end
                            end

                            -- 최종 민감도 (Arousal 보정 포함)
                            local sens = getFinalSensitivityValue(triggerId, base)

                            -- ===============================
                            -- 민감도 → 배율
                            -- ===============================
                            local rate = 0.0

                            if sens < 10 then rate = -0.5
                            elseif sens < 25 then rate = -0.4
                            elseif sens < 40 then rate = -0.3
                            elseif sens < 55 then rate = -0.2
                            elseif sens < 70 then rate = -0.1
                            elseif sens < 85 then rate = 0.0
                            elseif sens < 100 then rate = 0.1
                            elseif sens < 120 then rate = 0.2
                            elseif sens < 150 then rate = 0.3
                            elseif sens < 200 then rate = 0.4
                            else rate = 0.5
                            end

                            -- ===============================
                            -- 최종 적용
                            -- ===============================
                            local function applyMult(A)

                                if A ~= 0 then

                                    local raw = A + math.abs(A) * rate

                                    local v
                                    if raw > 0 then
                                        v = math.ceil(raw)
                                    else
                                        v = math.floor(raw)
                                    end

                                    if v == 0 then
                                        return (A > 0) and 1 or -1
                                    end

                                    return v
                                end

                                return A
                            end

                            leftVal  = applyMult(leftVal)
                            rightVal = applyMult(rightVal)
                        end
                    end

                    -- ===============================
                    -- Type Level 난이도 증가
                    -- ===============================
                    if typeLevel >= 5 and statKey == "attention" then
                        leftVal  = plusNeg(leftVal, 1)
                        rightVal = plusNeg(rightVal, 1)
                    end

                    if typeLevel >= 10 and statKey == "alert" then
                        leftVal  = plusNeg(leftVal, 1)
                        rightVal = plusNeg(rightVal, 1)
                    end

                    if typeLevel >= 15 and statKey == "arousal" then
                        leftVal  = plusNeg(leftVal, 1)
                        rightVal = plusNeg(rightVal, 1)
                    end

                    if typeLevel >= 20 and statKey == "attention" then
                        leftVal  = minusPos(leftVal, 1)
                        rightVal = minusPos(rightVal, 1)
                    end

                    if typeLevel >= 25 and statKey == "alert" then
                        leftVal  = minusPos(leftVal, 1)
                        rightVal = minusPos(rightVal, 1)
                    end

                    if typeLevel >= 30 and statKey == "arousal" then
                        leftVal  = minusPos(leftVal, 1)
                        rightVal = minusPos(rightVal, 1)
                    end
                    -- ---------------------------
                    -- Trait 효과 (수치 증감)
                    -- ---------------------------
                    if statKey == "alert"
                    and (string.find(traitRaw, "Defiant Inner Will", 1, true)
                    or string.find(traitRaw, "Unyielding Against Injustice", 1, true)
                    or string.find(traitRaw, "Iron Will", 1, true)
                    or string.find(traitRaw, "Unbreakable Spirit", 1, true)) then

                        if nextArousal >= 75 then

                            local inc = 1
                            if level >= 4 then
                                inc = 3
                            elseif level >= 2 then
                                inc = 2
                            end

                            leftVal  = plusPos(leftVal, inc)
                            rightVal = plusPos(rightVal, inc)

                        end
                    end

                    if string.find(traitRaw, "Calm Under Fire", 1, true)
                    or string.find(traitRaw, "Fearless", 1, true) then

                        -- 기본 효과
                        if statKey == "alert" or statKey == "attention" then
                            leftVal  = plusPos(leftVal, 1)
                            rightVal = plusPos(rightVal, 1)
                        end

                        -- 추가 효과 (흥분 억제)
                        if statKey == "arousal" then

                            if nextArousal >= 75 then
                                leftVal  = minusPos(leftVal, 2)
                                rightVal = minusPos(rightVal, 2)
                            end

                        end
                    end

                    if (string.find(traitRaw, "Mental Resilience", 1, true)
                    or string.find(traitRaw, "Quick Recovery Mind", 1, true)
                    or string.find(traitRaw, "Adaptive", 1, true)) then

                        if nextArousal >= 75 then

                            local dec = 1
                            local inc = 1

                            if level >= 5 then
                                dec = 2
                                inc = 2
                            end

                            -- Arousal 감소
                            if statKey == "arousal" then
                                leftVal  = minusPos(leftVal, dec)
                                rightVal = minusPos(rightVal, dec)
                            end

                            -- Alert 증가
                            if statKey == "alert" then
                                leftVal  = plusPos(leftVal, inc)
                                rightVal = plusPos(rightVal, inc)
                            end

                        end
                    end

                    if string.find(traitRaw, "Strong Sense of Justice", 1, true) and statKey == "alert" and type == "Molestation" then
                        leftVal  = plusPos(leftVal, 2)
                        rightVal = plusPos(rightVal, 2)
                    end

                    if (string.find(traitRaw, "Seductive Figure", 1, true)
                    or string.find(traitRaw, "Beautiful Face", 1, true)
                    or string.find(traitRaw, "Revealing Fashion", 1, true)
                    or string.find(traitRaw, "Cute Appearance", 1, true))
                    and statKey == "attention" then

                        leftVal  = plusPos(leftVal, 1)
                        rightVal = plusPos(rightVal, 1)

                    end

                    if (string.find(traitRaw, "Bizarre Reactions", 1, true)
                        or string.find(traitRaw, "Overreacts", 1, true))
                    and statKey == "attention" then

                        leftVal  = plusPos(leftVal, 1)
                        rightVal = plusPos(rightVal, 1)

                    elseif string.find(traitRaw, "Loud Voice", 1, true)
                    and statKey == "attention" then

                        leftVal  = plusPos(leftVal, 2)
                        rightVal = plusPos(rightVal, 2)

                    end

                    if string.find(traitRaw, "Pheromone-Rich", 1, true) and statKey == "attention" then
                        leftVal  = plusPos(leftVal, 1)
                        rightVal = plusPos(rightVal, 1)
                    end

                    if string.find(traitRaw, "Filthy", 1, true) and statKey == "attention" then
                        leftVal  = plusPos(leftVal, 1)
                        rightVal = plusPos(rightVal, 1)

                        leftVal  = minusNeg(leftVal, 1)
                        rightVal = minusNeg(rightVal, 1)
                    end

                    if string.find(traitRaw, "Goddess-Like Beauty", 1, true) and statKey == "attention" then
                        local inc = 1
                        if nextAttention > 70 then
                            inc = 3
                        elseif nextAttention > 35 then
                            inc = 2
                        end

                        leftVal  = plusPos(leftVal, inc)
                        rightVal = plusPos(rightVal, inc)

                    end

                    if string.find(traitRaw, "Famous", 1, true) and statKey == "attention" then
                        local inc = 1
                        if nextAttention > 35 then
                            inc = 2
                        end

                        leftVal  = plusPos(leftVal, inc)
                        rightVal = plusPos(rightVal, inc)

                        leftVal  = plusNeg(leftVal, 1)
                        rightVal = plusNeg(rightVal, 1)

                    end

                    if (string.find(traitRaw, "Influencer", 1, true)
                    or string.find(traitRaw, "Idol", 1, true))
                    and statKey == "attention" then
                        local inc = 1
                        if nextAttention > 70 then
                            inc = 3
                        elseif nextAttention > 35 then
                            inc = 2
                        end

                        leftVal  = plusPos(leftVal, inc)
                        rightVal = plusPos(rightVal, inc)

                    end

                    if (string.find(traitRaw, "Fast Reflexes", 1, true) or string.find(traitRaw, "Sharp Vision", 1, true)) and statKey == "alert" then
                        local inc = (nextAlert <= 20) and 2 or 1

                        leftVal  = plusPos(leftVal, inc)
                        rightVal = plusPos(rightVal, inc)

                    end

                    if string.find(traitRaw, "Self-Controlled", 1, true) and statKey == "arousal" then

                        local dec = (nextArousal > 75) and 2 or 1

                        leftVal  = minusPos(leftVal, dec)
                        rightVal = minusPos(rightVal, dec)

                    end

                    if string.find(traitRaw, "Paranoid", 1, true) and statKey == "alert" then
                        local inc = (nextAlert <= 20) and 4 or 1

                        leftVal  = plusPos(leftVal, inc)
                        rightVal = plusPos(rightVal, inc)

                    end

                    if string.find(traitRaw, "Always Accompanied", 1, true) and statKey == "attention" then

                        leftVal  = plusPos(leftVal, 1)
                        rightVal = plusPos(rightVal, 1)

                    end

