                "알리나","소피야","마리아","엘레나",
                "나탈리아","카테리나","밀라","알리사","사샤", "릴리아"
            }
        elseif lang == 2 then
            return {
                "Anastasia","Alina","Sofia","Maria","Elena",
                "Natalia","Katerina","Mila","Alisa","Sasha"
            }
        else -- lang == 3 (일본어)
            return {
                "アナスタシア","アリーナ","ソフィア","マリア","エレナ",
                "ナターリヤ","カテリーナ","ミラ","アリサ","サーシャ"
            }
        end
    end

end

-- 헤어
function getHairColor(...)
    local groups = {}

    for _, idx in ipairs({...}) do

        -- 0 : 기본 자연 + 어두운 서브컬쳐 색
        if idx == 0 then table.insert(groups, { "Black", "Dark Brown", "Dark Blue", "Dark Purple" }) end

        -- 1 : 금발 계열
        if idx == 1 then table.insert(groups, { "Blonde", "Yellow", "Light Yellow", "Light Blonde", "Dark Yellow" }) end

        -- 2 : 핑크 계열
        if idx == 2 then table.insert(groups, { "Pink", "Light Pink" }) end

        -- 3 : 레드 계열
        if idx == 3 then table.insert(groups, { "Red", "Crimson", "Dark Red" }) end

        -- 4 : 그린 ~ 청록 계열
        if idx == 4 then table.insert(groups, { "Green", "Light Green", "Mint Green", "Dark Green" }) end

        -- 5 : 화이트 / 실버 계열
        if idx == 5 then table.insert(groups, { "White", "Silver", "Platinum Silver", "Light Gray" }) end

        -- 6 : 퍼플 계열
        if idx == 6 then table.insert(groups, { "Purple", "Light Purple", "Lavender", "Violet" }) end

        -- 7 : 오렌지 계열
        if idx == 7 then table.insert(groups, { "Orange", "Light Orange", "Dark Orange" }) end

        -- 8 : 갈색 계열
        if idx == 8 then table.insert(groups, { "Brown", "Light Brown", "Ash Brown" }) end

        -- 9 : 회색 계열
        if idx == 9 then table.insert(groups, { "Gray", "Light Gray", "Ash Gray" }) end

        -- 10 : 블루 계열
        if idx == 10 then table.insert(groups, { "Light Blue" }) end

    end

    local g = groups[math.random(#groups)]
    return g[math.random(#g)]
end

