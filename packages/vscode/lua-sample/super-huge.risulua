function getTargetTable()

    local BreastGroup = {"Breast", "Nipple", "Chest"}
    local HeadGroup = { "Neck", "Head", "Ear", "Hair", "Face", "Lips", "Tongue", "Oral", "Throat", "Mouth", "Cheek", "Breath"}

    local VulvaCoreGroup  = {"Vulva", "Vaginal", "Cervix", "Crotch", "Uterus", "Womb", "Clitoris"}
    local VulvaInnerGroup = {"Vulva", "Vaginal", "Cervix", "Crotch", "Uterus", "Womb"}

    local ButtGroup = {"Buttock", "Anal", "Pelvis", "Hip"}

    local ArmGroup = {"Arm", "Shoulder", "Wrist", "Hand", "Armpit", "Elbow", "Finger", "Palm", "Collarbone"}
    local LegGroup = {"Leg", "Thigh", "Knee", "Calf", "Foot", "Ankle", "Toe"}
    local WaistGroup = {"Waist", "Back", "Belly", "Rib", "Stomach", "Belly"}

    return {
        ["Breast"] = BreastGroup,
        ["Nipple"] = BreastGroup,
        ["Chest"]  = BreastGroup,

        ["Neck"]   = HeadGroup,
        ["Head"]   = HeadGroup,
        ["Ear"]    = HeadGroup,
        ["Hair"]   = HeadGroup,
        ["Face"]   = HeadGroup,
        ["Lips"]   = HeadGroup,
        ["Tongue"] = HeadGroup,
        ["Oral"]   = HeadGroup,
        ["Throat"] = HeadGroup,
        ["Mouth"]  = HeadGroup,
        ["Cheek"]  = HeadGroup,
        ["Breath"] = HeadGroup,

        ["Clitoris"] = {"Clitoris", "Vulva", "Crotch"},
        ["Vulva"]    = VulvaCoreGroup,
        ["Crotch"]   = VulvaCoreGroup,

        ["Vaginal"]  = VulvaInnerGroup,
        ["Cervix"]   = VulvaInnerGroup,
        ["Uterus"]   = VulvaInnerGroup,
        ["Womb"]     = VulvaInnerGroup,

        ["Buttock"] = ButtGroup,
        ["Anal"]    = ButtGroup,
        ["Pelvis"] = ButtGroup,
        ["Hip"]   = ButtGroup,

        ["Arm"]      = ArmGroup,
        ["Shoulder"] = ArmGroup,
        ["Wrist"]    = ArmGroup,
        ["Hand"]     = ArmGroup,
        ["Armpit"] = ArmGroup,
        ["Elbow"]  = ArmGroup,
        ["Finger"] = ArmGroup,
        ["Palm"]   = ArmGroup,
        ["Collarbone"] = ArmGroup,

        ["Leg"]   = LegGroup,
        ["Thigh"] = LegGroup,
        ["Knee"]  = LegGroup,
        ["Calf"]  = LegGroup,
        ["Foot"]  = LegGroup,
        ["Ankle"] = LegGroup,
        ["Toe"]   = LegGroup,

        ["Waist"] = WaistGroup,
        ["Back"]  = WaistGroup,
        ["Belly"]   = WaistGroup,
        ["Rib"]     = WaistGroup,
        ["Stomach"] = WaistGroup,
        ["Belly"] = WaistGroup
    }
end


