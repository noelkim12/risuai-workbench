                local multiplier = 1.0

                if ageType == "JS" then
                    multiplier = 0.8
                elseif ageType == "JC" then
                    multiplier = 0.9
                else
                    multiplier = 1.0
                end

                return math.floor(value * multiplier + 0.5)
            end

