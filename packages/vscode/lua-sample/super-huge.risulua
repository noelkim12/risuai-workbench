end

-- 시작 버튼
function generateStartInput(triggerId)

    local allowLoli    = safeGet(triggerId, "ct_Char_Loli", "0") == "1"
    local allowJC = safeGet(triggerId, "ct_Char_JC", "0") == "1"
    local allowJK = safeGet(triggerId, "ct_Char_JK", "0") == "1"
    local allowAdult   = safeGet(triggerId, "ct_Char_Adult", "0") == "1"
    local allowAdult2  = safeGet(triggerId, "ct_Char_Adult2", "0") == "1"

    -- 전부 0이면 종료
    if not (allowLoli or allowJC or allowJK or allowAdult or allowAdult2) then
        return
    end

    local initFlag = getChatVar(triggerId, "ct_Init")
    local lang = tonumber(getChatVar(triggerId, "ct_Language") or "1")

    if initFlag ~= "1" then
        setChatVar(triggerId, "ct_Init", "1")
        setChatVar(triggerId, "ct_Mode", "1")

        local startExpert = tonumber(getChatVar(triggerId, "ct_StartExpert") or "0")
        local chikanLevel = 1
        if startExpert == 1 then
            setChatVar(triggerId, "ct_ChikanLevel", "30")
            setChatVar(triggerId, "ct_ChikanPoint", "30")
            chikanLevel = 30
        else
            setChatVar(triggerId, "ct_ChikanLevel", "1")
            setChatVar(triggerId, "ct_ChikanPoint", "0")
        end

        setChatVar(triggerId, "ct_ChikanExp", "0")
        setChatVar(triggerId, "ct_Skill_1", "0")
        setChatVar(triggerId, "ct_Skill_2", "0")
        setChatVar(triggerId, "ct_Skill_3", "0")
        setChatVar(triggerId, "ct_Skill_4", "0")
        setChatVar(triggerId, "ct_Skill_5", "0")
        setChatVar(triggerId, "ct_Skill_6", "0")
        setChatVar(triggerId, "ct_Skill_7", "0")
        setChatVar(triggerId, "ct_Skill_8", "0")
        setChatVar(triggerId, "ct_Skill_9", "0")
        setChatVar(triggerId, "ct_Skill_10", "0")
        setChatVar(triggerId, "ct_Skill_11", "0")
        setChatVar(triggerId, "ct_Skill_12", "0")
        setChatVar(triggerId, "ct_Skill_13", "0")
        setChatVar(triggerId, "ct_Skill_14", "0")
        setChatVar(triggerId, "ct_Skill_15", "0")
        setChatVar(triggerId, "ct_Skill_16", "0")
        setChatVar(triggerId, "ct_Skill_17", "0")
        setChatVar(triggerId, "ct_Skill_18", "0")

        setChatVar(triggerId, "ct_AutoSuccess", "0")

        setChatVar(triggerId, "ct_NextDate", "")
        setChatVar(triggerId, "ct_NextDaypart", "")

        setChatVar(triggerId, "ct_CharList", "")
        setChatVar(triggerId, "ct_Char_Overview", "")
        setChatVar(triggerId, "ct_Char_Objective", "")

        local useMemory = tostring(getChatVar(triggerId, "ct_UseMemory") or "0")
        if useMemory == "1" then
            setChatVar(triggerId, "ct_MemoryNum", "0")
            setChatVar(triggerId, "ct_MemoryCurrent", "")
        end

        resetTargetState(triggerId)
        -- ==========================================
        -- Character List 초기 생성 (공용 모듈 사용)
        -- ==========================================
        local createCount = 6
        if startExpert == 1 then
            createCount = 30
        end

        for i = 1, createCount do
            createRandomCharacter(triggerId, chikanLevel, false)
        end

        buildAllCharacterOverview(triggerId)
        generateHTML(triggerId)
    end

    -- ==========================================
    -- Language 텍스트 결정
    -- ==========================================
    local langText = "한국어"
    if lang == 2 then
        langText = "English"
    elseif lang == 3 then
        langText = "日本語"
    end

    local date = getChatVar(triggerId, "ct_StartDate") or os.date("%Y-%m-%d")
    local exp  = tonumber(getChatVar(triggerId, "ct_StartExp") or "1")

    -- ==========================================
    -- Start Experience 텍스트 결정
    -- ==========================================
    local expText = ""

    if exp == 1 then
        expText = "{{user}} has no experience with Chikan and has no intention of engaging in Chikan."
    elseif exp == 2 then
        expText = "{{user}} has no experience with Chikan but is considering engaging in Chikan."
    elseif exp == 3 then
        expText = "{{user}} has engaged in Chikan a few times and intends to continue engaging in Chikan."
    elseif exp == 4 then
        expText = "{{user}} has engaged in Chikan many times and intends to continue engaging in Chikan."
    end

    -- ==========================================
    -- 생성될 라인
    -- ==========================================
    local langLine = "▷ [Language: " .. langText .. "]"
    local dateLine = "▷ [Current Date: " .. date .. "]"
    local expLine  = "▷ [" .. expText .. "]"

    local startText = "시작"
    if lang == 2 then
        startText = "Start"
    elseif lang == 3 then
        startText = "スタート"
    end

    local guideLine = "▷ [Prologue: In this response, depict the scene in which {{user}} is cursed by an unidentified witch. The location may be inside a Train or elsewhere. As a result of the curse, {{user}} becomes a Train-bound existence that can only exist inside a Train. However, absolutely no information about the witch must be revealed. Nothing about appearance, body type, voice, or any identifying trait may be described or implied. The entity's identity is predetermined but not yet disclosed, and any attempt to portray her form or characteristics could cause a setting contradiction. The only thing that can be known is that the witch is female."

    if exp == 1 then
        guideLine = guideLine .. " {{user}} has no prior experience with Chikan and no intention of engaging in it, therefore any reference or narrative involving Chikan must be excluded.]"
    else
        guideLine = guideLine .. "]"
    end

    local choiceGuide = "▷ [You must output exactly 5 Choices at the end. The User will select one of them in the next input, so {{user}}'s Chikan plan must remain neither decided nor implied in this response, as {{user}} may ultimately decide not to engage in Chikan at all today.]"

    local cl = getChatLength(triggerId)
    local handled = false

    if cl > 0 then
        local last = getChat(triggerId, cl - 1)

        if last and last.role == "user" and type(last.data) == "string" then
            local text = last.data

            -- 기존 Start 텍스트 제거
            text = text:gsub("\n?시작", "")
            text = text:gsub("\n?Start", "")
            text = text:gsub("\n?スタート", "")

            -- 기존 ▷ [ ... ] 블록 전부 제거
            text = text:gsub("\n?▷ %[[^%]]*%]", "")

            -- 새로 추가
            text = text .. "\n" .. startText
            text = text .. "\n" .. langLine
            text = text .. "\n" .. dateLine
            text = text .. "\n" .. expLine
            text = text .. "\n" .. guideLine
            text = text .. "\n" .. choiceGuide

            setChat(triggerId, cl - 1, text)
            handled = true
        end
    end

    if not handled then
        local text = startText
            .. "\n" .. langLine
            .. "\n" .. dateLine
            .. "\n" .. expLine
            .. "\n" .. guideLine
            .. "\n" .. choiceGuide

        addChat(triggerId, "user", text)
    end
end

-- ==========================================
-- 스킬트리
-- ==========================================
local function adjustSkill(triggerId, skillKey, delta, maxLevel, minChikanLevel)

    local point = tonumber(getChatVar(triggerId, "ct_ChikanPoint")) or 0
    local skill = tonumber(getChatVar(triggerId, skillKey)) or 0
    local chLv  = tonumber(getChatVar(triggerId, "ct_ChikanLevel")) or 1

    maxLevel = tonumber(maxLevel) or 5
    minChikanLevel = tonumber(minChikanLevel) or 1

    -- 최소 레벨 체크 (업그레이드 때만)
    if delta > 0 and chLv < minChikanLevel then
        alertError(triggerId, "❌ 레벨이 부족합니다.")
        return
    end

    if delta > 0 then
        -- 최대치면 조용히 종료
        if skill >= maxLevel then
            return
        end

        -- 포인트 부족
        if point <= 0 then
            alertError(triggerId, "❌ 포인트가 부족합니다.")
            return
        end

        skill = skill + 1
        point = point - 1

    else
        -- 다운: 0이면 조용히 종료
        if skill <= 0 then
            return
        end

        skill = skill - 1
        point = point + 1
    end

    setChatVar(triggerId, skillKey, tostring(skill))
    setChatVar(triggerId, "ct_ChikanPoint", tostring(point))

end

