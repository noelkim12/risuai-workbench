        local function buildKeywords(coreList, poolList, count)
            local result = {}

            -- 코어 먼저 추가
            for _, v in ipairs(coreList) do
                table.insert(result, v)
            end

            -- 풀 복사 (원본 보호)
            local pool = {}
            for _, v in ipairs(poolList) do
                table.insert(pool, v)
            end

            -- 랜덤 count개 선택 (중복 방지)
            for i = 1, math.min(count, #pool) do
                local idx = math.random(#pool)
                table.insert(result, pool[idx])
                table.remove(pool, idx)
            end

            return table.concat(result, ", ")
        end

