                                        [3] = "トイレに連れて行く"
                                    }

                                    local name = names[lang] or names[1]

                                    local line = "[" .. name .. " | 6 | Toilet | Oral/Breast/Crotch/Anal | 100 | +35:-35 | +28:+35 | +20:+30]"

                                    table.insert(injectLines, line)

                                    setTrackedChatVar(triggerId, "ct_Skill_14", tostring(s14) .. "X")
                                end

                                -- --------------------------
                                -- 스킬 15 : 주변을 끌어들여 놀기
                                -- --------------------------
                                if s15 >= 1 and not raw15:find("X", 1, true) then

                                    local names = {
                                        [1] = "주변인들을 끌어들여 윤간",
                                        [2] = "Draw Others In and gangbang",
                                        [3] = "周囲を巻き込んで輪姦"
                                    }

                                    local name = names[lang] or names[1]

                                    local line = "[" .. name .. " | 6 | Gangbang | Oral/Breast/Crotch/Anal | 100 | +35:-35 | +28:+35 | +20:+30]"

                                    table.insert(injectLines, line)

                                    setTrackedChatVar(triggerId, "ct_Skill_15", tostring(s15) .. "X")
                                end
                            end
                        end
                    end

                    -- ------------------------------------------------
                    -- 실제 주입 (injectLines 있을 때만)
                    -- ------------------------------------------------
                    if #injectLines > 0 then

                        local injectText = table.concat(injectLines, "\n")

                        if cleanMsg:find("<New Chikan Actions>", 1, true) then
                            cleanMsg = cleanMsg:gsub(
                                "<New Chikan Actions>",
                                "<New Chikan Actions>\n" .. injectText,
                                1
                            )
                        else
                            cleanMsg = cleanMsg
                                .. "\n\n<New Chikan Actions>\n"
                                .. injectText
                                .. "\n</New Chikan Actions>\n"
                        end
                    end
                end

                local function removeOrdinalFromName(name)

                    local lang = tonumber(getChatVar(triggerId, "ct_Language") or "1")

                    if lang == 1 then
                        if name:find("번째") then
                            name = name:gsub("%s*첫%s*번째", "")
                            name = name:gsub("%s*두%s*번째", "")
                            name = name:gsub("%s*세%s*번째", "")
                            name = name:gsub("%s*네%s*번째", "")
                            name = name:gsub("%s*다섯%s*번째", "")
                        end

                        if name:find("차") then
                            name = name:gsub("%s*1%s*차", "")
                            name = name:gsub("%s*2%s*차", "")
                            name = name:gsub("%s*3%s*차", "")
                            name = name:gsub("%s*4%s*차", "")
                            name = name:gsub("%s*5%s*차", "")
                        end

                    elseif lang == 2 then
                        if name:lower():find("time") then
                            name = name:gsub("%s*1st%s*time?", "")
                            name = name:gsub("%s*2nd%s*time?", "")
                            name = name:gsub("%s*3rd%s*time?", "")
                            name = name:gsub("%s*4th%s*time?", "")
                            name = name:gsub("%s*5th%s*time?", "")

                            name = name:gsub("%s*first%s*time?", "")
                            name = name:gsub("%s*second%s*time?", "")
                            name = name:gsub("%s*third%s*time?", "")
                            name = name:gsub("%s*fourth%s*time?", "")
                            name = name:gsub("%s*fifth%s*time?", "")
                        end

                    elseif lang == 3 then
                        if name:find("回目") then
                            name = name:gsub("%s*一回目", "")
                            name = name:gsub("%s*二回目", "")
                            name = name:gsub("%s*三回目", "")
                            name = name:gsub("%s*四回目", "")
                            name = name:gsub("%s*五回目", "")
                        end

                        if name:find("度目") then
                            name = name:gsub("%s*一度目", "")
                            name = name:gsub("%s*二度目", "")
                            name = name:gsub("%s*三度目", "")
                            name = name:gsub("%s*四度目", "")
                            name = name:gsub("%s*五度目", "")
                        end
                    end

                    -- 공백 정리
                    name = name:gsub("%s+", " ")
                    name = name:match("^%s*(.-)%s*$")

                    return name
                end

                for block in cleanMsg:gmatch(
                    "<New Chikan Actions>([%s%S]-)</New Chikan Actions>"
                ) do
                    for line in block:gmatch("%b[]") do

                        local content = line:match("^%[(.*)%]$")
                        if content then
                            local parts = splitLiteral(content, "|")

                            if #parts >= 8 then

                                local name  = trim(parts[1])
                                local level = tonumber(extractInt(parts[2])) or 1
                                local type  = trim(parts[3])
                                local target= trim(parts[4])

                                -- 이름에서 번째 제거
                                name = removeOrdinalFromName(name)

                                -- Threshold 숫자만
                                local threshold =
                                    tostring(extractInt(parts[5]))

                                local arousal  = cleanPair(parts[6], level)
                                local alert    = cleanPair(parts[7], level)
                                local attention= cleanPair(parts[8], level)

                                local arousal_before   = arousal
                                local alert_before     = alert
                                local attention_before = attention
                                local threshold_before = threshold

                                arousal = applyDeckSkillPair(triggerId, arousal, level, type, "arousal",   target)
                                alert = applyDeckSkillPair(triggerId, alert, level, type, "alert", target)
                                attention = applyDeckSkillPair(triggerId, attention, level, type, "attention", target)
                                threshold = applyDeckSkillPair(triggerId, threshold, level, type, "threshold", target)

                                -- ===============================
                                -- 디버그 로그 출력
                                -- ===============================
                                local msg = "[DECK DEBUG] " .. name

                                local changed = false

                                if threshold_before ~= threshold then
                                    msg = msg .. " | Thr: " .. threshold_before .. " → " .. threshold
                                    changed = true
                                end

                                if arousal_before ~= arousal then
                                    msg = msg .. " | Arousal: " .. arousal_before .. " → " .. arousal
                                    changed = true
                                end

                                if alert_before ~= alert then
                                    msg = msg .. " | Alert: " .. alert_before .. " → " .. alert
                                    changed = true
                                end

                                if attention_before ~= attention then
                                    msg = msg .. " | Attention: " .. attention_before .. " → " .. attention
                                    changed = true
                                end

                                if changed then
                                    print(msg)
                                end

                                deckNum = deckNum + 1
                                local code = tostring(deckNum)

                                local arousal_o   = arousal:gsub(":", " / ")
                                local alert_o     = alert:gsub(":", " / ")
                                local attention_o = attention:gsub(":", " / ")

                                local newLine =
                                    "[Add: " .. code .. " | "
                                    .. name .. " | "
                                    .. level .. " | "
                                    .. type .. " | "
                                    .. target .. " | "
                                    .. threshold .. " | "
                                    .. arousal_o .. " | "
                                    .. alert_o .. " | "
                                    .. attention_o .. "]"

                                table.insert(deckLines, newLine)

                                -- ===============================
                                -- Add 로그 생성 (타입 아이콘)
                                -- ===============================
                                local icon = getDeckIcon(type)

                                table.insert(addItems,
                                    icon .. " " .. name .. " (Lv." .. level .. ")")

                                -- 저장용 pair 형식 변환 (: → " / ")
                                local arousal_s  = arousal:gsub(":", " / ")
                                local alert_s    = alert:gsub(":", " / ")
                                local attention_s= attention:gsub(":", " / ")

                                -- 변수용 저장 형식
                                local storeLine =
                                    "[Deck: " .. code .. " | "
                                    .. name .. " | "
                                    .. level .. " | "
                                    .. type .. " | "
                                    .. target .. " | "
                                    .. threshold .. " | "
                                    .. arousal_s .. " | "
                                    .. alert_s .. " | "
                                    .. attention_s .. "]"

                                if deckList == "" then
                                    deckList = storeLine
                                else
                                    deckList = deckList .. "\n" .. storeLine
                                end
                            end
                        end
                    end
                end

                cleanMsg = cleanMsg:gsub(
                    "<New Chikan Actions>[%s%S]-</New Chikan Actions>",
                    ""
                )

                if #deckLines > 0 then
                    -- Deck 변수 저장
                    setChatVar(triggerId, "ct_Deck_Num", tostring(deckNum))
                    setChatVar(triggerId, "ct_Deck_List", deckList)

                    local addText = table.concat(deckLines, "\n")

                    -- ==================================
                    -- 기존 <Chikan Deck> 존재 여부 확인
                    -- ==================================
                    if cleanMsg:find("<Chikan Deck>", 1, true) then

                        -- </Chikan Deck> 바로 위에 삽입
                        cleanMsg = cleanMsg:gsub(
                            "</Chikan Deck>",
                            addText .. "\n</Chikan Deck>",
                            1
                        )

                    else
                        -- 새로 생성
                        local newBlock =
                            "<Chikan Deck>\n"
                            .. addText
                            .. "\n</Chikan Deck>"

                        cleanMsg = cleanMsg .. "\n\n" .. newBlock
                    end
                end

                if #addItems > 0 then
                    table.insert(chikanMessages,
                        "추가: " .. table.concat(addItems, ", "))
                end
            end

            -- ===============================
            -- Next → Current 덮어쓰기
            -- ===============================
            print("치한 Next Value")

            local nextArousal = tonumber(getChatVar(triggerId, "ct_Target_NextArousal") or "0") or 0
            local nextAlert = tonumber(getChatVar(triggerId, "ct_Target_NextAlert") or "0") or 0
            local nextAttention = tonumber(getChatVar(triggerId, "ct_Target_NextAttention") or "0") or 0

            local curArousal =
                tonumber(getChatVar(triggerId, "ct_Target_Arousal") or "0") or 0
            local curAlert =
                tonumber(getChatVar(triggerId, "ct_Target_Alert") or "0") or 0
            local curAttention =
                tonumber(getChatVar(triggerId, "ct_Target_Attention") or "0") or 0

            local function statLine(label, cur, nxt)

                local diff = nxt - cur
                --if diff == 0 then return nil end

                local sign = diff > 0 and "+" or ""

                local maxValue = 100
                if label == "흥분" then
                    maxValue = 150
                end

                return label .. " " .. nxt .. " / " .. maxValue .. " (" .. sign .. diff .. ")"
            end

            local s1 = statLine("흥분", curArousal, nextArousal)
            local s2 = statLine("경계", curAlert, nextAlert)
            local s3 = statLine("발각", curAttention, nextAttention)

            if s1 then table.insert(chikanMessages, s1) end
            if s2 then table.insert(chikanMessages, s2) end
            if s3 then table.insert(chikanMessages, s3) end

            setChatVar(triggerId, "ct_Target_Arousal", tostring(nextArousal))
            setChatVar(triggerId, "ct_Target_Alert", tostring(nextAlert))
            setChatVar(triggerId, "ct_Target_Attention", tostring(nextAttention))

            -- Clear 체크 (Arousal 100 도달 시)
            local clearFlag = tonumber(getChatVar(triggerId, "ct_Target_Clear") or "0") or 0
            if nextArousal >= 150 and clearFlag == 0 then
                setTrackedChatVar(triggerId, "ct_Target_Clear", "1")
            end

            -- ===============================
            -- RemainStops -1
            -- ===============================
            print("지난 정거장 수 체크")

            local remainStops = tonumber(getChatVar(triggerId, "ct_Target_RemainStops") or "0") or 0

            if remainStops >= 1 then
                remainStops = remainStops - 1
                setChatVar(triggerId, "ct_Target_RemainStops", tostring(remainStops))
            else
                local exTurn = tonumber(getChatVar(triggerId, "ct_Target_ExTurn") or "-1") or -1
                exTurn = exTurn + 1
                setChatVar(triggerId, "ct_Target_ExTurn", tostring(exTurn))
            end

            -- ==========================================
            -- Heroine 상태 확장 라인 생성
            -- ==========================================
            print("상태창 확장")

            do
                local line      = safeGet(triggerId, "ct_Target_Line", "")
                local station   = safeGet(triggerId, "ct_Target_Station", "")
                local purpose   = safeGet(triggerId, "ct_Target_Purpose", "")
                local arousal       = safeGet(triggerId, "ct_Target_Arousal", "0")
                local alert     = safeGet(triggerId, "ct_Target_Alert", "0")
                local attention = safeGet(triggerId, "ct_Target_Attention", "0")

                local totalStops = tonumber(safeGet(triggerId, "ct_Target_Stops", "0")) or 0
                local remain = tonumber(safeGet(triggerId, "ct_Target_RemainStops", "0")) or 0
                local exTurn = tonumber(safeGet(triggerId, "ct_Target_ExTurn", "-1")) or -1

                local stopsText = ""

                if exTurn == 0 then
                    stopsText = tostring(exTurn)
                elseif exTurn > 0 then
                    local maxExTurn = 19 - totalStops
                    stopsText = "-" .. tostring(exTurn) .. " / " .. tostring(maxExTurn)
                else
                    if remain == totalStops then
                        stopsText = tostring(remain)
                    else
                        stopsText = tostring(remain + 1)
                    end
                end

                local extraInfo =
                    " | Line: " .. line ..
                    " | Station: " .. station ..
                    " | Stops: " .. stopsText ..
                    " | Purpose: " .. purpose ..
                    " | Arousal: " .. arousal ..
                    " | Alert: " .. alert ..
                    " | Attention: " .. attention

                -- Heroine 상태 라인에 정보 추가 (cleanMsg 수정)
                if cleanMsg and cleanMsg ~= "" then
                    cleanMsg = cleanMsg:gsub(
                        "(%[Heroine:[^%]]-)%]",
                        "%1" .. extraInfo .. "]",
                        1
                    )
                end
            end

            -- ===============================
            -- Chikan 메시지 출력
            -- ===============================
            if #chikanMessages > 0 then

                local lines = {}

                for _, msg in ipairs(chikanMessages) do
                    table.insert(lines,
                        "[Chikan Message: " .. msg .. "]")
                end

                cleanMsg = cleanMsg .. "\n" .. table.concat(lines, "\n")
            end

            cleanMsg = cleanMsg:gsub("<Choice>.-</Choice>", "")
            cleanMsg = cleanMsg .. "\n♣♥♣"

        elseif mode == "3" then

            -- 기존 Choice 제거 (중복 방지)
            cleanMsg = cleanMsg:gsub("<Choice>.-</Choice>", "")

            local choiceBlock =
                "\n<Choice>\n"
                .. "[Chikan End: 결과를 확인한다.]\n"
                .. "</Choice>\n"

            cleanMsg = cleanMsg .. choiceBlock
        elseif mode == "4" or mode == "5" or mode == "6" then

            -- 기존 Choice 제거 (중복 방지)
            cleanMsg = cleanMsg:gsub("<Choice>.-</Choice>", "")

            local choiceBlock = "\n<Choice>\n"

            if mode == "4" then
                choiceBlock = choiceBlock
                    .. "[Toilet End: 중단하고 돌아간다.]\n"
            elseif mode == "5" then
                choiceBlock = choiceBlock
                    .. "[Gangbang End: 중단하고 돌아간다.]\n"
            elseif mode == "6" then
                choiceBlock = choiceBlock
                    .. "[Home End: 중단하고 돌아간다.]\n"
            end

            choiceBlock = choiceBlock .. "</Choice>\n"

            cleanMsg = cleanMsg .. choiceBlock

        end

        -- 항상 마지막에 ♥♣♥ 추가
        cleanMsg = cleanMsg .. "\n♥♣♥"

        -- Save
        if mode == "1" then
            -- --------------------------
            -- 사용 스킬들 X 제거
            -- --------------------------
            do
                setChatVar(triggerId, "ct_Skill_6", tostring(extractInt(getChatVar(triggerId, "ct_Skill_6") or "0") or 0))
                setChatVar(triggerId, "ct_Skill_8", tostring(extractInt(getChatVar(triggerId, "ct_Skill_8") or "0") or 0))
                setChatVar(triggerId, "ct_Skill_10", tostring(extractInt(getChatVar(triggerId, "ct_Skill_10") or "0") or 0))
                setChatVar(triggerId, "ct_Skill_12", tostring(extractInt(getChatVar(triggerId, "ct_Skill_12") or "0") or 0))
                setChatVar(triggerId, "ct_Skill_13", tostring(extractInt(getChatVar(triggerId, "ct_Skill_13") or "0") or 0))
                setChatVar(triggerId, "ct_Skill_14", tostring(extractInt(getChatVar(triggerId, "ct_Skill_14") or "0") or 0))
                setChatVar(triggerId, "ct_Skill_15", tostring(extractInt(getChatVar(triggerId, "ct_Skill_15") or "0") or 0))
                setChatVar(triggerId, "ct_Skill_17", tostring(extractInt(getChatVar(triggerId, "ct_Skill_17") or "0") or 0))
            end
            -- --------------------------
            -- 스킬 포인트 계산
            -- --------------------------
            local chLv = tonumber(getChatVar(triggerId, "ct_ChikanLevel")) or 0
            local totalSkill =
                (tonumber(getChatVar(triggerId, "ct_Skill_1")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_2")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_3")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_4")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_5")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_6")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_7")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_8")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_9")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_10")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_11")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_12")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_13")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_14")) or 0) +
                (tonumber(getChatVar(triggerId, "ct_Skill_15")) or 0) + 
                (tonumber(getChatVar(triggerId, "ct_Skill_16")) or 0) + 
                (tonumber(getChatVar(triggerId, "ct_Skill_17")) or 0) + 
                (tonumber(getChatVar(triggerId, "ct_Skill_18")) or 0)

            local remainPoint = chLv - totalSkill
            if remainPoint < 0 then remainPoint = 0 end

            setChatVar(triggerId, "ct_ChikanPoint", tostring(remainPoint))

            local extraText = ""

            if chLv >= 10 then
                extraText = extraText .. "[Heroine Clothes: 등장할 캐릭터의 옷에 포함할 요소를 입력]\n"
            end

            if chLv >= 20 then
                extraText = extraText .. "[Set Train Theme: 다음에 탈 열차 테마 설정]\n"
            end

            -- extraText가 있을 때만 실행
            if extraText ~= "" then
                cleanMsg = cleanMsg:gsub(
                    "</Choice>",
                    extraText .. "</Choice>"
                )
            end

            cleanMsg = cleanMsg .. "\n▣◇▣"

            local fullSave = buildChikanFullSave(triggerId)
            if fullSave ~= "" then
                cleanMsg = cleanMsg .. "\n" .. fullSave
            end

            generateHTML(triggerId)
        else
            local targetSave = buildChikanTargetSave(triggerId, changedVars)
            if targetSave ~= "" then
                cleanMsg = cleanMsg .. "\n" .. targetSave
            end
        end

        if cleanMsg ~= lastMsg then
            setChat(triggerId, lastIndex - 1, cleanMsg)
        end

        buildSessionMemory(triggerId)
    end

end)

-- ==========================================
-- 버튼
-- ==========================================
function loadData(triggerId)

    print("불러오기 실행")

    restoreChikanFullSave(triggerId)
    buildTargetStatus(triggerId)
    buildCurrentMemory(triggerId)
    buildSessionMemory(triggerId)
    buildAllCharacterOverview(triggerId)
    restoreChikanDeck(triggerId)
    generateHTML(triggerId)
    reloadDisplay(triggerId)

    alertNormal(triggerId, "✅ 불러오기 완료")
end

setHeroineClothes = async(function(triggerId)

    -- ===============================
    -- 📌 마지막 user 채팅 찾기
    -- ===============================
    local cl = getChatLength(triggerId)
    local last = getChat(triggerId, cl - 1)

    if not (last and last.role == "user" and type(last.data) == "string") then
        alertError(triggerId, "❌ 먼저 목표 캐릭터를 선택하세요.")
        return
    end

    local text = last.data

    -- ===============================
    -- 📌 Date 라인 존재 여부 확인
    -- ===============================
    if not text:match("%[Date: [^%]]*%]") then
        alertError(triggerId, "❌ 먼저 목표 캐릭터를 선택하세요.")
        return
    end

    -- ===============================
    -- ✔ 여기서만 입력창 표시
    -- ===============================
    local message =
        "등장할 캐릭터의 옷에 포함시키고자 하는 요소를 입력하세요.\n빈 칸을 입력하면 해제됩니다.\n"
        .. "(예: 검은 스타킹, 흰 블라우스, 베이지 코트)"

    local input = alertInput(triggerId, message):await()

    -- ===============================
    -- 📌 기존 Clothes 라인 제거
    -- ===============================
    text = text:gsub("\n?%[The heroine's attire includes the following elements: [^%]]*%]", "")

    -- ===============================
    -- 📌 입력값 처리
    -- ===============================
    if input and input ~= "" then

        local clothesLine = "[The heroine's attire includes the following elements: " .. input .. "]"

        -- Date 바로 아래에 삽입
        text = text:gsub(
            "(%[Date: [^%]]*%])",
            "%1\n" .. clothesLine
        )
    end

    -- ===============================
    -- 📌 채팅 갱신
    -- ===============================
    setChat(triggerId, cl - 1, text)

end)

setTrainTheme = async(function(triggerId)

    -- ===============================
    -- 📌 마지막 user 채팅 찾기
    -- ===============================
    local cl = getChatLength(triggerId)
    local last = getChat(triggerId, cl - 1)

    if not (last and last.role == "user" and type(last.data) == "string") then
        alertError(triggerId, "❌ 먼저 목표 캐릭터를 선택하세요.")
        return
    end

    local text = last.data

    -- ===============================
    -- 📌 Date 라인 존재 여부 확인
    -- ===============================
    if not text:match("%[Date: [^%]]*%]") then
        alertError(triggerId, "❌ 먼저 목표 캐릭터를 선택하세요.")
        return
    end

    -- ===============================
    -- ✔ 여기서만 입력창 표시
    -- ===============================
    local trainTheme = safeGet(triggerId, "ct_Train_Theme", "")
    local message =
        "다음에 탈 열차의 테마를 입력하세요.\n빈 칸을 입력하면 Modern Japanese Train 으로 설정됩니다.\n"
        .. "현재 테마: " .. trainTheme

    local input = alertInput(triggerId, message):await()

    -- ===============================
    -- 📌 기존 Clothes 라인 제거
    -- ===============================
    text = text:gsub("\n?%[Train Setting: [^%]]*%]", "")

    -- ===============================
    -- 📌 입력값 처리
    -- ===============================
    if input and input ~= "" then

        local clothesLine = "[Train Setting: " .. input .. "]"

        -- Date 바로 아래에 삽입
        text = text:gsub(
            "(%[Date: [^%]]*%])",
            "%1\n" .. clothesLine
        )
        setChatVar(triggerId, "ct_Train_Theme", input)
    elseif input == "" then
        setChatVar(triggerId, "ct_Train_Theme", "Modern Japanese Train")
    end

    -- ===============================
    -- 📌 채팅 갱신
    -- ===============================
    setChat(triggerId, cl - 1, text)

end)

