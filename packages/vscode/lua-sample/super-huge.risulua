-- ==========================================
function buildTargetStatus(triggerId)

    local targetName = safeGet(triggerId, "ct_Target_Name", "")
    if targetName == "" then
        setChatVar(triggerId, "ct_Target_Status", "")
        return
    end

    local targetCode = findCharacterCode(triggerId, targetName)
    if not targetCode then
        setChatVar(triggerId, "ct_Target_Status", "")
        return
    end


    -- ==========================================
    -- Target Nai 생성
    -- ==========================================

    local naiRaw = safeGet(triggerId, targetCode .. "_Nai", "")

    if naiRaw ~= "" then

        -- 태그 조정
        naiRaw = naiRaw:gsub("Gradient Hair,", "Gradient Hair Tips,")
        naiRaw = naiRaw:gsub("Chin%-length hair,", "Bob cut,")

        if naiRaw:find("Medium Breasts,", 1, true) and naiRaw:find("Mature", 1, true) then
            naiRaw = naiRaw:gsub("Medium Breasts,", "2::Medium Breasts::, -2::Huge Breasts::,")
        end

        local naiBlock =
            "## " .. targetName .. "\n"
            .. naiRaw

        setChatVar(triggerId, "ct_Target_Nai", naiBlock)
    else
        setChatVar(triggerId, "ct_Target_Nai", "")
    end

    -- ==========================================
    -- Target 세팅
    -- ==========================================
    local resRaw = safeGet(triggerId, targetCode .. "_Response", "")
    setChatVar(triggerId, "ct_Target_Response", resRaw)

    local resRawA = safeGet(triggerId, targetCode .. "_ResponseArousal", "")
    setChatVar(triggerId, "ct_Target_ResponseArousal", resRawA)

    -- ==========================================
    -- Encounter
    -- ==========================================
    -- Corruption 값
    local corr = tonumber(safeGet(triggerId, targetCode .. "_Corruption", "0")) or 0

    -- 히스토리 문자열
    local history = safeGet(triggerId, targetCode .. "_History", "") or ""

    -- 기록 분리
    local count = 0
    local hasAction = false

    -- 제외 키워드
    local excludePregnancy = {
        "출산", "Childbirth", "出産",
        "임신", "Pregnancy", "妊娠"
    }

    local count = 0
    local lastDate = nil

    for entry in string.gmatch(history, "([^|]+)") do
        local skip = false

        -- 제외 키워드 체크
        for _, word in ipairs(excludePregnancy) do
            if string.find(entry, word, 1, true) then
                skip = true
                break
            end
        end

        if not skip and entry:match("%S") then
            count = count + 1

            -- 날짜 추출 (YYYY-MM-DD)
            local date = entry:match("^(%d%d%d%d%-%d%d%-%d%d)")
            if date then
                lastDate = date  -- 마지막 값 유지
            end
        end
    end

    -- 이번이 몇 번째인지 (현재 포함 → +1)
    local encounterNum = count + 1

    -- 서수 변환 함수
    local function ordinal(n)
        local lastTwo = n % 100
        if lastTwo >= 11 and lastTwo <= 13 then
            return n .. "th"
        end

        local last = n % 10
        if last == 1 then return n .. "st"
        elseif last == 2 then return n .. "nd"
        elseif last == 3 then return n .. "rd"
        else return n .. "th"
        end
    end

    local encounterText = ordinal(encounterNum)

    -- 세 줄 구성
    local encounterVar = "- Heroine's Attitude toward " .. getPersonaName(triggerId) .. ": " .. describeCorruptionLevel(triggerId, corr)
    encounterVar = encounterVar .. "\n- This is the " .. encounterText .. " time the heroine has been targeted by " .. getPersonaName(triggerId) .. "."

    if lastDate then
        encounterVar = encounterVar .. " The last time the heroine encountered " .. getPersonaName(triggerId) .. " was on " .. lastDate

        if count == 1 then
            encounterVar = encounterVar .. ", and she may remember " .. getPersonaName(triggerId) .. "."
        elseif count >= 2 then
            encounterVar = encounterVar .. ", and she remembers " .. getPersonaName(triggerId) .. ""

            if corr < 5 then
                encounterVar = encounterVar .. "."
            elseif corr < 25 then
                encounterVar = encounterVar .. " and eventually recognizes him."
            elseif corr < 50 then
                encounterVar = encounterVar .. " and quickly recognizes him."
            elseif corr < 75 then
                encounterVar = encounterVar .. " and recognizes him at once."
            elseif corr < 100 then
                encounterVar = encounterVar .. " and recognizes him instantly."
            else
                encounterVar = encounterVar .. " and cannot fail to recognize him. Since then, she has masturbated every day while recalling the times " .. getPersonaName(triggerId) .. " had molested her."
            end
        end
    end

    -- 변수 저장
    setChatVar(triggerId, "ct_Target_Encounter", encounterVar)

    -- ==========================================
    -- Body
    -- ==========================================

    buildBodySensitivityText(triggerId)

    -- ==========================================
    -- Profile
    -- ==========================================
    local lines = {}

    local profile = safeGet(triggerId, targetCode .. "_Profile", "")

    if profile ~= "" then
        profile = profile:gsub("Sharp Eyes", "Sharp Eyes (Normal pupils; not Four-white eyes)")
        profile = profile:gsub("Piercing Eyes", "Piercing Eyes (Normal pupils; not Four-white eyes)")

        table.insert(lines, "")
        table.insert(lines, profile)
        table.insert(lines, "")
    end

    -- ==========================================
    -- 나머지 (Virginity + Reproductive + History)
    -- ==========================================

    buildVirginityReproductiveHistory(triggerId, targetCode, lines, false)

    -- ==========================================
    -- Virginity 저장
    -- ==========================================

    local rawFirst = safeGet(triggerId, targetCode .. "_First", "0|0|0|0")
    local firstData = splitPipe(rawFirst)

    local fk = firstData[1] or "0"
    local ff = firstData[2] or "0"
    local fv = firstData[3] or "0"
    local fa = firstData[4] or "0"

    -- 0 → "" / 값 있음 → "1"
    if fk ~= "0" and fk ~= "" then fk = "1" else fk = "" end
    if ff ~= "0" and ff ~= "" then ff = "1" else ff = "" end
    if fv ~= "0" and fv ~= "" then fv = "1" else fv = "" end
    if fa ~= "0" and fa ~= "" then fa = "1" else fa = "" end

    setChatVar(triggerId, "ct_Target_ResultKiss", fk)
    setChatVar(triggerId, "ct_Target_ResultFellatio", ff)
    setChatVar(triggerId, "ct_Target_ResultVaginal", fv)
    setChatVar(triggerId, "ct_Target_ResultAnal", fa)

    -- ==========================================
    -- Trait (출력만)
    -- ==========================================

    buildTraitSection(triggerId, targetCode, lines)

    -- ==========================================
    -- Trait 저장 (이름만 추출)
    -- ==========================================

    do
        local traitRaw  = safeGet(triggerId, targetCode .. "_Trait", "")
        local traitList = splitPipe(traitRaw)

        local nameResult = {}

        for _, t in ipairs(traitList) do
            local name = t:match("^%s*([^:]+)")
            if name then
                table.insert(nameResult, trim(name))
            end
        end

        if #nameResult > 0 then
            setChatVar(triggerId, "ct_Target_Trait", table.concat(nameResult, "|"))
        else
            setChatVar(triggerId, "ct_Target_Trait", "")
        end
    end

    -- ==========================================
    -- 최종 저장
    -- ==========================================

    local finalText = table.concat(lines, "\n")
    setChatVar(triggerId, "ct_Target_Status", finalText)

end

function buildTraitSection(triggerId, targetCode, lines)

    local traitRaw = safeGet(triggerId, targetCode .. "_Trait", "")
    local traitList = splitPipe(traitRaw)

    if #traitList > 0 then
        table.insert(lines, "\n### Trait")

        for _, t in ipairs(traitList) do
            table.insert(lines, "- " .. t)
        end
    end

end

