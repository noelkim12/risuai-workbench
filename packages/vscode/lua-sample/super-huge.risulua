    -- ======================================

    additionalCharacterList[typeName] = {
        fullName = fullName,

        v_Height = v_Height,
        v_Age = v_Age,

        v_BodyType = v_BodyType,
        v_BustSize = v_BustSize,
        v_Skin = v_Skin,
        v_Face = v_Face,
        v_BodyAdd = v_BodyAdd,

        v_Hair = v_Hair,
        v_Eye = v_Eye,

        v_Personality = v_Personality,
        v_SpeechStyle = v_SpeechStyle,

        v_Occupation = v_Occupation,
        v_Affiliation = v_Affiliation,

        v_Background = v_Background,
        v_Reputation = v_Reputation,
        v_Values = v_Values,
        v_Friend = v_Friend,
        v_SocialStyle = v_SocialStyle,
        v_Health = v_Health,
