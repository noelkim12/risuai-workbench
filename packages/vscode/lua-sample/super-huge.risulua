setStartDatePrompt = async(function(triggerId)
    if safeGet(triggerId, "ct_Init", "0") == "1" then return end
    
    local current = getChatVar(triggerId, "ct_StartDate") or os.date("%Y-%m-%d")
    
    local message = "시작일을 입력하세요.\n형식: YYYY-MM-DD\n\n현재 날짜: " .. current
    
    local input = alertInput(triggerId, message):await()
    
    if input and input:match("^%d%d%d%d%-%d%d%-%d%d$") then
        setChatVar(triggerId, "ct_StartDate", input)
        alertNormal(triggerId, "✅ 시작일이 설정되었습니다: " .. input)
    else
        alertError(triggerId, "❌ 입력 형식이 올바르지 않습니다.\nYYYY-MM-DD 형식으로 입력하세요.")
    end
end)

