-- ==========================================
-- Data Structure
-- ==========================================
-- ct_Mode
-- 1 = 스케쥴 / 결과 정리 -> 2
-- 2 = 전철 치한 -> 3
-- 3 = 치한 종료 -> 1
-- 4 = 화장실 -> 1
-- 5 = 윤간 -> 1
-- 6 = 집 -> 1

-- CXXX_First      = [1] First Kiss | [2] First Fellatio | [3] First Vaginal Penetration | [4] First Anal Penetration (0 = not experienced)
-- CXXX_Count      = Climax | External | Oral | Vaginal | Anal Ejaculation Counts
-- CXXX_Bodypart   = Breast | Oral | Clitoris | Vaginal | Anal
-- ==========================================
-- 공용 모듈
-- ==========================================
local function trim(s)
    return (s:gsub("^%s+", ""):gsub("%s+$", ""))
end

local function clamp(v, min, max)
    if v < min then return min end
    if v > max then return max end
    return v
end

local function splitPipe(str)
    local t = {}

    if not str or str == "" then
        return t
    end

    for token in string.gmatch(str, "([^|]+)") do
        table.insert(t, trim(token))
    end

    return t
end

local function splitLiteral(str, sep)
    local t = {}

    if not str or str == "" then
        return t
    end

    local start = 1

    while true do
        local i, j = string.find(str, sep, start, true)
        if not i then
            table.insert(t, trim(string.sub(str, start)))
            break
        end

        table.insert(t, trim(string.sub(str, start, i - 1)))
        start = j + 1
    end

    return t
end

local function joinPipe(t)
    if not t or #t == 0 then
        return ""
    end
    return table.concat(t, "|")
end

function appendComma(fullValue, addValue)
    if not addValue or addValue == "" then
        return fullValue
    end

    if not fullValue or fullValue == "" then
        return addValue
    end

    return fullValue .. ", " .. addValue
end

function appendPipe(fullValue, addValue)
    if not addValue or addValue == "" then
        return fullValue
    end

    if not fullValue or fullValue == "" then
        return addValue
    end

    return fullValue .. "|" .. addValue
end

function safeGet(triggerId, key, default)
    local val = getChatVar(triggerId, key)
    if val == nil or val == "null" or val == "nil" then return default end
    return val
end

-- 숫자 안전 추출
local function extractInt(s)
    if not s then return 0 end
    local m = tostring(s):match("[-+]?%d+")
    return tonumber(m) or 0
end

-- 이름 → CXXX 코드 찾기
function findCharacterCode(triggerId, targetName)

    local charList = safeGet(triggerId, "ct_CharList", "")

    for token in string.gmatch(charList, "([^|]+)") do
        local code, name = token:match("^(C%d+)%=(.+)$")
        if code and name then
            if name == targetName or string.find(name, targetName, 1, true) then
                return code
            end
        end
    end

    return nil
end

-- ==========================================
-- 캐릭터 생성
-- ==========================================
function createRandomCharacter(triggerId, level, expansion)

