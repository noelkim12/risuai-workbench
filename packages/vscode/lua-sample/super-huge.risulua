        elseif b_sexualExperience == "One-Night" then
            removeValues(traitPool, "Overprotected")
        end

        -- =========================
        -- Guaranteed Trait Helper
        -- =========================
        local function forceAddTrait(traitPool, traitName)

            for i = #traitPool, 1, -1 do
                if traitPool[i] == traitName then

                    local data = traitData[traitName]

                    -- =========================
                    -- Trait 적용 (랜덤과 동일)
                    -- =========================
                    if data and data.desc then
                        v_Trait = appendPipe(v_Trait, traitName .. ": " .. data.desc)
                    else
                        v_Trait = appendPipe(v_Trait, traitName)
                    end

                    if data and data.additional then
                        v_Additional = appendComma(v_Additional, data.additional)
                    end

                    -- =========================
                    -- 풀에서 제거
                    -- =========================
                    table.remove(traitPool, i)

                    -- =========================
                    -- exclude 제거
                    -- =========================
                    if data and data.exclude then
                        for ex in string.gmatch(data.exclude, "[^|]+") do
                            for j = #traitPool, 1, -1 do
                                if traitPool[j] == ex then
                                    table.remove(traitPool, j)
                                end
                            end
                        end
                    end

                    return true
                end
            end

            return false
        end

