function skill_Reset(triggerId)

    -- 현재 총 레벨 = 최대 포인트
    local maxPoint = tonumber(getChatVar(triggerId, "ct_ChikanLevel")) or 0

    -- 스킬 전부 0으로
    for i = 1, 18 do
        setChatVar(triggerId, "ct_Skill_" .. i, "0")
    end

    -- 포인트 전부 환급
    setChatVar(triggerId, "ct_ChikanPoint", tostring(maxPoint))

end

-- ==========================================
-- 선택지
-- ==========================================
onButtonClick = async(function(t, c)

    local currentMode = tostring(getChatVar(t, "ct_Mode") or "")
    -- ===============================
    -- 버튼 파싱
    -- ===============================
    local parts = {}

    for m in (c .. "_"):gmatch("(.-)_") do
        table.insert(parts, m)
    end

    -- choice가 아니면 종료
    if parts[1] ~= "choice" then
        return
    end

    local actionType = parts[2]

    -- ======================================
    -- 현재 상태 로그
    -- ======================================
    local function updateCurrentStatusBlock(prevArousal, nextArousalValue, prevAlert, nextAlertValue, prevAttention, nextAttentionValue)

        local prevArousalDesc = describeArousalLocal(t, prevArousal)
        local nextArousalDesc = describeArousalLocal(t, nextArousalValue)

        local prevAlertDesc = ""
        local nextAlertDesc = ""
        local prevAlertDisplay = prevAlert
        local nextAlertDisplay = nextAlertValue

        local targetCorruption = 0

        -- 치한 성공 후 Alert 조정
        local clearFlag = tonumber(safeGet(t, "ct_Target_Clear", "0")) or 0
        if clearFlag == 1 then
            prevAlertDisplay = 100
            nextAlertDisplay = 100
        end

        prevAlertDesc = describeAlertLocal(t, prevAlertDisplay)
        nextAlertDesc = describeAlertLocal(t, nextAlertDisplay)

        local targetName = safeGet(t, "ct_Target_Name", "")
        if targetName ~= "" then
            local targetCode = findCharacterCode(t, targetName)
            if targetCode then
                targetCorruption = tonumber(safeGet(t, targetCode .. "_Corruption", "")) or 0
            end
        end

        local prevAttentionDesc = describeAttentionLocal(t, prevAttention)
        local nextAttentionDesc = describeAttentionLocal(t, nextAttentionValue)

        local currentBlock = ""

        -- Physiological Response
        if prevArousalDesc ~= nextArousalDesc then
            local diffArousal = nextArousalValue - prevArousal

            if diffArousal > 0 then
                currentBlock = currentBlock
                    .. "- Heroine's physiological response intensifies: "
                    .. prevArousalDesc .. " → " .. nextArousalDesc
            else
                currentBlock = currentBlock
                    .. "- Heroine's physiological response subsides: "
                    .. prevArousalDesc .. " → " .. nextArousalDesc
            end
        else
            currentBlock = currentBlock
                .. "- Heroine's physiological response remains: "
                .. nextArousalDesc
        end

        -- Wariness
        if nextAlertValue < 100 and targetCorruption >= 100 and ((clearFlag == 1 and nextArousalValue >= 135) or nextArousalValue >= 150) then
                currentBlock = currentBlock
                    .. "\n- Heroine's wariness: Completely disarmed; she shows no sign of displeasure toward " .. getPersonaName(t) .. ", entrusting herself entirely and eagerly seeking pleasure as well."
        else
            if prevAlertDesc ~= nextAlertDesc then
                local diffAlert = nextAlertValue - prevAlert

                if diffAlert > 0 then
                    currentBlock = currentBlock
                        .. "\n- Heroine's wariness increases: "
                        .. prevAlertDesc .. " → " .. nextAlertDesc
                else
                    currentBlock = currentBlock
                        .. "\n- Heroine's wariness decreases: "
                        .. prevAlertDesc .. " → " .. nextAlertDesc
                end
            else
                currentBlock = currentBlock
                    .. "\n- Heroine's wariness remains: "
                    .. nextAlertDesc
            end
        end

        -- Crowd Attention
        if prevAttentionDesc ~= nextAttentionDesc then
            local diffAttention = nextAttentionValue - prevAttention

            if diffAttention > 0 then
                currentBlock = currentBlock
                    .. "\n- Crowd's attention increases: "
                    .. prevAttentionDesc .. " → " .. nextAttentionDesc
            else
                currentBlock = currentBlock
                    .. "\n- Crowd's attention decreases: "
                    .. prevAttentionDesc .. " → " .. nextAttentionDesc
            end
        else
            currentBlock = currentBlock
                .. "\n- Crowd's attention remains: "
                .. nextAttentionDesc
        end

        setChatVar(t, "ct_Target_Current", currentBlock)
    end

    -- =====================================================
    -- 목표 히로인
    -- =====================================================
    if actionType == "objective" then

        local code = parts[3] or ""

        local key = "ct_Char_Objective"

        -- 현재 저장된 값
        local current = safeGet(t, key, "")

        -- 같으면 해제, 다르면 설정
        if current == code then
            setChatVar(t, key, "")
        else
            setChatVar(t, key, code)
        end

        buildAllCharacterOverview(t)
        generateHTML(t)
        reloadDisplay(t)
        alertNormal(t, "🎯 집착 대상이 갱신되었습니다.")
    -- =====================================================
    -- 🚇 이동 분기
    -- =====================================================
    elseif actionType == "move" then

        -- 스킬 백업
        local backupSkills = {}
        for i = 1, 18 do
            backupSkills[i] = getChatVar(t, "ct_Skill_" .. i) or "0"
        end
        local backupPoint = getChatVar(t, "ct_ChikanPoint") or "0"

        restoreChikanFullSave(t)

        -- 스킬 복원
        for i = 1, 18 do
            setChatVar(t, "ct_Skill_" .. i, backupSkills[i])
        end
        setChatVar(t, "ct_ChikanPoint", backupPoint)

        -- 모드 변경
        setChatVar(t, "ct_Mode", "2")

        if #parts < 10 then
            return
        end

        local rawDate   = parts[3] or ""
        local daypart   = parts[4] or ""
        local crowding  = parts[5] or ""
        local heroine   = parts[6] or ""
        local purpose   = parts[7] or ""
        local line      = parts[8] or ""
        local station   = parts[9] or ""
        local stops     = extractInt(parts[10])

        -- ===============================
        -- Crowding 이모지 → 언어별 텍스트 변환
        -- ===============================
        local lang = tonumber(getChatVar(t, "ct_Language") or "1")
        local crowdText = crowding

        if crowding == "🟢" then
            if lang == 1 then crowdText = "한산"
            elseif lang == 2 then crowdText = "Sparse"
            elseif lang == 3 then crowdText = "空いている" end

        elseif crowding == "🟡" then
            if lang == 1 then crowdText = "적당"
            elseif lang == 2 then crowdText = "Moderate"
            elseif lang == 3 then crowdText = "普通" end

        elseif crowding == "🟠" then
            if lang == 1 then crowdText = "혼잡"
            elseif lang == 2 then crowdText = "Crowded"
            elseif lang == 3 then crowdText = "混雑" end

        elseif crowding == "🔴" then
            if lang == 1 then crowdText = "극심한 혼잡"
            elseif lang == 2 then crowdText = "Packed"
            elseif lang == 3 then crowdText = "満員" end
        end

        -- ===============================
        -- Date 처리
        -- ===============================
        local cleanedDate = rawDate:gsub("%b()", "")
        cleanedDate = trim(cleanedDate)

        resetTargetState(t)

        setChatVar(t, "ct_NextDate", cleanedDate)
        setChatVar(t, "ct_NextDaypart", daypart)
        setChatVar(t, "ct_Target_Name", trim(heroine))
        setChatVar(t, "ct_Target_Crowd", crowdText)
        setChatVar(t, "ct_Target_Line", trim(line))
        setChatVar(t, "ct_Target_Station", trim(station))
        setChatVar(t, "ct_Target_Purpose", trim(purpose))
        setChatVar(t, "ct_Target_Stops", tostring(stops))
        setChatVar(t, "ct_Target_RemainStops", tostring(stops + 1))

        -- ==========================================
        -- LastPeriod 설정
        -- ==========================================
        local targetCode = findCharacterCode(t, trim(heroine))

        if targetCode then
            local lastPeriodKey = targetCode .. "_LastPeriod"
            local currentLast = safeGet(t, lastPeriodKey, "")

            -- 아직 기록이 없을 경우에만 생성
            if currentLast == "" then

                -- cleanedDate → 연/월/일 분해
                local y, m, d = cleanedDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

                if y and m and d then
                    local baseTime = os.time({
                        year  = tonumber(y),
                        month = tonumber(m),
                        day   = tonumber(d),
                        hour  = 12
                    })

                    -- 0 ~ 27일 랜덤
                    local offsetDays = math.random(0, 27)

                    local lastTime = baseTime - (offsetDays * 86400)

                    local lastDate = os.date("%Y-%m-%d", lastTime)

                    setChatVar(t, lastPeriodKey, lastDate)
                end

            else

                -- ==========================================
                -- 임신 판정 (Pregnancy 값이 숫자일 경우만)
                -- ==========================================
                local pregnancyKey  = targetCode .. "_Pregnancy"
                local pregRaw = safeGet(t, pregnancyKey, "")

                local pregnancySucceeded = false

                if pregRaw ~= "" then
                    local pregChance = tonumber(pregRaw)

                    if pregChance then

                        -- ==========================================
                        -- 날짜 조건 체크:
                        -- "배란일 + 1일" 보다 이후(cleanedDate가 더 미래)일 때만 판정
                        -- 배란일 = LastPeriod + 14일
                        -- 임신일(저장) = 배란일 + 1일 (LastPeriod + 15일)
                        -- ==========================================
                        local y2, m2, d2 = currentLast:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")
                        local y1, m1, d1 = cleanedDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

                        if y2 and m2 and d2 and y1 and m1 and d1 then

                            local baseTime = os.time({
                                year  = tonumber(y2),
                                month = tonumber(m2),
                                day   = tonumber(d2),
                                hour  = 12
                            })

                            local currentTime = os.time({
                                year  = tonumber(y1),
                                month = tonumber(m1),
                                day   = tonumber(d1),
                                hour  = 12
                            })

                            local ovulationTime = baseTime + (13 * 86400)
                            local pregTime      = baseTime + (14 * 86400)  -- 배란일 + 1일
                            local pregDate      = os.date("%Y-%m-%d", pregTime)

                            -- ✅ 배란일+1일(pregTime) "이후"일 때만 확률 판정
                            if currentTime > pregTime then

                                local dice = math.random(1, 100)

                                if dice <= pregChance then
                                    -- ==========================
                                    -- ✅ 임신 성공
                                    -- ==========================

                                    -- LastPeriod → X
                                    setChatVar(t, lastPeriodKey, "X")

                                    -- Pregnancy → 임신일(배란일+1일로 고정)
                                    setChatVar(t, pregnancyKey, pregDate)

                                    pregnancySucceeded = true

                                    -- ==========================
                                    -- History 기록: 임신
                                    -- ==========================
                                    -- timeSpan 생성 (임신일 = pregDate 기준)
                                    local py3, pm3, pd3 = pregDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")
                                    local weekday = ""

                                    local pregText

                                    if lang == 1 then
                                        pregText = "임신"
                                    elseif lang == 2 then
                                        pregText = "Pregnancy"
                                    elseif lang == 3 then
                                        pregText = "妊娠"
                                    else
                                        pregText = "Pregnancy"
                                    end

                                    local historyEntry =
                                        pregDate .. " § " .. pregText

                                    local oldHistory =
                                        safeGet(t, targetCode .. "_History", "")

                                    if oldHistory == "" then
                                        setChatVar(t, targetCode .. "_History", historyEntry)
                                    else
                                        setChatVar(t, targetCode .. "_History", oldHistory .. " | " .. historyEntry)
                                    end

                                    updateHistoryCount(t, targetCode)

                                else
                                    -- ==========================
                                    -- ❌ 임신 실패
                                    -- ==========================
                                    setChatVar(t, pregnancyKey, "")
                                end
                            end
                        end

                    else
                        local pregIsDate = pregRaw:match("^%d%d%d%d%-%d%d%-%d%d$")
                        if pregIsDate then

                            -- ==========================================
                            -- 출산 체크 (40주 = 280일)
                            -- ==========================================
                            local py, pm, pd = pregRaw:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")
                            local cy, cm, cd = cleanedDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

                            if py and pm and pd and cy and cm and cd then

                                local conceptionTime = os.time({
                                    year  = tonumber(py),
                                    month = tonumber(pm),
                                    day   = tonumber(pd),
                                    hour  = 12
                                })

                                local currentTime = os.time({
                                    year  = tonumber(cy),
                                    month = tonumber(cm),
                                    day   = tonumber(cd),
                                    hour  = 12
                                })

                                local daysPassed = math.floor((currentTime - conceptionTime) / 86400)
                                if daysPassed < 0 then daysPassed = 0 end

                                if daysPassed >= 280 then

                                    -- ✅ 출산일 = 임신일(pregRaw) + 280일(40주)
                                    local birthTime = conceptionTime + (280 * 86400)
                                    local birthDate = os.date("%Y-%m-%d", birthTime)

                                    -- timeSpan 생성 (출산일 기준)
                                    local by, bm, bd = birthDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

                                    local birthText

                                    if lang == 1 then
                                        birthText = "출산"
                                    elseif lang == 2 then
                                        birthText = "Childbirth"
                                    elseif lang == 3 then
                                        birthText = "出産"
                                    else
                                        birthText = "Childbirth"
                                    end

                                    -- 장소 비움 / Acts = 출산(언어별) / Comment 비움
                                    local historyEntry =
                                        birthDate .. " § " .. birthText

                                    local oldHistory =
                                        safeGet(t, targetCode .. "_History", "")

                                    if oldHistory == "" then
                                        setChatVar(t, targetCode .. "_History", historyEntry)
                                    else
                                        setChatVar(t, targetCode .. "_History", oldHistory .. " | " .. historyEntry)
                                    end

                                    updateHistoryCount(t, targetCode)

                                    -- 임신 상태 초기화
                                    setChatVar(t, pregnancyKey, "")

                                    -- ✅ 새 주기 시작일도 출산일 기준으로
                                    setChatVar(t, lastPeriodKey, birthDate)
                                    currentLast = birthDate
                                end
                            end
                        end
                    end
                end

                -- ==========================================
                -- 임신 성공이 아닐 때만 기존 28일 주기 유지 로직 실행
                -- ==========================================
                if not pregnancySucceeded then

                    -- 기존 LastPeriod 날짜 파싱
                    local y2, m2, d2 = currentLast:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")
                    local y1, m1, d1 = cleanedDate:match("^(%d%d%d%d)%-(%d%d)%-(%d%d)$")

                    if y2 and m2 and d2 and y1 and m1 and d1 then

                        local lastTime = os.time({
                            year  = tonumber(y2),
                            month = tonumber(m2),
                            day   = tonumber(d2),
                            hour  = 12
                        })

                        local currentTime = os.time({
                            year  = tonumber(y1),
                            month = tonumber(m1),
                            day   = tonumber(d1),
                            hour  = 12
                        })

                        -- 28일 주기 유지
                        while (currentTime - lastTime) > (27 * 86400) do
                            lastTime = lastTime + (28 * 86400)
                        end

                        -- 미래로 넘어갔다면 한 주기 뒤로
                        if lastTime > currentTime then
                            lastTime = lastTime - (28 * 86400)
                        end

                        local adjustedDate = os.date("%Y-%m-%d", lastTime)

                        setChatVar(t, lastPeriodKey, adjustedDate)
                    end

                end

            end
        end

        buildTargetStatus(t)
        buildCurrentMemory(t)
        generateHTML(t)
        reloadDisplay(t)

        -- ===============================
        -- 🚇 출력 라인 (Line + Station 포함)
        -- ===============================
        local newLine = string.format(
        "[Date: %s | Daypart: %s | Crowding: %s | Heroine: %s | Purpose: %s | Line: %s | Destination Station: %s | Remain Stops: %d]",
            rawDate,
            daypart,
            crowdText,
            heroine,
            purpose,
            line,
            station,
            stops
        )

        -- ===============================
        -- 상태 블록 생성
        -- ===============================
        local initAlert  = tonumber(safeGet(t, "ct_Target_NextAlert", "0")) or 0
        local initAtt    = tonumber(safeGet(t, "ct_Target_NextAttention", "0")) or 0
        local initArousal= tonumber(safeGet(t, "ct_Target_NextArousal", "0")) or 0

        updateCurrentStatusBlock (0, initArousal, 0, initAlert, 0, initAtt)

        local statusBlock = ""
        local onlyExpansion = tonumber(safeGet(t, "ct_OnlyExpansion", "0")) or 0
        if onlyExpansion == 1 then
            statusBlock = "\n▷ [Unless otherwise specified, the heroine appears wearing her signature canon outfit, provided it does not significantly conflict with her reason for boarding the train.]"
        end

        statusBlock = statusBlock..
            "\n▷ [After some time has passed, {{user}} moves to a different train. By coincidence, {{user}} spots the heroine from a distance on the specified line. The response must conclude with no physical contact or interaction of any kind having occurred. Under no circumstances is any interaction with the heroine allowed in this response. The heroine also does not notice or become aware of {{user}} at any point during this response. The response must end with {{user}} and the heroine having had no contact. Wait for the User's next input.]"

        local cl = getChatLength(t)

        if cl > 0 then
            local last = getChat(t, cl - 1)

            if last and last.role == "user" and type(last.data) == "string" then
                local text = last.data

                -- 🆕 추가 설정 제거
                text = text:gsub("\n?%[The heroine's attire includes the following elements: [^%]]*%]", "")
                text = text:gsub("\n?%[Train Setting: [^%]]*%]", "")
                
                -- 기존 ▷ 블록 전부 제거
                text = text:gsub("\n?%s*▷ %[[^%]]*%]", "")

                -- 기존 존재 여부 확인
                if text:match("%[Date: [^%]]*%]") then
                    text = text:gsub("%[Date: [^%]]*%]", newLine)
                else
                    if text ~= "" then
                        text = text .. "\n" .. newLine
                    else
                        text = newLine
                    end
                end

                text = text .. statusBlock
                setChat(t, cl - 1, text)
                return
            end
        end

        local newText = newLine .. statusBlock
        addChat(t, "user", newText)
    -- =====================================================
    -- 🎲 치한 분기
    -- =====================================================
    elseif actionType == "chikan" then
        local deckCode  = parts[3] or "0"      -- Code
        local actName   = parts[4] or ""       -- Action Name

        local isReroll = (actName == "🎲 리롤")

        local clearFlag = tonumber(safeGet(t, "ct_Target_Clear", "0")) or 0
        local autoSuccess = 0
        local autoOff = tonumber(safeGet(t, "ct_AutoOffAfterClear", "0")) or 0

        if (clearFlag == 0 or autoOff == 0) then
            autoSuccess = tonumber(safeGet(t, "ct_AutoSuccess", "0")) or 0
        end

        -- ==========================================
        -- Action Order 계산
        -- ==========================================
        local cl = getChatLength(t)

        local currentOrder = 0
        local lastText = ""
        local last = nil

        if cl > 0 then
            last = getChat(t, cl - 1)

            if last and last.role == "user" and type(last.data) == "string" then
                lastText = last.data

                if lastText:find("%[Action Order:%s*2") then
                    currentOrder = 2
                elseif lastText:find("%[Action Order:%s*1") then
                    currentOrder = 1
                end
            end
        end

        if isReroll and currentOrder < 2 then return end
        if currentOrder >= 2 and not isReroll then return end

        local nextOrder = isReroll and 2 or (currentOrder + 1)

        -- ==========================================
        -- Order 1 선언 단계
        -- ==========================================
        if nextOrder == 1 then

            local newLine = "[Action Order: 1 | Code: " .. deckCode .. " | Action: " .. actName .. " | Result: Pending]"

            if cl > 0 then
                if last and last.role == "user" and type(last.data) == "string" then
                    local text = last.data

                    if text ~= "" then
                        text = text .. "\n" .. newLine
                    else
                        text = newLine
                    end

                    setChat(t, cl - 1, text)
                    return
                end
            end

            addChat(t, "user", newLine)
            return
        end

        -- ==========================================
        -- Order1 재선택 방지 (Code 기준)
        -- ==========================================
        if not isReroll and currentOrder == 1 and lastText ~= "" then

            local prevCode1 =
                lastText:match(
                    "%[Action Order:%s*1%s*|%s*Code:%s*([^|%]]+)"
                )

            if prevCode1 and trim(prevCode1) == trim(deckCode) then
                return
            end
        end

        setChatVar(t, "ct_Mode", "2")
        setChatVar(t, "ct_Target_Extra", "0")

        -- ==========================================
        -- Action 이름 결정 (Order1 Deck 복원)
        -- ==========================================
        local action1 = ""
        local action2 = ""
        local code1   = ""
        local code2   = deckCode

        -- [변경] 리롤일 때는 "리롤 버튼" 정보를 쓰면 안 됨
        --         반드시 직전 로그의 Action Order:2에서 Code/Action을 가져옴
        local prevCode2 = ""
        local prevAction2 = ""

        if lastText ~= "" then
            code1 = trim(lastText:match(
                "%[Action Order:%s*1%s*|%s*Code:%s*([^|%]]+)"
            ) or "")

            action1 = trim(lastText:match(
                "%[Action Order:%s*1%s*|%s*Code:[^|]+|%s*Action:%s*([^|%]]+)"
            ) or "")

            prevCode2 = trim(lastText:match(
                "%[Action Order:%s*2%s*|%s*Code:%s*([^|%]]+)"
            ) or "")

            prevAction2 = trim(lastText:match(
                "%[Action Order:%s*2%s*|%s*Code:[^|]+|%s*Action:%s*([^|%]]+)"
            ) or "")

            if isReroll then
                code2 = (prevCode2 ~= "" and prevCode2 or code2)
                action2 = prevAction2
            else
                action2 = actName
            end
        else
            action2 = actName
        end

        -- ==========================================
        -- Deck에서 카드 데이터 복원 (공용 함수)
        -- ==========================================
        local function loadDeckByCode(codeNumStr, fallbackActionName)
            local name  = fallbackActionName or ""
            local lvl   = 1
            local cType = ""
            local target= ""
            local th    = 1
            local aRaw  = "0"
            local alRaw = "0"
            local atRaw = "0"

            if codeNumStr ~= "" then
                local deckText = safeGet(t, "ct_Deck_List", "")

                for block in string.gmatch(deckText, "%b[]") do
                    local content = block:sub(2, -2)
                    local p = splitLiteral(content, "|")

                    local codeField = trim(p[1] or "")
                    local codeNum = codeField:match("Deck:%s*(%d+)")

                    if codeNum == codeNumStr then
                        name  = trim(p[2] or name)
                        lvl   = tonumber(extractInt(p[3])) or 1
                        cType = trim(p[4] or "")
                        target = trim(p[5] or "")
                        th    = tonumber(extractInt(p[6])) or 1
                        aRaw  = trim(p[7] or "0")
                        alRaw = trim(p[8] or "0")
                        atRaw = trim(p[9] or "0")
                        break
                    end
                end
            end

            return name, lvl, cType, target, th, aRaw, alRaw, atRaw
        end

        -- ==========================================
        -- Order1 카드 데이터 (Deck에서 복원)
        -- ==========================================
        local th1 = 1
        local a1raw = "0"
        local al1raw = "0"
        local at1raw = "0"
        local lvl1 = 1

        if code1 ~= "" then
            action1, lvl1, type1, target1, th1, a1raw, al1raw, at1raw =
                loadDeckByCode(code1, action1)
        end

        -- ==========================================
        -- Action2도 Deck에서 복원
        -- ==========================================
        local th2 = 1
        local a2raw = "0"
        local al2raw = "0"
        local at2raw = "0"
        local lvl2 = 1

        action2, lvl2, type2, target2, th2, a2raw, al2raw, at2raw =
            loadDeckByCode(code2, action2)

        -- Mitigation 중복 선택 방지 (Order1 + Order2)
        if type1 == "Mitigation" and type2 == "Mitigation" then
            return
        end

        -- Toilet ↔ Gangbang ↔ Home 상호 배타 (셋 중 하나만 선택 가능)
        if (type1 == "Toilet" and (type2 == "Gangbang" or type2 == "Home")) 
            or (type1 == "Gangbang" and (type2 == "Toilet" or type2 == "Home")) 
            or (type1 == "Home" and (type2 == "Toilet" or type2 == "Gangbang")) then
            return
        end
        -- ==========================================
        -- Pair 파싱
        -- ==========================================
        local function splitPair(str)
            local sep = string.find(str or "", "/", 1, true)
            if not sep then return 0, 0 end

            local left  = trim(str:sub(1, sep - 1))
            local right = trim(str:sub(sep + 1))

            return extractInt(left), extractInt(right)
        end

        local function getPairs(aRaw, alRaw, atRaw)
            local a_s, a_f = splitPair(aRaw)
            local al_s, al_f = splitPair(alRaw)
            local at_s, at_f = splitPair(atRaw)
            return a_s, a_f, al_s, al_f, at_s, at_f
        end

        -- ==========================================
