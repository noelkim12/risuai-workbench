function applySkillSet(triggerId, skillKey, newValue, minValue, maxValue, minChikanLevel)

    local point = tonumber(getChatVar(triggerId, "ct_ChikanPoint")) or 0
    local skill = tonumber(getChatVar(triggerId, skillKey)) or 0
    local chLv  = tonumber(getChatVar(triggerId, "ct_ChikanLevel")) or 1

    minValue = tonumber(minValue) or 0
    maxValue = tonumber(maxValue) or 5
    minChikanLevel = tonumber(minChikanLevel) or 1

    if newValue == nil or newValue == "" then
        return false
    end

    local num = tonumber(newValue)
    if not num then
        alertError(triggerId, "❌ 숫자만 입력 가능합니다.")
        return false
    end

    if num < minValue or num > maxValue then
        alertError(triggerId, "❌ " .. minValue .. " ~ " .. maxValue .. " 사이만 입력 가능합니다.")
        return false
    end

    -- 증가할 때만 레벨 제한
    if num > skill and chLv < minChikanLevel then
        alertError(triggerId, "❌ 레벨이 부족합니다.")
        return false
    end

    local delta = num - skill

    if delta > 0 then
        if point < delta then
            alertError(triggerId, "❌ 스킬 포인트가 부족합니다.")
            return false
        end
        point = point - delta
    elseif delta < 0 then
        point = point - delta  -- delta 음수라 환급
    else
        return true -- 변화 없음(조용히 성공 처리)
    end

    setChatVar(triggerId, skillKey, tostring(num))
    setChatVar(triggerId, "ct_ChikanPoint", tostring(point))

    return true
end

skill_1_Set = async(function(triggerId)
    local min, max, needLv = 0, 5, 1
    local input = alertInput(triggerId, "스킬 레벨 설정\n"..min.." ~ "..max):await()
    if not input then return end
    applySkillSet(triggerId, "ct_Skill_1", input, min, max, needLv)
end)

skill_2_Set = async(function(triggerId)
    local min, max, needLv = 0, 5, 1
    local input = alertInput(triggerId, "스킬 레벨 설정\n"..min.." ~ "..max):await()
    if not input then return end
    applySkillSet(triggerId, "ct_Skill_2", input, min, max, needLv)
