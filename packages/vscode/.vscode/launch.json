{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "Risu: watch core lsp extension and webview",
      "env": {
        "RISU_WORKBENCH_WEBVIEW_DEV_SERVER": "http://127.0.0.1:5173"
      }
    },
    {
      "name": "Run Extension (Webview HMR)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "Risu: watch core lsp extension and webview",
      "env": {
        "RISU_WORKBENCH_WEBVIEW_DEV_SERVER": "http://127.0.0.1:5173"
      }
    }
  ]
}
