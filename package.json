{
  "name": "risu-workbench",
  "private": true,
  "version": "1.0.0",
  "description": "RisuAI 캐릭터 번들러 - 모듈화를 통한 캐릭터 카드 생성 도구",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "risuai",
    "tstl",
    "typescript-to-lua",
    "vscode-extension",
    "workbench"
  ],
  "author": "NOEL",
  "license": "MIT",
  "scripts": {
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts' '*.{json,mjs}' '.prettierrc'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "luaparse": "^0.3.1",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.33.1"
  }
}
