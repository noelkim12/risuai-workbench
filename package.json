{
  "name": "risu-workbench",
  "private": true,
  "version": "1.0.0",
  "description": "RisuAI 캐릭터 번들러 - 모듈화를 통한 캐릭터 카드 생성 도구",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "risuai",
    "tstl",
    "typescript-to-lua",
    "vscode-extension",
    "workbench"
  ],
  "author": "NOEL",
  "license": "MIT",
  "scripts": {
    "wasm:build": "npm --workspace @risuai/lua-analyzer-wasm run build:wasm",
    "wasm:test:rust": "npm --workspace @risuai/lua-analyzer-wasm run test:rust",
    "wasm:test:wasm": "npm --workspace @risuai/lua-analyzer-wasm run test:wasm",
    "wasm:smoke": "npm --workspace @risuai/lua-analyzer-wasm run test:smoke",
    "wasm:check": "npm --workspace @risuai/lua-analyzer-wasm run test",
    "graph:build": "node ./scripts/graph/run-graphify.mjs build",
    "graph:mcp": "node ./scripts/graph/run-graphify.mjs mcp",
    "graph:review:build": "node ./scripts/graph/run-code-review-graph.mjs build",
    "graph:review:mcp": "node ./scripts/graph/run-code-review-graph.mjs serve",
    "verify:graph-workflow": "node --test ./scripts/graph/graph-workflow.test.mjs",
    "build:core": "npm run --workspace risu-workbench-core build",
    "build:cbs-lsp": "npm run --workspace cbs-language-server build",
    "build:vscode": "npm run --workspace risu-workbench-vscode build",
    "typecheck:cbs-lsp-release": "npm run build:core && npm run build:cbs-lsp && npm run build:vscode",
    "verify:cbs-lsp-release": "npm run typecheck:cbs-lsp-release && npm run --workspace cbs-language-server test && npm run --workspace cbs-language-server test:product-matrix && npm run --workspace risu-workbench-vscode verify:cbs-client",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish:cbs-lsp": "changeset publish",
    "release:smoke:published:cbs-lsp": "node ./scripts/release/smoke-published-cbs-lsp.mjs",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts' '*.{json,mjs}' '.prettierrc'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "luaparse": "^0.3.1",
    "prettier": "^3.5.3",
    "tsc-alias": "^1.8.0",
    "typescript-eslint": "^8.33.1"
  }
}
